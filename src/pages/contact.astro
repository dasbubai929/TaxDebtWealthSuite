---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="Contact Us — FinanceFlow Hub"
  description="Get in touch with the team at FinanceFlow Hub. Submit your inquiries, suggestions, or feedback using our secure contact channel."
>
  <div class="min-h-screen flex flex-col justify-between">
    
    <!-- Top Navigation Header -->
    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 sm:h-20">
          
          <!-- Logo & Branding -->
          <div class="flex items-center space-x-3">
            <a href="/" class="flex items-center space-x-3 hover:opacity-90 transition-opacity">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-brand-600 to-accent-emerald flex items-center justify-center shadow-lg shadow-brand-500/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h1 class="text-lg sm:text-xl font-bold tracking-tight text-white font-sans">
                  FinanceFlow<span class="text-brand-400">Hub</span>
                </h1>
                <p class="text-xs text-slate-400 hidden sm:block">Advanced Strategic Finance Suite</p>
              </div>
            </a>
          </div>

          <!-- Navigation Links / CTA -->
          <div class="flex items-center space-x-4">
            <a href="/" class="text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-800 transition-all focus-ring text-xs font-semibold flex items-center space-x-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              <span>Back to Calculators</span>
            </a>
          </div>

        </div>
      </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-grow max-w-lg w-full mx-auto px-4 py-12 sm:py-16 flex flex-col justify-center">
      
      <!-- Back Link for Mobile/SEO -->
      <div class="mb-6">
        <a href="/" class="inline-flex items-center text-xs font-semibold uppercase tracking-wider text-brand-400 hover:text-brand-300 transition-colors">
          &larr; Back to Calculators
        </a>
      </div>

      <!-- Glass Panel Card -->
      <div class="glass-panel p-6 sm:p-10 rounded-2xl shadow-2xl border border-slate-800 space-y-6">
        <div class="text-center">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight font-sans">Get in Touch</h1>
          <p class="text-xs text-slate-400 mt-2 leading-relaxed">
            Have suggestions, questions, or feedback? Send us a message and our team will get back to you shortly.
          </p>
        </div>

        <!-- Submission Status Indicator -->
        <div id="contact-success" class="hidden p-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-xl text-xs text-center leading-relaxed">
          <strong>Thank you!</strong> Your message has been received. We will get back to you as soon as possible.
        </div>

        <!-- Contact Form -->
        <form id="contact-form" action="#" method="POST" class="space-y-4">
          <!-- Full Name -->
          <div>
            <label for="contact-name" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Full Name</label>
            <input 
              type="text" 
              id="contact-name" 
              name="name"
              required 
              placeholder="John Doe"
              class="focus-ring block w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" 
            />
          </div>

          <!-- Email Address -->
          <div>
            <label for="contact-email" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Email Address</label>
            <input 
              type="email" 
              id="contact-email" 
              name="email"
              required 
              placeholder="john@example.com"
              class="focus-ring block w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" 
            />
          </div>

          <!-- Message -->
          <div>
            <label for="contact-message" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Message</label>
            <textarea 
              id="contact-message" 
              name="message"
              required 
              rows="4"
              placeholder="Tell us what you'd like to talk about..."
              class="focus-ring block w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm min-h-32 resize-y"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="focus-ring w-full py-3.5 bg-gradient-to-r from-brand-600 to-indigo-600 hover:from-brand-500 hover:to-indigo-500 text-white font-bold text-sm rounded-lg transition-all duration-300 shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30 flex items-center justify-center space-x-2 cursor-pointer h-12"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
            <span>Send Message</span>
          </button>
        </form>
      </div>

    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-800 bg-slate-950/90 py-10 text-xs text-slate-400">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <!-- Copyright & Disclaimer info -->
          <div class="max-w-xl space-y-2">
            <p class="font-semibold text-slate-300">
              &copy; 2026 FinanceFlow Hub. All rights reserved.
            </p>
            <p class="text-slate-500 leading-relaxed">
              Disclaimer: The calculators provided on this website are for informational and educational purposes only and do not constitute professional financial or legal advice.
            </p>
          </div>
          <!-- Legal & Info links -->
          <nav class="flex flex-wrap gap-x-6 gap-y-2 text-slate-400" aria-label="Footer Navigation">
            <a href="/about" class="hover:text-white transition-colors font-medium">About Us</a>
            <a href="/contact" class="hover:text-white transition-colors font-medium">Contact Us</a>
            <a href="/privacy-policy" class="hover:text-white transition-colors font-medium">Privacy Policy</a>
            <a href="/terms-conditions" class="hover:text-white transition-colors font-medium">Terms & Conditions</a>
          </nav>
        </div>
        <div class="border-t border-slate-900 pt-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-slate-600">
          <p>Calculations are estimates. All financial strategies contain risk.</p>
          <p>Hosted on Cloudflare Pages.</p>
        </div>
      </div>
    </footer>

  </div>
</Layout>

<script is:inline>
  document.getElementById("contact-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const successBox = document.getElementById("contact-success");
    const form = document.getElementById("contact-form");
    
    if (successBox && form) {
      successBox.classList.remove("hidden");
      form.reset();
      
      // Scroll success box into view smoothly
      successBox.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  });
</script>
