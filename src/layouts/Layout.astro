---
import "../styles/global.css";
import { getCollection } from "astro:content";

interface Props {
  title?: string;
  description?: string;
  robots?: string;
  ogImage?: string;
}

const { 
  title = "TaxDebtWealthSuite — Multi-Tool Wealth & Debt Suite", 
  description = "Analyze wealth optimization (Buy, Borrow, Die), calculate side-hustle corporate tax benefits, and schedule debt snowballs.",
  robots = "index, follow",
  ogImage = "https://taxdebtwealthsuite.com/images/og-home.png"
} = Astro.props;

const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalURL = new URL(canonicalPath, Astro.site || "https://taxdebtwealthsuite.com").toString();

// Determine if we are on one of the calculator tool pages
const path = canonicalPath;
const isCalculatorPage = ["/buy-borrow-die-calculator/", "/s-corp-tax-calculator/", "/debt-payoff-calculator/"].includes(path);

// Fetch latest 3 blog posts for the footer
const allPosts = (await getCollection("blog")).sort((a, b) => {
  const dateDiff = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  if (dateDiff !== 0) return dateDiff;
  // Secondary sort by title alphabetically if dates are identical
  return a.data.title.localeCompare(b.data.title);
});
const latestPosts = allPosts.slice(0, 3);
---

<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7LV68K7PQR" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-7LV68K7PQR');
    </script>
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <slot name="head" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@TaxDebtWealthSuite" />
    <meta name="twitter:creator" content="@TaxDebtWealthSuite" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" fetchpriority="high">

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "@id": "https://taxdebtwealthsuite.com/#organization",
        "name": "TaxDebtWealthSuite",
        "url": "https://taxdebtwealthsuite.com/",
        "logo": "https://taxdebtwealthsuite.com/favicon.svg",
        "sameAs": [
          "https://twitter.com/TaxDebtWealthSuite"
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://taxdebtwealthsuite.com/#website",
        "name": "TaxDebtWealthSuite",
        "url": "https://taxdebtwealthsuite.com/",
        "publisher": {
          "@id": "https://taxdebtwealthsuite.com/#organization"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": `${canonicalURL}#webpage`,
        "url": canonicalURL,
        "name": title,
        "description": description,
        "isPartOf": {
          "@id": "https://taxdebtwealthsuite.com/#website"
        },
        "about": {
          "@id": "https://taxdebtwealthsuite.com/#organization"
        }
      }
    ])} />
  </head>
  <body class="h-full bg-[#0A0F1D] text-[#F8FAFC] font-sans antialiased selection:bg-[#00F5D4]/30 selection:text-white overflow-y-auto custom-scrollbar">
    <div class="min-h-screen flex flex-col justify-between">
      
      <!-- Shared Header -->
      <header class="border-b border-[#1E294B] bg-[#141C32] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between py-4 md:h-20 gap-4">
            
            <!-- Logo & Navigation -->
            <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
              <a href="/" class="flex items-center space-x-3 hover:opacity-90 transition-opacity">
                <div class="w-10 h-10 rounded-lg bg-[#1E294B] border border-[#00F5D4]/30 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <span class="text-lg sm:text-xl font-bold tracking-tight text-white font-sans block">
                    TaxDebtWealth<span class="text-[#00F5D4]">Suite</span>
                  </span>
                  <span class="text-xs text-slate-400 hidden sm:block">Advanced Strategic Finance Suite</span>
                </div>
              </a>

              <nav class="flex items-center space-x-1" aria-label="Tools Navigation">
                <a href="/buy-borrow-die-calculator/" class={`text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-800 transition-all text-xs font-semibold ${path === '/buy-borrow-die-calculator' ? 'text-white bg-slate-800' : ''}`}>Buy, Borrow, Die</a>
                <a href="/s-corp-tax-calculator/" class={`text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-800 transition-all text-xs font-semibold ${path === '/s-corp-tax-calculator' ? 'text-white bg-slate-800' : ''}`}>S-Corp Tax</a>
                <a href="/debt-payoff-calculator/" class={`text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-800 transition-all text-xs font-semibold ${path === '/debt-payoff-calculator' ? 'text-white bg-slate-800' : ''}`}>Debt Payoff</a>
                <a href="/blog/" class={`text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-800 transition-all text-xs font-semibold ${Astro.url.pathname.startsWith('/blog') ? 'text-white bg-slate-800' : ''}`}>Blog</a>
              </nav>
            </div>

            <!-- Persistence Badge & Refresh Button (Only on calculator pages) -->
            {isCalculatorPage && (
              <div class="flex items-center justify-center space-x-3">
                <button id="toggle-autosave" class="inline-flex items-center justify-center px-2.5 py-1 rounded-full text-xs font-medium border transition-all duration-200 focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900 cursor-pointer whitespace-nowrap min-w-[7.5rem]" title="Click to toggle auto-save state">
                  <span id="autosave-dot" class="w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                  <span id="autosave-text">Auto-Save: On</span>
                </button>
                <button id="reset-state" class="text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-800 transition-all focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900 text-xs font-semibold flex items-center space-x-1.5" title="Reset all calculators">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18.2" />
                  </svg>
                  <span id="reset-btn-text">Reset Suite</span>
                </button>
              </div>
            )}

          </div>
        </div>
      </header>

      <!-- Main Slot Content -->
      <slot />

      <!-- Shared Footer -->
      <footer class="border-t border-[#1E294B] bg-[#0A0F1D] py-10 text-xs text-slate-400">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
          <!-- Sitemap block -->
          <div class="border-b border-slate-900 pb-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <div>
              <p class="font-bold text-slate-200 mb-3 font-sans tracking-wide uppercase text-3xs text-[#00F5D4]/80">Buy, Borrow, Die Calculator</p>
              <ul class="space-y-2 text-[#94A3B8]">
                <li><a href="/buy-borrow-die-calculator/" class="hover:text-[#00F5D4] transition-colors">United States (Default)</a></li>
                <li><a href="/buy-borrow-die-calculator/uk/" class="hover:text-[#00F5D4] transition-colors">United Kingdom (Lombard Loan)</a></li>
                <li><a href="/buy-borrow-die-calculator/canada/" class="hover:text-[#00F5D4] transition-colors">Canada (Margin Loan)</a></li>
                <li><a href="/buy-borrow-die-calculator/australia/" class="hover:text-[#00F5D4] transition-colors">Australia (Margin Lending)</a></li>
              </ul>
            </div>
            <div>
              <p class="font-bold text-slate-200 mb-3 font-sans tracking-wide uppercase text-3xs text-[#00F5D4]/80">S-Corp Tax Calculator</p>
              <ul class="space-y-2 text-[#94A3B8]">
                <li><a href="/s-corp-tax-calculator/" class="hover:text-[#00F5D4] transition-colors">United States (Default)</a></li>
                <li><a href="/s-corp-tax-calculator/uk/" class="hover:text-[#00F5D4] transition-colors">United Kingdom (Ltd Company)</a></li>
                <li><a href="/s-corp-tax-calculator/canada/" class="hover:text-[#00F5D4] transition-colors">Canada (CCPC)</a></li>
                <li><a href="/s-corp-tax-calculator/australia/" class="hover:text-[#00F5D4] transition-colors">Australia (Pty Ltd)</a></li>
              </ul>
            </div>
            <div>
              <p class="font-bold text-slate-200 mb-3 font-sans tracking-wide uppercase text-3xs text-[#00F5D4]/80">Debt Payoff Calculator</p>
              <ul class="space-y-2 text-[#94A3B8]">
                <li><a href="/debt-payoff-calculator/" class="hover:text-[#00F5D4] transition-colors">United States (Default)</a></li>
                <li><a href="/debt-payoff-calculator/uk/" class="hover:text-[#00F5D4] transition-colors">United Kingdom</a></li>
                <li><a href="/debt-payoff-calculator/canada/" class="hover:text-[#00F5D4] transition-colors">Canada</a></li>
                <li><a href="/debt-payoff-calculator/australia/" class="hover:text-[#00F5D4] transition-colors">Australia</a></li>
              </ul>
            </div>
            <div>
              <p class="font-bold text-slate-200 mb-3 font-sans tracking-wide uppercase text-3xs text-[#00F5D4]/80">Blog</p>
              <ul class="space-y-2 text-[#94A3B8]">
                {latestPosts.map(post => (
                  <li>
                    <a href={`/blog/${post.slug}/`} class="hover:text-[#00F5D4] transition-colors leading-snug block">
                      {post.data.title}
                    </a>
                  </li>
                ))}
                <li class="pt-2">
                  <a href="/blog/" class="text-[#00F5D4] hover:text-white transition-colors font-medium flex items-center gap-1 group">
                    View all articles
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                </li>
              </ul>
            </div>
          </div>
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <!-- Copyright & Disclaimer info -->
            <div class="max-w-xl space-y-2">
              <p class="font-semibold text-slate-300">
                &copy; 2026 TaxDebtWealthSuite. All rights reserved.
              </p>
              <p class="text-slate-500 leading-relaxed">
                Disclaimer: The calculators provided on this website are for informational and educational purposes only and do not constitute professional financial or legal advice.
              </p>
            </div>
            <!-- Legal & Info links -->
            <nav class="flex flex-wrap gap-x-6 gap-y-2 text-slate-400" aria-label="Footer Navigation">
              <a href="/author/" class="hover:text-white transition-colors font-medium">About the Author</a>
              <a href="/editorial-policy/" class="hover:text-white transition-colors font-medium">Editorial Policy</a>
              <a href="/methodology/" class="hover:text-white transition-colors font-medium">Methodology</a>
              <a href="/about/" class="hover:text-white transition-colors font-medium">About Us</a>
              <a href="/contact/" class="hover:text-white transition-colors font-medium">Contact Us</a>
              <a href="/privacy-policy/" class="hover:text-white transition-colors font-medium">Privacy Policy</a>
              <a href="/terms-conditions/" class="hover:text-white transition-colors font-medium">Terms & Conditions</a>
              <a href="/disclosure/" class="hover:text-white transition-colors font-medium">Disclosure</a>
            </nav>
          </div>
          <div class="border-t border-slate-900 pt-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-slate-600">
            <p>Calculations are estimates. All financial strategies contain risk.</p>
            <p>Hosted on Cloudflare Pages.</p>
          </div>
        </div>
      </footer>

      <!-- ============================================================ -->
      <!-- SHARE RESULTS MODAL — Global Overlay                         -->
      <!-- ============================================================ -->
      <div
        id="share-modal"
        class="fixed inset-0 z-[200] flex items-center justify-center p-4 hidden"
        role="dialog"
        aria-modal="true"
        aria-labelledby="share-modal-title"
      >
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeShareModal()" aria-hidden="true"></div>

        <!-- Panel -->
        <div class="share-modal-panel relative w-full max-w-sm bg-[#141C32] border border-[#1E294B] rounded-2xl shadow-2xl overflow-hidden">

          <!-- Gradient accent bar -->
          <div class="h-0.5 w-full bg-gradient-to-r from-transparent via-[#00F5D4]/60 to-transparent"></div>

          <div class="p-6 space-y-5">

            <!-- Header -->
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-xl bg-[#00F5D4]/10 border border-[#00F5D4]/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#00F5D4]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                  </svg>
                </div>
                <div>
                  <h3 id="share-modal-title" class="text-sm font-bold text-white">Share Your Results</h3>
                  <p class="text-3xs text-slate-400 mt-0.5">Help others discover this free financial suite.</p>
                </div>
              </div>
              <button
                onclick="closeShareModal()"
                class="p-1.5 rounded-lg text-slate-500 hover:text-white hover:bg-slate-800/80 transition-colors flex-shrink-0 mt-0.5"
                aria-label="Close share dialog"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <!-- Message Preview -->
            <div class="bg-[#0A0F1D] border border-[#1E294B] rounded-xl p-3.5">
              <p class="text-3xs font-bold uppercase tracking-wider text-[#00F5D4]/50 mb-2">Your Message</p>
              <p id="share-preview-text" class="text-xs text-slate-300 leading-relaxed"></p>
            </div>

            <!-- Platform Buttons -->
            <div class="grid grid-cols-3 gap-2.5">

              <!-- X / Twitter -->
              <a
                id="share-twitter"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col items-center gap-2 p-3 rounded-xl bg-[#0A0F1D] hover:bg-slate-800 border border-[#1E294B] hover:border-slate-600 transition-all duration-200"
                aria-label="Share on X / Twitter"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-500 group-hover:text-white transition-colors duration-200" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                <span class="text-3xs font-semibold text-slate-500 group-hover:text-slate-300 transition-colors duration-200">X / Twitter</span>
              </a>

              <!-- LinkedIn -->
              <a
                id="share-linkedin"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col items-center gap-2 p-3 rounded-xl bg-[#0A0F1D] hover:bg-[#0A66C2]/15 border border-[#1E294B] hover:border-[#0A66C2]/40 transition-all duration-200"
                aria-label="Share on LinkedIn"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-500 group-hover:text-[#0A66C2] transition-colors duration-200" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <span class="text-3xs font-semibold text-slate-500 group-hover:text-[#0A66C2] transition-colors duration-200">LinkedIn</span>
              </a>

              <!-- WhatsApp -->
              <a
                id="share-whatsapp"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col items-center gap-2 p-3 rounded-xl bg-[#0A0F1D] hover:bg-[#25D366]/10 border border-[#1E294B] hover:border-[#25D366]/30 transition-all duration-200"
                aria-label="Share on WhatsApp"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-500 group-hover:text-[#25D366] transition-colors duration-200" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
