---
import Layout from '../../../layouts/Layout.astro';

const seo = {
  title: "UK Capital Gains Tax Guide (2026) | Annual Exempt Allowance & Rates",
  description: "Comprehensive guide to UK Capital Gains Tax (CGT), annual exempt allowance (£3,000 limit), residential property rates, and ISA tax shelters.",
  schema: `
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "UK Capital Gains Tax Guide: Annual Exempt Allowance & Rates",
        "author": {
          "@type": "Person",
          "name": "Mrittunjoy Das"
        },
        "publisher": {
          "@type": "Organization",
          "name": "TaxDebtWealthSuite"
        },
        "datePublished": "2026-07-23",
        "dateModified": "2026-07-23",
        "description": "Comprehensive guide to UK Capital Gains Tax (CGT), annual exempt allowance, and ISA tax shelters."
      }
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the UK Capital Gains Tax Annual Exempt Allowance?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "For the tax year, the UK CGT Annual Exempt Amount is £3,000 for individuals."
            }
          }
        ]
      }
    </script>
  `
};
---

<Layout title={seo.title} description={seo.description} head={seo.schema}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-12 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-xs font-bold uppercase tracking-widest border border-emerald-500/20 mb-6">
        <span>UK Capital Gains Tax</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-6 leading-tight">
        UK Capital Gains Tax Guide
      </h1>
      <div class="flex items-center justify-center gap-4 text-sm text-slate-400">
        <span class="flex items-center gap-2">
          <img src="https://ui-avatars.com/api/?name=Mrittunjoy+Das&background=00F5D4&color=000" alt="Mrittunjoy Das" class="w-8 h-8 rounded-full" />
          By <span class="text-white font-medium">Mrittunjoy Das</span>
        </span>
        <span>•</span>
        <time datetime="2026-07-23">July 23, 2026</time>
      </div>
    </header>

    <!-- Embedded Calculator Callout Banner -->
    <div class="my-8 p-6 rounded-2xl bg-gradient-to-r from-[#141C32] to-[#1E294B] border border-[#00F5D4]/30 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="space-y-1">
        <span class="text-xs font-bold text-[#00F5D4] uppercase tracking-wider">Interactive Tool</span>
        <h3 class="text-lg font-bold text-white">UK Capital Gains Tax Calculator</h3>
        <p class="text-xs text-slate-300">Calculate UK CGT on shares and property after applying annual allowances.</p>
      </div>
      <a href="/capital-gains-tax-calculator/uk/" class="px-5 py-2.5 rounded-xl bg-[#00F5D4] hover:bg-[#00F5D4]/90 text-slate-950 font-bold text-xs whitespace-nowrap transition-all shadow-lg shadow-[#00F5D4]/20">
        Calculate UK Capital Gains →
      </a>
    </div>

    <div class="prose prose-invert max-w-none space-y-8 text-slate-300 text-base leading-relaxed">
      <section class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-4">
        <h2 class="text-2xl font-bold text-white border-b border-slate-800 pb-3">Introduction</h2>
        <p>
          HMRC imposes Capital Gains Tax on profits earned when disposing of assets in excess of the annual exempt allowance.
        </p>
      </section>

      <section class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-4">
        <h2 class="text-2xl font-bold text-white border-b border-slate-800 pb-3">Key Benefits</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>ISA Tax Shelters:</strong> Capital gains inside Stocks & Shares ISAs are completely tax-free.</li>
          <li><strong>Spousal Transfers:</strong> Transferring assets between spouses is tax-free.</li>
        </ul>
      </section>

      <section class="p-6 rounded-2xl bg-slate-900 border border-slate-800 space-y-3 text-xs text-slate-300">
        <h4 class="text-sm font-bold text-white">Methodology & HMRC Source References</h4>
        <p>Calculations adhere to HMRC Capital Gains Tax Manual rules.</p>
        <p><strong>Official Reference:</strong> <a href="https://www.gov.uk/capital-gains-tax" target="_blank" rel="noopener noreferrer" class="text-emerald-400 hover:underline">HMRC CGT Guide</a></p>
      </section>

      <section class="space-y-4 pt-4">
        <h3 class="text-xl font-bold text-white border-b border-slate-800 pb-3">Related Calculators & Tools</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="/capital-gains-tax-calculator/uk/" class="p-4 rounded-xl bg-slate-900 border border-slate-800 hover:border-[#00F5D4]/40 transition-all space-y-2">
            <span class="text-xs font-bold text-[#00F5D4] uppercase">Calculator</span>
            <h4 class="text-sm font-bold text-white">UK CGT Calculator</h4>
            <p class="text-xs text-slate-400">Calculate UK CGT on shares & property.</p>
          </a>
          <a href="/tax-loss-harvesting-calculator/uk/" class="p-4 rounded-xl bg-slate-900 border border-slate-800 hover:border-indigo-500/40 transition-all space-y-2">
            <span class="text-xs font-bold text-indigo-400 uppercase">Related Tool</span>
            <h4 class="text-sm font-bold text-white">Tax Loss Harvesting Tool</h4>
            <p class="text-xs text-slate-400">Harvest losses under Bed & Breakfast rules.</p>
          </a>
          <a href="/superannuation-rrsp-withdrawal-calculator/uk/" class="p-4 rounded-xl bg-slate-900 border border-slate-800 hover:border-amber-500/40 transition-all space-y-2">
            <span class="text-xs font-bold text-amber-400 uppercase">Related Tool</span>
            <h4 class="text-sm font-bold text-white">UK Pension Drawdown Tool</h4>
            <p class="text-xs text-slate-400">Model SIPP flexi-drawdowns.</p>
          </a>
        </div>
      </section>
    </div>
  </article>
</Layout>
