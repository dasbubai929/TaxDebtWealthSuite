---
import Layout from "../../../layouts/Layout.astro";
import BuyBorrowDieCalculator from "../../../components/BuyBorrowDieCalculator.astro";
---

<Layout
  title="Buy, Borrow, Die Calculator (Australia) | TaxDebtWealthSuite"
  description="Model the Buy, Borrow, Die strategy in Australia. Compare margin loan borrowing costs vs Capital Gains Tax, check margin call risk, and see your net wealth advantage."
  ogImage="https://taxdebtwealthsuite.com/images/og-buy-borrow-die.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/buy-borrow-die-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Buy, Borrow, Die Calculator (Australia)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "AUD" },
        "description": "Model the Buy, Borrow, Die strategy in Australia. Compare margin loan borrowing costs vs Capital Gains Tax, check margin call risk, and see your net wealth advantage."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is the Buy, Borrow, Die strategy legal?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, borrowing against your own assets is a standard financial practice and does not trigger a taxable event under current tax guidelines."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Buy, Borrow, Die Calculator (Australia)
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Model the Buy, Borrow, Die strategy in Australia. Compare margin loan borrowing costs vs Capital Gains Tax, check margin call risk, and see your net wealth advantage.
      </p>
    </div>

    <BuyBorrowDieCalculator defaultCurrency="AUD" />
  </main>
</Layout>
