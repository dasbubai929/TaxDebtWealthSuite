              <span class="text-3xs font-semibold text-slate-500 group-hover:text-[#25D366] transition-colors duration-200">WhatsApp</span>
            </a>

          </div>

          <!-- Copy to Clipboard -->
          <button
            id="share-copy-btn"
            onclick="window.copyShareText()"
            class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-[#1E294B] bg-[#0A0F1D] hover:border-[#00F5D4]/25 hover:bg-[#00F5D4]/5 text-slate-400 hover:text-[#00F5D4] text-xs font-semibold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-[#00F5D4]/30"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <span id="copy-btn-text">Copy Message</span>
          </button>

        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  @reference "../styles/global.css";

  /* Share modal — entrance animation */
  @keyframes share-modal-in {
    from { opacity: 0; transform: scale(0.96) translateY(6px); }
    to   { opacity: 1; transform: scale(1)    translateY(0);   }
  }
  .share-modal-panel {
    animation: share-modal-in 0.18s cubic-bezier(0.34, 1.3, 0.64, 1) forwards;
  }
</style>

<!-- Client-Side State Controller Script -->
<script>
  (function() {
    const STORAGE_KEY = "taxdebtwealthsuite_state_v1";
    const AUTOSAVE_KEY = "taxdebtwealthsuite_autosave_pref";

    function getAutoSavePref() {
      const raw = localStorage.getItem(AUTOSAVE_KEY);
      return raw !== null ? raw === "true" : true;
    }

    function triggerAutosaveIndicator(status) {
      const dot = document.getElementById("autosave-dot");
      const text = document.getElementById("autosave-text");
      const btn = document.getElementById("toggle-autosave");
      if (!dot || !text || !btn) return;

      const autoSave = getAutoSavePref();

      if (!autoSave) {
        btn.className = "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-slate-800/40 text-slate-400 border-slate-700 hover:bg-slate-800/80 hover:border-slate-600 transition-all duration-200 cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900";
        dot.className = "w-1.5 h-1.5 mr-1.5 rounded-full bg-slate-500";
        text.innerText = "Auto-Save: Off";
      } else if (status === "saving") {
        btn.className = "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-emerald-500/10 text-emerald-400 border-emerald-500/30 transition-all duration-200 cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900";
        dot.className = "w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-400 animate-pulse";
        text.innerText = "Saving...";
      } else {
        btn.className = "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-emerald-500/5 text-emerald-400/80 border-emerald-500/10 hover:bg-emerald-500/10 hover:border-emerald-500/20 transition-all duration-200 cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900";
        dot.className = "w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-500";
        text.innerText = "Saved (Local)";
      }
    }

    // Initialize indicator on DOM load
    window.addEventListener("DOMContentLoaded", () => {
      triggerAutosaveIndicator();

      const toggleBtn = document.getElementById("toggle-autosave");
      if (toggleBtn) {
        toggleBtn.addEventListener("click", () => {
          const autoSave = !getAutoSavePref();
          localStorage.setItem(AUTOSAVE_KEY, autoSave ? "true" : "false");
          triggerAutosaveIndicator();
          window.dispatchEvent(new CustomEvent("financial-hub-autosave-toggled", { detail: { autoSave } }));
        });
      }

      // Reset button confirmation pattern
      const resetBtn = document.getElementById("reset-state");
      let resetPending = false;
      let resetTimeout = null;
      if (resetBtn) {
        resetBtn.addEventListener("click", () => {
          const btnText = document.getElementById("reset-btn-text");
          if (!resetBtn || !btnText) return;

          if (!resetPending) {
            resetPending = true;
            const originalText = btnText.innerText;
            const originalClass = resetBtn.className;
            btnText.innerText = "Confirm Reset?";
            resetBtn.className = resetBtn.className.replace("text-slate-400", "text-amber-400 bg-amber-500/10 border border-amber-500/30");

            resetTimeout = setTimeout(() => {
              resetPending = false;
              btnText.innerText = originalText;
              resetBtn.className = originalClass;
            }, 3000);
            return;
          }

          resetPending = false;
          clearTimeout(resetTimeout);

          localStorage.removeItem(STORAGE_KEY);
          window.dispatchEvent(new Event("financial-hub-reset"));

          const originalText2 = "Reset Suite";
          const originalClass2 = resetBtn.className.replace("text-amber-400 bg-amber-500/10 border border-amber-500/30", "text-slate-400");
          btnText.innerText = "Cleared! ✓";
          resetBtn.className = resetBtn.className.replace("text-amber-400 bg-amber-500/10 border border-amber-500/30", "text-emerald-400 bg-emerald-500/10 border-emerald-500/30");

          setTimeout(() => {
            btnText.innerText = originalText2;
            resetBtn.className = originalClass2;
          }, 1500);
        });
      }
    });

    window.addEventListener("financial-hub-saving", () => {
      triggerAutosaveIndicator("saving");
    });
    window.addEventListener("financial-hub-saved", () => {
      triggerAutosaveIndicator("saved");
    });

    // ── Global Share Logic ──
    let _shareText = '';
    window.buildShareText = function(tabId) {
      const url = 'https://taxdebtwealthsuite.com/';
      if (tabId === 'tax') {
        const savings  = document.getElementById('tax-rec-savings')?.innerText;
        const recTitle = document.getElementById('tax-rec-title')?.innerText || '';
        if (savings && savings !== '—' && !recTitle.toLowerCase().includes('enter revenue')) {
          return `Just found out I could save ${savings}/yr by optimizing my business structure! Check if you're overpaying taxes: ${url}`;
        }
        return `Just calculated my optimal business structure using the Side-Hustle Tax Predictor! Check if you're overpaying taxes: ${url}`;
      }
      if (tabId === 'debt') {
        const avInterest = document.getElementById('debt-av-interest')?.innerText;
        const avTime     = document.getElementById('debt-av-time')?.innerText;
        if (avInterest && avInterest !== '$0' && avTime && avTime !== '—') {
          return `I just mapped my debt-free timeline — ${avTime} to pay off with only ${avInterest} in total interest! Try the Debt Payoff Planner: ${url}`;
        }
        return `I just mapped out my debt-free timeline using the Debt Payoff Planner. Try it yourself and accelerate your freedom: ${url}`;
      }
      if (tabId === 'bbd') {
        const netSaved = document.getElementById('bbd-net-saved')?.innerText;
        if (netSaved && netSaved !== '$0') {
          return `I'm preserving ${netSaved} in tax drag by borrowing instead of liquidating — modeled on the Buy, Borrow, Die calculator. Check your leverage safety score: ${url}`;
        }
        return `Just modeled my portfolio margin risk and tax drag on the Buy, Borrow, Die calculator. Check your leverage safety score here: ${url}`;
      }
      return `Free financial calculators for tax optimization, debt payoff, and portfolio strategy: ${url}`;
    };

    window.shareResults = function(tabId) {
      const text = window.buildShareText(tabId);
      _shareText = text;
      if (navigator.share) {
        navigator.share({
          title: 'TaxDebtWealthSuite — Free Financial Calculators',
          text:  text,
          url:   'https://taxdebtwealthsuite.com/'
        }).catch(() => {});
        return;
      }
      window.openShareModal(text);
    };

    window.openShareModal = function(text) {
      const modal = document.getElementById('share-modal');
      if (!modal) return;
      const enc     = encodeURIComponent(text);
      const siteEnc = encodeURIComponent('https://taxdebtwealthsuite.com/');
      document.getElementById('share-preview-text').innerText = text;
      document.getElementById('share-twitter').href  = `https://twitter.com/intent/tweet?text=${enc}`;
      document.getElementById('share-linkedin').href = `https://www.linkedin.com/sharing/share-offsite/?url=${siteEnc}&summary=${enc}`;
      document.getElementById('share-whatsapp').href = `https://api.whatsapp.com/send?text=${enc}`;
      document.getElementById('copy-btn-text').innerText = 'Copy Message';
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    window.closeShareModal = function() {
      const modal = document.getElementById('share-modal');
      if (!modal) return;
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    };

    window.copyShareText = function() {
      if (!_shareText) return;
      const btn  = document.getElementById('copy-btn-text');
      const done = () => {
        if (btn) {
          btn.innerText = 'Copied! ✓';
          setTimeout(() => { btn.innerText = 'Copy Message'; }, 2500);
        }
      };
      if (navigator.clipboard) {
        navigator.clipboard.writeText(_shareText).then(done).catch(() => {});
      } else {
        const ta = document.createElement('textarea');
        ta.value = _shareText;
        Object.assign(ta.style, { position: 'fixed', opacity: '0', top: '0', left: '0' });
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); done(); } catch (e) {}
        document.body.removeChild(ta);
      }
    };

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') window.closeShareModal();
    });
  })();
</script>
