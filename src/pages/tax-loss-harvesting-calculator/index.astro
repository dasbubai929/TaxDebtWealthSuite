---
import Layout from '../../layouts/Layout.astro';
import TaxLossHarvestingCalculator from '../../components/TaxLossHarvestingCalculator.astro';
---

<Layout
  title="Tax Loss Harvesting Calculator (US) | Wash-Sale Rules & Offsets"
  description="Calculate your estimated tax savings from harvesting investment losses in the United States. Instantly see how capital losses offset gains and up to $3,000 of ordinary income."
  ogImage="https://taxdebtwealthsuite.com/images/og-tax-loss-harvesting.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Tax Loss Harvesting Calculator (US)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "description": "Calculate your estimated tax savings from harvesting investment losses in the United States."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the IRS wash-sale rule?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The wash-sale rule prohibits you from claiming a capital loss on a security if you buy a 'substantially identical' security within 30 days before or after the sale."
            }
          },
          {
            "@type": "Question",
            "name": "How much ordinary income can I offset with capital losses?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "In the US, after your capital losses have offset your capital gains, you can use up to $3,000 of net capital loss per year to offset your ordinary income ($1,500 if married filing separately)."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Tax Loss Harvesting Calculator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Turn investment losses into tax savings by offsetting capital gains and up to $3,000 of ordinary income. Select your country to apply local tax code logic.
      </p>
    </div>

    <TaxLossHarvestingCalculator defaultCountry="us" />
  </main>
</Layout>
