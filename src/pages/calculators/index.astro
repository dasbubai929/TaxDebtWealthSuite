---
import Layout from "../../layouts/Layout.astro";

const title = "Financial Calculators Hub | Tax, Debt, Retirement & Wealth Tools";
const description = "Interactive calculators for smarter financial planning. Explore tax, retirement, debt, and wealth tools with linked guides and blogs.";

const breadcrumbs = [
  { name: "Home", url: "https://taxdebtwealthsuite.com/" },
  { name: "Calculators", url: "https://taxdebtwealthsuite.com/calculators/" }
];

const calculators = [
  { name: "S-Corp Tax Calculator", href: "/s-corp-tax-calculator/", category: "tax", blog: "/blog/s-corp-tax/", icon: "business", color: "emerald" },
  { name: "QBI Deduction Calculator", href: "/qbi-deduction-calculator/", category: "tax", blog: "/blog/qbi-deduction/", icon: "calculator", color: "cyan" },
  { name: "SALT Cap Deduction Calculator", href: "/salt-cap-deduction-calculator/", category: "tax", blog: "/blog/salt-cap-deduction/", icon: "currency", color: "purple" },
  { name: "Capital Gains Tax Calculator", href: "/capital-gains-tax-calculator/", category: "tax", blog: "/blog/capital-gains-tax-us/", icon: "trending", color: "lime" },
  { name: "Tax Loss Harvesting Calculator", href: "/tax-loss-harvesting-calculator/", category: "tax", blog: "/blog/tax-loss-harvesting-us/", icon: "chart", color: "orange" },
  { name: "Debt Payoff Planner", href: "/debt-payoff-calculator/", category: "debt", blog: "/blog/debt-payoff-planner/", icon: "chart", color: "rose" },
  { name: "Mortgage Recast Calculator", href: "/mortgage-recast-calculator/", category: "debt", blog: "/blog/mortgage-recast-us/", icon: "home", color: "teal" },
  { name: "Buy, Borrow, Die Calculator", href: "/buy-borrow-die-calculator/", category: "wealth", blog: "/blog/buy-borrow-die/", icon: "trending", color: "indigo" },
  { name: "Roth Conversion Calculator", href: "/roth-conversion-calculator/", category: "retirement", blog: "/blog/roth-conversion/", icon: "swap", color: "amber" },
  { name: "RMD Calculator", href: "/rmd-calculator/", category: "retirement", blog: "/blog/rmd-calculator-us/", icon: "clock", color: "blue" },
  { name: "Social Security & Pension Estimator", href: "/social-security-pension-estimator/", category: "retirement", blog: "/blog/social-security-us/", icon: "shield", color: "emerald" },
  { name: "Superannuation & RRSP Withdrawal", href: "/superannuation-rrsp-withdrawal-calculator/", category: "retirement", blog: "/blog/superannuation-rrsp-us/", icon: "currency", color: "purple" },
];
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs}>
  <main class="flex-grow pt-24 pb-20">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight font-sans mb-6">
        Financial Calculators <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00F5D4] to-blue-400">Hub</span>
      </h1>
      <p class="text-base sm:text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Explore interactive calculators for tax, debt, wealth, and retirement planning.
      </p>
    </section>

    <!-- Filters Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-10">
      <div class="flex flex-wrap items-center justify-center gap-3">
        <button class="filter-btn active px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-[#00F5D4]/10 text-[#00F5D4] border border-[#00F5D4]/30" data-filter="all">All</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="tax">Tax</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="debt">Debt</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="wealth">Wealth</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="retirement">Retirement</button>
      </div>
    </section>

    <!-- Calculators Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="calculators-grid">
        {calculators.map((calc) => (
          <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category={calc.category}>
            <div class="space-y-4">
              <h3 class="text-lg font-bold text-white tracking-wide font-sans">{calc.name}</h3>
              <p class="text-xs text-slate-400 leading-relaxed">
                Free interactive calculator with real-time results. Supports US, UK, Canada, and Australia.
              </p>
            </div>
            <div class="mt-8 space-y-2">
              <a href={calc.href} class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
                Try the Calculator
              </a>
              <a href={calc.blog} class="w-full flex items-center justify-center px-4 py-2 text-xs text-slate-400 hover:text-[#00F5D4] transition-colors font-semibold">
                Read the Guide →
              </a>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Empty State for Filters -->
      <div id="no-results" class="hidden text-center py-12">
        <p class="text-slate-500">No calculators found in this category.</p>
      </div>
    </section>

    <!-- Related Blogs CTA -->
    <section class="border-t border-slate-800/60 bg-gradient-to-b from-slate-950 to-slate-950/95 py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-white mb-4">Want to dive deeper?</h2>
        <p class="text-slate-400 mb-8 max-w-2xl mx-auto">
          Our financial calculators are paired with comprehensive guides and case studies. Explore our blog to master the strategies behind the math.
        </p>
        <a href="/blog/" class="inline-flex items-center justify-center px-8 py-3.5 border border-transparent text-sm font-bold rounded-xl text-slate-950 bg-[#00F5D4] hover:bg-white transition-colors duration-300 shadow-lg shadow-[#00F5D4]/20 uppercase tracking-widest">
          Read the Blog
        </a>
      </div>
    </section>
  </main>

  <script>
    // @ts-nocheck
    document.addEventListener("DOMContentLoaded", () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.calculator-card');
      const noResults = document.getElementById('no-results');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // Update active styles
          filterBtns.forEach(b => {
            b.classList.remove('active', 'bg-[#00F5D4]/10', 'text-[#00F5D4]', 'border-[#00F5D4]/30');
            b.classList.add('bg-slate-900', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:bg-slate-800');
          });
          btn.classList.add('active', 'bg-[#00F5D4]/10', 'text-[#00F5D4]', 'border-[#00F5D4]/30');
          btn.classList.remove('bg-slate-900', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:bg-slate-800');

          // Filter logic
          const filter = btn.getAttribute('data-filter');
          let visibleCount = 0;

          cards.forEach(card => {
            if (filter === 'all' || card.getAttribute('data-category') === filter) {
              card.style.display = 'flex';
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          });

          if (visibleCount === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        });
      });
    });
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Which calculators are available in the Financial Hub?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our hub includes tools for tax planning (S-Corp Tax Predictor, QBI Deduction, SALT Cap), retirement (Roth Conversion, Required Minimum Distributions), wealth management (Buy, Borrow, Die strategy), and debt (Debt Payoff Planner)."
          }
        },
        {
          "@type": "Question",
          "name": "Are these calculators country-specific?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Many of our calculators, such as the Side-Hustle S-Corp Tax Predictor, Buy, Borrow, Die calculator, and Required Minimum Distributions tool, support multiple jurisdictions including the US, UK, Canada, and Australia."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use the calculators?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Simply click on any calculator card to open the tool. You can adjust your financial parameters dynamically, and the interactive visualizations will update in real-time. Our auto-save feature ensures your inputs are preserved."
          }
        }
      ]
    }
  </script>
</Layout>
