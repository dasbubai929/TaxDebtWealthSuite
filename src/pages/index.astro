---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="TaxDebtWealthSuite | Free Interactive Tax, Debt, and Wealth Suite"
  description="Analyze portfolio borrowing strategy (Buy, Borrow, Die), calculate side-hustle corporate tax benefits, and model debt payoff schedules."
>
  <!-- Main Outer Container -->
  <div class="min-h-screen flex flex-col justify-between">
    
    <!-- Top Navigation Header -->
    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 sm:h-20">
          
          <!-- Logo & Branding -->
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-brand-600 to-accent-emerald flex items-center justify-center shadow-lg shadow-brand-500/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h1 class="text-lg sm:text-xl font-bold tracking-tight text-white font-sans">
                TaxDebtWealth<span class="text-brand-400">Suite</span>
              </h1>
              <p class="text-xs text-slate-400 hidden sm:block">Advanced Strategic Finance Suite</p>
            </div>
          </div>

          <!-- Persistence Badge & Refresh Button -->
          <div class="flex items-center space-x-3">
            <button id="toggle-autosave" class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border transition-all duration-200 focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900 cursor-pointer" title="Click to toggle auto-save state">
              <span id="autosave-dot" class="w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-400"></span>
              <span id="autosave-text">Auto-Save: On</span>
            </button>
            <button id="reset-state" class="text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-800 transition-all focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900 text-xs font-semibold flex items-center space-x-1.5" title="Reset all calculators">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18.2" />
              </svg>
              <span id="reset-btn-text">Reset Suite</span>
            </button>
          </div>

        </div>
      </div>
    </header>

    <!-- Main Workspace Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
      
      <!-- Responsive Tab Controller Matrix -->
      <div class="mb-8">
        <!-- Horizontal Scrollable Container on Mobile -->
        <div class="overflow-x-auto no-scrollbar -mx-4 px-4 sm:mx-0 sm:px-0 border-b border-slate-800">
          <div class="flex space-x-1 min-w-max sm:min-w-0 sm:space-x-2" role="tablist" aria-label="Financial Tools">
            
            <button id="tab-btn-bbd" class="tab-btn active-tab focus-ring px-4 py-3 sm:px-5 sm:py-4 text-sm font-semibold rounded-t-xl transition-all duration-200 border-b-2 flex items-center space-x-2" role="tab" aria-selected="true" aria-controls="panel-bbd">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
              <span>Buy, Borrow, Die</span>
            </button>

            <button id="tab-btn-tax" class="tab-btn inactive-tab focus-ring px-4 py-3 sm:px-5 sm:py-4 text-sm font-semibold rounded-t-xl transition-all duration-200 border-b-2 flex items-center space-x-2" role="tab" aria-selected="false" aria-controls="panel-tax">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              <span>Side-Hustle Tax Predictor</span>
            </button>

            <button id="tab-btn-debt" class="tab-btn inactive-tab focus-ring px-4 py-3 sm:px-5 sm:py-4 text-sm font-semibold rounded-t-xl transition-all duration-200 border-b-2 flex items-center space-x-2" role="tab" aria-selected="false" aria-controls="panel-debt">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
              </svg>
              <span>Debt payoff planner</span>
            </button>
            
          </div>
        </div>
      </div>

      <!-- ========================================== -->
      <!-- TAB 1: Buy, Borrow, Die Portfolio wealth  -->
      <!-- ========================================== -->
      <section id="panel-bbd" class="tab-panel space-y-6" role="tabpanel" aria-labelledby="tab-btn-bbd">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
          
          <!-- Parameters Card (Left Column) -->
          <div class="space-y-6">
            <div class="glass-panel p-6 rounded-2xl shadow-xl space-y-6 border border-slate-800">
              <div>
                <h3 class="text-lg font-bold text-white tracking-wide">Strategy Parameters</h3>
                <p class="text-xs text-slate-400 mt-1">Configure your portfolio structure and borrowing parameters.</p>
              </div>

              <!-- Inputs -->
              <div class="space-y-4">
                <!-- Currency Selector -->
                <div>
                  <label for="bbd-currency" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Currency</label>
                  <select id="bbd-currency" class="focus-ring block w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12 cursor-pointer">
                    <option value="USD">USD ($)</option>
                    <option value="GBP">GBP (£)</option>
                    <option value="CAD">CAD (C$)</option>
                    <option value="AUD">AUD (A$)</option>
                  </select>
                </div>

                <!-- Total Portfolio Value -->
                <div>
                  <label for="bbd-portfolio" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Total Portfolio Value</label>
                  <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium bbd-currency-symbol">$</div>
                    <input type="number" id="bbd-portfolio" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="1000" placeholder="0" />
                  </div>
                </div>

                <!-- Asset Cost Basis -->
                <div>
                  <label for="bbd-basis" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Asset Cost Basis</label>
                  <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium bbd-currency-symbol">$</div>
                    <input type="number" id="bbd-basis" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="1000" placeholder="0" />
                  </div>
                  <p class="text-3xs text-slate-500 mt-1">Used to calculate unrealized capital gains for tax drag comparison.</p>
                </div>

                <!-- Capital Gains Tax Rate -->
                <div>
                  <label for="bbd-tax-rate" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Capital Gains Tax Rate (%)</label>
                  <div class="relative rounded-lg shadow-sm">
                    <input type="number" id="bbd-tax-rate" class="focus-ring block w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" max="100" step="0.1" placeholder="0" />
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-slate-400 font-medium">%</div>
                  </div>
                  
                  <!-- Country Presets -->
                  <div class="flex flex-wrap gap-2 mt-2" aria-label="Country Tax Presets">
                    <button type="button" class="tax-preset-btn px-2.5 py-1 text-xs rounded bg-slate-800 hover:bg-slate-700 text-slate-300 font-semibold transition cursor-pointer" data-rate="20">US Preset (20%)</button>
                    <button type="button" class="tax-preset-btn px-2.5 py-1 text-xs rounded bg-slate-800 hover:bg-slate-700 text-slate-300 font-semibold transition cursor-pointer" data-rate="20">UK Preset (20%)</button>
                    <button type="button" class="tax-preset-btn px-2.5 py-1 text-xs rounded bg-slate-800 hover:bg-slate-700 text-slate-300 font-semibold transition cursor-pointer" data-rate="26.5">CA Preset (26.5%)</button>
                    <button type="button" class="tax-preset-btn px-2.5 py-1 text-xs rounded bg-slate-800 hover:bg-slate-700 text-slate-300 font-semibold transition cursor-pointer" data-rate="22.5">AU Preset (22.5%)</button>
                  </div>
                </div>

                <!-- Desired Cash to Borrow -->
                <div>
                  <label for="bbd-borrow-amount" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Desired Cash to Borrow / Draw</label>
                  <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium bbd-currency-symbol">$</div>
                    <input type="number" id="bbd-borrow-amount" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="1000" placeholder="0" />
                  </div>
                </div>

                <!-- SBLOC Interest Rate -->
                <div>
                  <label for="bbd-interest-rate" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">SBLOC / Margin Interest Rate (%)</label>
                  <div class="relative rounded-lg shadow-sm">
                    <input type="number" id="bbd-interest-rate" class="focus-ring block w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" max="100" step="0.1" placeholder="0" />
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-slate-400 font-medium">%</div>
                  </div>
                </div>

              </div>
            </div>
            
            <!-- Explainer -->
            <div class="bg-gradient-to-br from-slate-900 to-indigo-950/40 p-5 rounded-2xl border border-slate-850 space-y-3">
              <h4 class="text-xs font-bold tracking-wider text-brand-300 uppercase">Buy, Borrow, Die Mechanics</h4>
              <p class="text-xs text-slate-300 leading-relaxed">
                Rather than selling appreciated assets and triggering immediate capital gains taxes (the "Sell Asset" route), high-net-worth investors borrow against their portfolios using a Security-Backed Line of Credit (SBLOC). This keeps the asset compounding unchecked. Upon death, the assets receive a stepped-up basis, erasing capital gains taxes for heirs, who then repay the loan with tax-free funds.
              </p>
            </div>
          </div>

          <!-- Real-Time Outputs (Right Column) -->
          <div class="space-y-6">
            
            <!-- Comparison Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              
              <!-- Sell Route -->
              <div class="glass-panel p-6 rounded-2xl border border-slate-800/80 bg-slate-900/20">
                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-2xs font-semibold bg-rose-500/10 text-rose-400 border border-rose-500/20 uppercase tracking-widest">Sell Asset Route</span>
                <p class="text-xs text-slate-400 mt-2.5 font-medium uppercase tracking-wider">Immediate Tax Paid (Drag)</p>
                <p id="bbd-sell-tax" class="text-3xl font-black text-rose-400 mt-1 Outfit font-extrabold">$0</p>
                <div class="mt-4 pt-3 border-t border-slate-800/80 flex justify-between text-xs text-slate-400">
                  <span>Net Remaining Portfolio:</span>
                  <span id="bbd-sell-net" class="font-bold text-white">$0</span>
                </div>
              </div>

              <!-- Borrow Route -->
              <div class="glass-panel p-6 rounded-2xl border border-indigo-500/10 bg-gradient-to-tr from-slate-900/40 to-indigo-950/10">
                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-2xs font-semibold bg-brand-500/20 text-brand-300 border border-brand-500/30 uppercase tracking-widest">Borrow (SBLOC) Route</span>
                <p class="text-xs text-slate-400 mt-2.5 font-medium uppercase tracking-wider">Annual Interest Cost</p>
                <p id="bbd-borrow-interest" class="text-3xl font-black text-white mt-1 Outfit font-extrabold">$0</p>
                <div class="mt-4 pt-3 border-t border-slate-800/80 flex justify-between text-xs text-slate-400">
                  <span>Current Loan-to-Value (LTV):</span>
                  <span id="bbd-borrow-ltv" class="font-bold text-white">0%</span>
                </div>
              </div>

            </div>

            <!-- Net Savings Banner -->
            <div id="bbd-savings-banner" class="p-5 rounded-2xl border transition-all duration-300 flex items-center justify-between bg-slate-900 border-slate-800">
              <div class="flex items-center space-x-3">
                <div id="bbd-savings-icon" class="p-2.5 rounded-xl bg-slate-800 text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-white">1-Year Strategy Advantage</h4>
                  <p class="text-xs text-slate-400">Net wealth saved by borrowing instead of liquidating assets.</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-3xs uppercase font-bold text-slate-400 tracking-wider">Net Wealth Saved</p>
                <p id="bbd-net-saved" class="text-xl sm:text-2xl font-black text-slate-300 Outfit font-extrabold">$0</p>
              </div>
            </div>

            <!-- Risk Indicator & Price Drop Warning Meter -->
            <div class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-6">
              <div class="flex items-center justify-between">
                <h4 class="text-sm font-bold text-white uppercase tracking-wider">Margin Call Risk Profiler</h4>
                <span id="bbd-risk-status" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-800 text-slate-400 border border-slate-700 uppercase">No Loan</span>
              </div>

              <!-- Warning Alert box -->
              <div id="bbd-risk-alert" class="p-4 rounded-xl text-xs leading-relaxed transition-all duration-300 bg-slate-900/50 border border-slate-800 text-slate-300">
                Enter portfolio and loan parameters to analyze liquidation risk and margin call buffers.
              </div>

              <!-- Risk Zones Progress Bar -->
              <div class="space-y-2">
                <div class="flex justify-between text-xs text-slate-400">
                  <span>Current Loan LTV</span>
                  <span id="bbd-risk-ltv-label" class="font-bold text-white">0%</span>
                </div>
                <div class="relative w-full h-4 bg-slate-900 rounded-full overflow-hidden border border-slate-800 flex">
                  <!-- Track markers (LTV 30%, 50%) -->
                  <div class="h-full bg-emerald-500/25 border-r border-emerald-500/10" style="width: 30%"></div>
                  <div class="h-full bg-amber-500/25 border-r border-amber-500/10" style="width: 20%"></div>
                  <div class="h-full bg-rose-500/25" style="width: 50%"></div>
                  
                  <!-- Current LTV Pointer Overlay -->
                  <div id="bbd-risk-pointer" class="absolute top-0 bottom-0 w-1.5 bg-white shadow-lg transition-all duration-500" style="left: 0%; transform: translateX(-50%);"></div>
                </div>
                
                <!-- Zone Labels -->
                <div class="flex justify-between text-4xs uppercase tracking-wider text-slate-500 font-bold px-1">
                  <span>Low Risk (0-30%)</span>
                  <span>Moderate (30-50%)</span>
                  <span>High Risk (50%+)</span>
                </div>
              </div>

              <!-- Price Drop Buffer Card -->
              <div class="p-4 bg-slate-950/80 rounded-xl border border-slate-900 flex justify-between items-center">
                <div>
                  <p class="text-2xs font-semibold text-slate-400 uppercase tracking-wider">Margin Call Price Drop Buffer</p>
                  <p class="text-3xs text-slate-500 mt-0.5">Asset price decline required to hit 70% LTV maintenance margin limit.</p>
                </div>
                <p id="bbd-price-drop" class="text-lg sm:text-2xl font-black text-white Outfit font-extrabold">N/A</p>
              </div>

            </div>

          </div>

        </div>
      </section>

      <!-- ========================================== -->
      <!-- TAB 2: Side-Hustle Tax Predictor         -->
      <!-- ========================================== -->      <section id="panel-tax" class="tab-panel space-y-6 hidden" role="tabpanel" aria-labelledby="tab-btn-tax">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

          <!-- LEFT: Inputs -->
          <div class="space-y-6">
            <div class="glass-panel p-6 rounded-2xl shadow-xl space-y-5 border border-slate-800">
              <div>
                <h3 class="text-lg font-bold text-white tracking-wide">Business &amp; Income Details</h3>
                <p class="text-xs text-slate-400 mt-1">Enter your figures to compare unincorporated vs. corporate tax structures.</p>
              </div>

              <div class="space-y-4">
                <!-- Country Selector -->
                <div>
                  <label for="tax-country" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Country / Jurisdiction</label>
                  <select id="tax-country" class="focus-ring block w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12 cursor-pointer">
                    <option value="US">🇺🇸 United States</option>
                    <option value="UK">🇬🇧 United Kingdom</option>
                    <option value="CA">🇨🇦 Canada</option>
                    <option value="AU">🇦🇺 Australia</option>
                  </select>
                </div>

                <!-- Gross Revenue -->
                <div>
                  <label for="tax-revenue" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Annual Side-Hustle Gross Revenue</label>
                  <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium tax-currency-symbol">$</div>
                    <input type="number" id="tax-revenue" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="1000" placeholder="0" />
                  </div>
                </div>

                <!-- Business Expenses -->
                <div>
                  <label for="tax-expenses" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Annual Deductible Business Expenses</label>
                  <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium tax-currency-symbol">$</div>
                    <input type="number" id="tax-expenses" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="500" placeholder="0" />
                  </div>
                </div>

                <!-- Day Job Income -->
                <div>
                  <label for="tax-w2" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">
                    <span id="tax-w2-label">W2 / PAYE Day-Job Annual Income</span>
                  </label>
                  <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium tax-currency-symbol">$</div>
                    <input type="number" id="tax-w2" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="1000" placeholder="0" />
                  </div>
                  <p class="text-3xs text-slate-500 mt-1">Used to calculate your marginal tax bracket — crucial for accuracy.</p>
                </div>
              </div>
            </div>

            <!-- Country Explainer Card -->
            <div id="tax-country-tip" class="bg-gradient-to-br from-slate-900 to-indigo-950/40 p-5 rounded-2xl border border-slate-850 space-y-3">
              <h4 class="text-xs font-bold tracking-wider text-brand-300 uppercase">How Your Country Is Calculated</h4>
              <p id="tax-country-tip-text" class="text-xs text-slate-300 leading-relaxed">
                Select your country above to see jurisdiction-specific tax rates and corporate structure guidance.
              </p>
            </div>
          </div>

          <!-- RIGHT: Real-Time Outputs -->
          <div class="space-y-6">

            <!-- Break-Even / Recommendation Banner -->
            <div id="tax-recommendation-banner" class="p-6 rounded-2xl border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-slate-900 border-slate-800">
              <div class="flex items-center space-x-4">
                <div id="tax-rec-icon" class="p-3 rounded-xl bg-slate-800 text-slate-400 hidden sm:flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-widest text-slate-400">Optimal Structure</p>
                  <h4 id="tax-rec-title" class="text-lg font-extrabold text-white mt-0.5">Enter revenue to begin</h4>
                  <p id="tax-breakeven-msg" class="text-xs text-slate-400 mt-1"></p>
                </div>
              </div>
              <div class="text-left sm:text-right flex-shrink-0">
                <p class="text-2xs font-semibold uppercase tracking-wider text-slate-400">Annual Tax Saved</p>
