---
import Layout from '../../../layouts/Layout.astro';
import TaxLossHarvestingCalculator from '../../../components/TaxLossHarvestingCalculator.astro';
---

<Layout
  title="Tax Loss Harvesting Calculator (Australia) | ATO Wash Sale Rules"
  description="Calculate your estimated tax savings from harvesting capital losses in Australia. Understand ATO wash sale rules and how losses interact with the 50% CGT discount."
  ogImage="https://taxdebtwealthsuite.com/images/og-tax-loss-harvesting.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Tax Loss Harvesting Calculator (Australia)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "AUD" },
        "description": "Calculate your estimated tax savings from harvesting capital losses in Australia under ATO rules."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is an ATO wash sale?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The ATO defines a wash sale as disposing of an asset to crystallize a capital loss, then reacquiring the same or substantially similar asset shortly after. If determined to be for tax benefit only, the loss can be denied under Part IVA."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Tax Loss Harvesting Calculator (Australia)
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Calculate your potential ATO tax savings by harvesting capital losses, factoring in the 50% CGT discount and Part IVA anti-avoidance rules.
      </p>
    </div>

    <TaxLossHarvestingCalculator defaultCountry="australia" />
  </main>
</Layout>
