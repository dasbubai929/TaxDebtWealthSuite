---
import Layout from "../../../layouts/Layout.astro";
import RmdCalculator from "../../../components/RmdCalculator.astro";
---

<Layout
  title="Australia Superannuation Minimum Drawdown Calculator"
  description="Calculate the required minimum percentage drawdown for Account-Based Pensions."
>
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Superannuation Minimum Drawdown Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": {
          "@id": "https://taxdebtwealthsuite.com/#organization"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "AUD"
        },
        "description": "Calculate the required minimum percentage drawdown for Account-Based Pensions."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is an Account-Based Pension?",
            "acceptedAnswer": {
               "@type": "Answer",
               "text": "An Account-Based Pension is a regular income stream bought with money from your superannuation when you reach your preservation age and retire."
            }
          },
          {
            "@type": "Question",
            "name": "What are the minimum drawdown rates for superannuation?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The Australian Government sets minimum annual payment limits that you must withdraw from your super pension. The rates increase as you get older, starting at 4% for those under 65 and capping at 14% for those 95 and older."
            }
          }
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://taxdebtwealthsuite.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Australia Super Minimum Drawdown Calculator",
            "item": "https://taxdebtwealthsuite.com/rmd-calculator/australia/"
          }
        ]
      }
    ]
  }
  </script>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    <!-- Title Section -->
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Superannuation Minimum Drawdown Calculator (AU)
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-xs font-medium text-slate-500 bg-slate-900/50 inline-flex px-3 py-1.5 rounded-lg border border-slate-800">
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#00F5D4]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>Reviewed by <a href="/editorial-policy/" class="text-slate-400 hover:text-[#00F5D4] transition-colors underline decoration-slate-700 underline-offset-2">Editorial Staff</a></span>
        </div>
      </div>
      <p class="text-sm text-slate-400 mt-2 max-w-2xl leading-relaxed">
        Calculate the required minimum percentage drawdown for your Account-Based Pension based on your age.
      </p>
    </div>

    <!-- Calculator Component Island -->
    <RmdCalculator country="australia" />

    <!-- Explainer Content -->
    <div class="border-t border-slate-800/60 mt-12 bg-gradient-to-b from-slate-950 to-slate-950/95">
      <div class="max-w-4xl mx-auto py-16">
        <section>
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Financial Tool</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight leading-snug">
              Understanding Superannuation Drawdowns
            </h2>
          </div>

          <div class="space-y-8 text-sm text-slate-400 leading-relaxed">
            <article>
              <h3 class="text-xl font-bold text-slate-100 mb-3">Introduction</h3>
              <p>When you transition your superannuation into an Account-Based Pension (also known as an allocated pension), the Australian Government requires you to withdraw a minimum amount each financial year. This minimum is a percentage of your account balance, and the percentage increases as you get older.</p>
              <p class="mt-2">For a detailed breakdown of minimums and strategies, read our full article on <a href="/blog/rmd-calculator-australia/" class="text-[#00F5D4] hover:underline">Superannuation Minimum Drawdowns</a>.</p>
            </article>
            
            <article>
              <h3 class="text-xl font-bold text-slate-100 mb-3">Related Tools</h3>
              <p>While structured around US tax code, concepts in our <a href="/roth-conversion-calculator/" class="text-[#00F5D4] hover:underline">Roth Conversion Calculator</a> may provide insight into paying taxes upfront vs. managing tax-free growth.</p>
            </article>
          </div>

          <!-- FAQ Accordion -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-amber-500/10 text-amber-400 border border-amber-500/20 mb-4">FAQ</span>
            <h3 class="text-2xl font-bold text-white mb-6">Frequently Asked Questions</h3>

            <div class="space-y-4">
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">What is an Account-Based Pension?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  An Account-Based Pension is a regular income stream bought with money from your superannuation when you reach your preservation age and retire.
                </div>
              </div>
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">What are the minimum drawdown rates for superannuation?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  The Australian Government sets minimum annual payment limits that you must withdraw from your super pension. The rates increase as you get older, starting at 4% for those under 65 and capping at 14% for those 95 and older.
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
