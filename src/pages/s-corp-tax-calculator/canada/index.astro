---
import Layout from "../../../layouts/Layout.astro";
import SCorpTaxCalculator from "../../../components/SCorpTaxCalculator.astro";
---

<Layout
  title="Corporation vs Sole Proprietor Tax Calculator (Canada) | TaxDebtWealthSuite"
  description="Compare your tax bill as a sole proprietor vs corporation in Canada. Free salary vs distribution optimizer for freelancers and contractors."
  ogImage="https://taxdebtwealthsuite.com/images/og-s-corp-tax.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/s-corp-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/s-corp-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/s-corp-tax-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/s-corp-tax-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/s-corp-tax-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Corporation vs Sole Proprietor Tax Calculator (Canada)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CAD" },
        "description": "Compare your tax bill as a sole proprietor vs corporation in Canada. Free salary vs distribution optimizer for freelancers and contractors."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "When should I incorporate?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Generally, it makes sense when your net profits consistently exceed the threshold where tax savings on distributions outweigh the accounting compliance costs."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Corporation vs Sole Proprietor Tax Calculator (Canada)
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Compare your tax bill as a sole proprietor vs corporation in Canada. Free salary vs distribution optimizer for freelancers and contractors.
      </p>
    </div>

    <SCorpTaxCalculator defaultCountry="CA" />
  </main>
</Layout>
