---
import Layout from "../../../layouts/Layout.astro";
import SocialSecurityPensionEstimator from "../../../components/SocialSecurityPensionEstimator.astro";
---

<Layout
  title="Canada Pension Plan & OAS Estimator | CPP & OAS Calculator"
  description="Estimate your combined CPP (Canada Pension Plan) and OAS (Old Age Security) monthly retirement benefits."
  ogImage="https://taxdebtwealthsuite.com/images/og-social-security-ca.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/social-security-pension-estimator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/social-security-pension-estimator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/social-security-pension-estimator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/social-security-pension-estimator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/social-security-pension-estimator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Canada CPP & OAS Pension Estimator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": {
          "@id": "https://taxdebtwealthsuite.com/#organization"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "CAD"
        },
        "description": "Estimate your combined Canada Pension Plan (CPP) and Old Age Security (OAS) monthly benefits."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How does early CPP retirement affect my payment?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Taking CPP at age 60 reduces your monthly payment by 36% (-0.6% per month before age 65). Delaying to age 70 increases your CPP payment by 42% (+0.7% per month)."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Canada Pension Plan (CPP) & OAS Estimator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Calculate your projected CPP and OAS retirement benefits, evaluate early vs. delayed claiming factors, and optimize your retirement strategy.
      </p>
    </div>

    <SocialSecurityPensionEstimator country="canada" />
  </main>
</Layout>
