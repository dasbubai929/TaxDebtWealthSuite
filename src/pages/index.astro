  // ─────────────────────────────────────────────────────────────────────
  // TAX MATH ENGINE
  // ─────────────────────────────────────────────────────────────────────
  function calculateTax() {
    const country = state.tax.country || "US";
    const cfg = TAX_CONFIGS[country] || TAX_CONFIGS.US;
    const rev  = parseFloat(state.tax.revenue)  || 0;
    const exp  = parseFloat(state.tax.expenses) || 0;
    const w2   = parseFloat(state.tax.w2)       || 0;
    const netProfit = Math.max(0, rev - exp);

    let soleSE = 0, soleIT = 0, soleTotalTax = 0;
    let corpTax = 0, corpIT = 0, corpTotalTax = 0;

    // ── US ──────────────────────────────────────────────────────────────
    if (country === "US") {
      function usIT(income) {
        const i = Math.max(0, income - 15000); // standard deduction 2026 est.
        if (i <= 11925)  return i * 0.10;
        if (i <= 48475)  return 1192.5 + (i - 11925) * 0.12;
        if (i <= 103350) return 5578.5 + (i - 48475) * 0.22;
        if (i <= 197300) return 17651 + (i - 103350) * 0.24;
        if (i <= 250525) return 40199 + (i - 197300) * 0.32;
        if (i <= 626350) return 57231 + (i - 250525) * 0.35;
        return 188769.75 + (i - 626350) * 0.37;
      }
      // SE tax: 15.3% on 92.35% of net profit (SS cap $184,500, Medicare unlimited)
      const ssCap = 184500;
      const net9235 = netProfit * 0.9235;
      const ssPortion = Math.min(net9235, ssCap) * 0.124; // 12.4% SS
      const medPortion = net9235 * 0.029;                  // 2.9% Medicare
      soleSE = ssPortion + medPortion;
      const soleDeduction = soleSE * 0.5;
      soleIT = Math.max(0, usIT(w2 + netProfit - soleDeduction) - usIT(w2));
      soleTotalTax = soleSE + soleIT;

      // S-Corp: optimal salary = 40% of net profit (reasonable salary floor)
      const sSalary = Math.min(netProfit * 0.40, 150000);
      const sDist = Math.max(0, netProfit - sSalary);
      const ssCapCorpSalary = Math.min(sSalary * 0.9235, ssCap);
      corpTax = ssCapCorpSalary * 0.124 + sSalary * 0.9235 * 0.029; // FICA
      const corpDeductEmployer = corpTax * 0.5;
      corpIT = Math.max(0, usIT(w2 + sSalary + sDist - corpDeductEmployer) - usIT(w2));
      corpTotalTax = corpTax + corpIT;
    }

    // ── UK ──────────────────────────────────────────────────────────────
    else if (country === "UK") {
      function ukIT(income) {
        const pa = 12570; // Personal Allowance
        const taxable = Math.max(0, income - pa);
        if (taxable <= 37700)  return taxable * 0.20;                          // Basic
        if (taxable <= 125140) return 7540 + (taxable - 37700) * 0.40;         // Higher
        return 42140 + (taxable - 125140) * 0.45;                              // Additional
      }
      // Sole Trader: Class 4 NI 6% on £12,570–£50,270, then 2%; income tax
      const cls4Low = 12570, cls4High = 50270;
      const cl4Base = Math.max(0, Math.min(netProfit, cls4High) - cls4Low) * 0.06;
      const cl4Extra = Math.max(0, netProfit - cls4High) * 0.02;
      soleSE = cl4Base + cl4Extra;
      soleIT = Math.max(0, ukIT(w2 + netProfit) - ukIT(w2));
      soleTotalTax = soleSE + soleIT;

      // Ltd Company: optimal = small salary £12,570 + dividends
      const ltdSalary = Math.min(netProfit, 12570);
      const corpProfit = Math.max(0, netProfit - ltdSalary);
      corpTax = corpProfit <= 50000 ? corpProfit * 0.19 : // small profits rate
                corpProfit <= 250000 ? corpProfit * (0.19 + (corpProfit - 50000) / 200000 * 0.06) :
                corpProfit * 0.25; // marginal relief
      const dividendIncome = Math.max(0, corpProfit - corpTax);
      // Dividend tax: £500 allowance then 8.75% basic, 33.75% higher
      function divTax(div, totalIncome) {
        const allowance = 500;
        const taxableDiv = Math.max(0, div - allowance);
        const baseSpace = Math.max(0, 50270 - totalIncome);
        const basicDiv = Math.min(taxableDiv, baseSpace);
        const higherDiv = Math.max(0, taxableDiv - basicDiv);
        return basicDiv * 0.0875 + higherDiv * 0.3375;
      }
      corpIT = divTax(dividendIncome, w2 + ltdSalary);
      corpTotalTax = corpTax + corpIT;
    }

    // ── CA ──────────────────────────────────────────────────────────────
    else if (country === "CA") {
      function caIT(income) {
        if (income <= 57375)  return income * 0.15;
        if (income <= 114750) return 8606.25 + (income - 57375) * 0.205;
        if (income <= 177882) return 20349.38 + (income - 114750) * 0.26;
        if (income <= 253414) return 36764.70 + (income - 177882) * 0.29;
        return 58676.78 + (income - 253414) * 0.33;
      }
      // CPP: 9.9% on earnings ~$3,500–$73,200 (2026 estimates)
      const cppMax = 73200, cppMin = 3500;
      const cppBase = Math.max(0, Math.min(netProfit, cppMax) - cppMin);
      soleSE = cppBase * 0.099; // self-employed pays both sides
      // Federal + typical provincial (ON ~9.15%) combined IT
      const soleTaxable = w2 + netProfit;
      soleIT = Math.max(0, (caIT(soleTaxable) + soleTaxable * 0.0915) - (caIT(w2) + w2 * 0.0915));
      soleTotalTax = soleSE + soleIT;

      // CCPC: 9% SBD on active income (federal) + ~3% provincial combined = ~12%
      corpTax = Math.min(netProfit, 500000) * 0.12;
      const retained = Math.max(0, netProfit - corpTax);
      // Pay reasonable salary + eligible dividends (EDR ~15.02%)
      const corpSalary = Math.min(retained * 0.5, 100000);
      const dividends = Math.max(0, retained - corpSalary);
      const corpSalaryCPP = Math.max(0, Math.min(corpSalary, cppMax) - cppMin) * 0.0495; // employee side
      const divIncomeTax = dividends * 0.1502; // eligible dividend tax rate
      corpIT = Math.max(0, (caIT(w2 + corpSalary) + (w2 + corpSalary) * 0.0915) - (caIT(w2) + w2 * 0.0915)) + divIncomeTax;
      corpTotalTax = corpTax + corpSalaryCPP + corpIT;
    }

    // ── AU ──────────────────────────────────────────────────────────────
    else if (country === "AU") {
      function auIT(income) {
        if (income <= 18200)  return 0;
        if (income <= 45000)  return (income - 18200) * 0.19;
        if (income <= 120000) return 5092 + (income - 45000) * 0.325;
        if (income <= 180000) return 29467 + (income - 120000) * 0.37;
        return 51667 + (income - 180000) * 0.45;
      }
      // Medicare levy 2% on all income above low-income threshold
      const medicareLevy = (income) => income > 26000 ? income * 0.02 : 0;
      soleSE = medicareLevy(netProfit); // additional medicare on business income
      soleIT = Math.max(0, auIT(w2 + netProfit) + medicareLevy(w2 + netProfit) - auIT(w2) - medicareLevy(w2));
      soleTotalTax = soleSE + soleIT;

      // Pty Ltd: 25% company tax (small business entity < $50M turnover)
      corpTax = netProfit * 0.25;
      const retained = Math.max(0, netProfit - corpTax);
      // Pay small salary (up to $18,200 tax free) + franked dividends
      const auSalary = Math.min(retained, 18200);
      const dividends = Math.max(0, retained - auSalary);
      // Franked dividend: grossed up at 25% rate, offset by franking credits
      const grossDiv = dividends / 0.75;
      const frankingCredit = grossDiv - dividends;
      const divMarginalTax = Math.max(0, auIT(w2 + auSalary + grossDiv) + medicareLevy(w2 + auSalary + grossDiv)
        - auIT(w2 + auSalary) - medicareLevy(w2 + auSalary));
      corpIT = Math.max(0, divMarginalTax - frankingCredit);
      corpTotalTax = corpTax + corpIT;
    }

    // ── SHARED OUTPUTS ───────────────────────────────────────────────────
    function fmt(v) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: cfg.currency, maximumFractionDigits: 0 }).format(v);
    }

    const savings = Math.max(0, soleTotalTax - corpTotalTax);
    const soleEffRate = netProfit > 0 ? (soleTotalTax / netProfit) * 100 : 0;
    const corpEffRate = netProfit > 0 ? (corpTotalTax / netProfit) * 100 : 0;

    document.getElementById("tax-sole-total").innerText = fmt(soleTotalTax);
    document.getElementById("tax-sole-se").innerText    = fmt(soleSE);
    document.getElementById("tax-sole-income").innerText = fmt(soleIT);
    document.getElementById("tax-sole-rate").innerText  = soleEffRate.toFixed(1) + "%";
    document.getElementById("tax-sole-eff-rate").innerText = soleEffRate.toFixed(1) + "%";

    document.getElementById("tax-scorp-total").innerText  = fmt(corpTotalTax);
    document.getElementById("tax-scorp-se").innerText     = fmt(corpTax);
    document.getElementById("tax-scorp-income").innerText = fmt(corpIT);
    document.getElementById("tax-corp-rate").innerText    = corpEffRate.toFixed(1) + "%";
    document.getElementById("tax-corp-eff-rate").innerText = corpEffRate.toFixed(1) + "%";

    document.getElementById("tax-net-profit").innerText  = fmt(netProfit);
    document.getElementById("tax-rec-savings").innerText = savings > 0 ? fmt(savings) : "—";

    // Break-even logic
    const banner    = document.getElementById("tax-recommendation-banner");
    const recTitle  = document.getElementById("tax-rec-title");
    const recIcon   = document.getElementById("tax-rec-icon");
    const msgEl     = document.getElementById("tax-breakeven-msg");
    const isWorthIt = netProfit > cfg.breakEvenRevenue && savings > cfg.corpOverheadCost;

    if (netProfit === 0) {
      banner.className = "p-6 rounded-2xl border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-slate-900 border-slate-800";
      recTitle.innerText = "Enter revenue to begin";
      recIcon.className  = "p-3 rounded-xl bg-slate-800 text-slate-400 hidden sm:flex items-center justify-center flex-shrink-0";
      recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`;
      msgEl.innerText   = "";
    } else if (isWorthIt) {
      banner.className = "p-6 rounded-2xl border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-emerald-500/10 border-emerald-500/30";
      recTitle.innerText = `Incorporate — Switch to ${cfg.corpLabel}`;
      recIcon.className  = "p-3 rounded-xl bg-emerald-500/20 text-emerald-400 hidden sm:flex items-center justify-center flex-shrink-0";
      recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`;
      msgEl.innerText   = `Incorporation overhead ~${fmt(cfg.corpOverheadCost)}/yr. You save ${fmt(savings)}/yr — net advantage ${fmt(savings - cfg.corpOverheadCost)}.`;
    } else {
      const stillNeeded = Math.max(0, cfg.breakEvenRevenue - netProfit);
      banner.className = "p-6 rounded-2xl border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-amber-500/10 border-amber-500/30";
      recTitle.innerText = `Stay ${cfg.soleLabel} For Now`;
      recIcon.className  = "p-3 rounded-xl bg-amber-500/20 text-amber-400 hidden sm:flex items-center justify-center flex-shrink-0";
      recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`;
      msgEl.innerText   = stillNeeded > 0
        ? `Grow net profit by another ${fmt(stillNeeded)} to hit the break-even milestone for corporate overhead.`
        : `Savings (${fmt(savings)}) don't yet cover annual corporate overheads (~${fmt(cfg.corpOverheadCost)}). Keep scaling.`;
    }

    // Bar chart update
    const maxBurden = Math.max(soleTotalTax, corpTotalTax, 1);
    document.getElementById("chart-sole-tax-perc").innerText = soleEffRate.toFixed(1) + "%";
    document.getElementById("chart-sole-tax-bar").style.width = Math.round((soleTotalTax / maxBurden) * 100) + "%";
    document.getElementById("chart-scorp-tax-perc").innerText = corpEffRate.toFixed(1) + "%";
    document.getElementById("chart-scorp-tax-bar").style.width = Math.round((corpTotalTax / maxBurden) * 100) + "%";
  }

  // ─────────────────────────────────────────────────────────────────────
  // DEBT DYNAMIC ROW RENDERER
  // ─────────────────────────────────────────────────────────────────────
  function renderDebtRows() {
    const container = document.getElementById("debt-rows-container");
    const emptyState = document.getElementById("debt-empty-state");
    if (!container) return;

    container.innerHTML = "";

    const rows = state.debt.rows || [];
    emptyState.style.display = rows.length === 0 ? "flex" : "none";

    rows.forEach((row, idx) => {
      const el = document.createElement("div");
      el.className = "debt-row group relative";
      el.setAttribute("data-idx", idx);
      el.innerHTML = `
        <!-- Mobile layout: stacked -->
        <div class="sm:hidden p-3 bg-slate-900/60 border border-slate-800 rounded-xl space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-3xs font-bold uppercase tracking-widest text-slate-500">Debt #${idx + 1}</span>
            <button class="debt-remove-btn text-slate-600 hover:text-rose-400 transition-colors p-1 rounded" data-idx="${idx}" title="Remove debt">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <input type="text" class="debt-row-input focus-ring block w-full px-3 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="name" placeholder="Debt name (e.g. Visa, Student Loan)" value="${row.name || ''}" />
          <div class="grid grid-cols-3 gap-1.5">
            <div>
              <label class="block text-4xs font-bold uppercase tracking-wider text-slate-600 mb-0.5">Balance</label>
              <input type="number" class="debt-row-input focus-ring block w-full px-2 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="balance" placeholder="0" min="0" step="100" value="${row.balance || ''}" />
            </div>
            <div>
              <label class="block text-4xs font-bold uppercase tracking-wider text-slate-600 mb-0.5">Rate %</label>
              <input type="number" class="debt-row-input focus-ring block w-full px-2 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="rate" placeholder="0" min="0" max="100" step="0.1" value="${row.rate || ''}" />
            </div>
            <div>
              <label class="block text-4xs font-bold uppercase tracking-wider text-slate-600 mb-0.5">Min / Mo</label>
              <input type="number" class="debt-row-input focus-ring block w-full px-2 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="min" placeholder="0" min="0" step="5" value="${row.min || ''}" />
            </div>
          </div>
        </div>

        <!-- Desktop layout: row grid -->
        <div class="hidden sm:grid grid-cols-12 gap-2 items-center p-2 bg-slate-900/40 border border-slate-800/60 rounded-xl hover:border-slate-700/80 transition-all duration-150">
          <div class="col-span-4">
            <input type="text" class="debt-row-input focus-ring block w-full px-2.5 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9" data-idx="${idx}" data-field="name" placeholder="e.g. Visa Card" value="${row.name || ''}" />
          </div>
          <div class="col-span-2">
            <input type="number" class="debt-row-input focus-ring block w-full px-2 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9 text-right" data-idx="${idx}" data-field="balance" placeholder="0" min="0" step="100" value="${row.balance || ''}" />
          </div>
          <div class="col-span-2">
            <input type="number" class="debt-row-input focus-ring block w-full px-2 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9 text-right" data-idx="${idx}" data-field="rate" placeholder="0.00" min="0" max="100" step="0.1" value="${row.rate || ''}" />
          </div>
          <div class="col-span-2">
            <input type="number" class="debt-row-input focus-ring block w-full px-2 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9 text-right" data-idx="${idx}" data-field="min" placeholder="0" min="0" step="5" value="${row.min || ''}" />
          </div>
          <div class="col-span-2 flex justify-end">
            <button class="debt-remove-btn text-slate-600 hover:text-rose-400 transition-colors p-1.5 rounded-lg hover:bg-rose-500/10 opacity-0 group-hover:opacity-100" data-idx="${idx}" title="Remove debt">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </div>
        </div>
      `;
      container.appendChild(el);
    });

    // Bind row input events (event delegation already set on container)
    calculateDebt();
  }

  function addDebtRow() {
    if (!state.debt.rows) state.debt.rows = [];
    state.debt.rows.push({ name: "", balance: 0, rate: 0, min: 0 });
    saveState();
    renderDebtRows();
  }

  function removeDebtRow(idx) {
    state.debt.rows.splice(idx, 1);
    saveState();
    renderDebtRows();
  }

  // ─────────────────────────────────────────────────────────────────────
  // DEBT SIMULATION ENGINE
  // ─────────────────────────────────────────────────────────────────────
  function calculateDebt() {
    const rows = state.debt.rows || [];
    const debts = rows
      .map((r, i) => ({
        idx: i,
        name: r.name || `Debt #${i + 1}`,
        balance: parseFloat(r.balance) || 0,
        rate:    parseFloat(r.rate)    || 0,
        min:     parseFloat(r.min)     || 0
      }))
      .filter(d => d.balance > 0);

    const extraPayment = parseFloat(state.debt.extra) || 0;
    const totalBalance = rows.reduce((s, r) => s + (parseFloat(r.balance) || 0), 0);

    // Summary row stats
    document.getElementById("debt-total-balance").innerText = formatCurrency(totalBalance);
    document.getElementById("debt-row-count").innerText = debts.length;

    if (debts.length === 0) {
      const dash = "—";
      document.getElementById("debt-av-interest").innerText = "$0";
      document.getElementById("debt-av-time").innerText = dash;
      document.getElementById("debt-av-apr").innerText = "0%";
      document.getElementById("debt-av-first").innerText = dash;
      document.getElementById("debt-sb-interest").innerText = "$0";
      document.getElementById("debt-sb-time").innerText = dash;
      document.getElementById("debt-sb-apr").innerText = "0%";
      document.getElementById("debt-sb-first").innerText = dash;
      document.getElementById("debt-savings").innerText = dash;
      document.getElementById("debt-months-saved").innerText = "0";
      document.getElementById("chart-av-time-val").innerText = dash;
      document.getElementById("chart-sb-time-val").innerText = dash;
      document.getElementById("chart-av-bar").style.width = "0%";
      document.getElementById("chart-sb-bar").style.width = "0%";
      const banner = document.getElementById("debt-method-banner");
      banner.className = "p-6 rounded-2xl border flex flex-col gap-3 transition-all duration-300 bg-slate-900 border-slate-800";
      document.getElementById("debt-rec-title").innerText = "Add debts to run simulation";
      document.getElementById("debt-rec-subtitle").innerText = "";
      return;
    }

    // Blended APR for display
    const initialTotal = debts.reduce((s, d) => s + d.balance, 0);
    const weightedRate = debts.reduce((s, d) => s + d.balance * d.rate, 0);
    const blendedApr = initialTotal > 0 ? (weightedRate / initialTotal) : 0;

    // ── CORE SIMULATOR ─────────────────────────────────────────────────
    function simulate(sortFn) {
      let pool = debts.map(d => ({ ...d })); // deep clone
      let totalInterest = 0;
      let months = 0;
      let firstClearedName = null;
      let firstClearedMonth = null;

      while (pool.some(d => d.balance > 0.01) && months < 600) {
        months++;
        pool.sort(sortFn);

        // 1. Accrue monthly interest
        for (const d of pool) {
          if (d.balance > 0) {
            const interest = (d.balance * (d.rate / 100)) / 12;
            totalInterest += interest;
            d.balance += interest;
          }
        }

        // 2. Apply minimum payments
        let rollover = extraPayment;
        for (const d of pool) {
          if (d.balance > 0) {
            const payment = Math.min(d.balance, d.min);
            d.balance = Math.max(0, d.balance - payment);
          }
        }

        // 3. Apply extra payment cascade (snowball / avalanche target = first in sorted pool)
        for (const d of pool) {
          if (d.balance > 0.01 && rollover > 0) {
            const payment = Math.min(d.balance, rollover);
            d.balance = Math.max(0, d.balance - payment);
            rollover -= payment;
          }
        }

        // 4. Track first-cleared milestone
        if (firstClearedName === null) {
          const cleared = pool.find(d => d.balance <= 0.01 && d.balance >= 0);
          if (cleared && months > 0) {
            firstClearedName = cleared.name;
            firstClearedMonth = months;
          }
        }
      }

      return {
        interest: totalInterest,
        months,
        firstClearedName,
        firstClearedMonth,
        apr: blendedApr
      };
    }

    const avResult = simulate((a, b) => b.rate - a.rate);    // Avalanche: highest rate first
    const sbResult = simulate((a, b) => a.balance - b.balance); // Snowball: smallest balance first

    // Helper: months → human readable
    function fmtMonths(m) {
      if (m >= 600) return ">50 yrs";
      const yrs = Math.floor(m / 12);
      const mos = m % 12;
      if (yrs === 0) return `${mos} mo`;
      if (mos === 0) return `${yrs} yr`;
      return `${yrs} yr ${mos} mo`;
    }

    // ── UPDATE DOM ─────────────────────────────────────────────────────
    document.getElementById("debt-av-interest").innerText = formatCurrency(avResult.interest);
    document.getElementById("debt-av-time").innerText     = fmtMonths(avResult.months);
    document.getElementById("debt-av-apr").innerText      = blendedApr.toFixed(1) + "%";
    document.getElementById("debt-av-first").innerText    = avResult.firstClearedName
      ? `${avResult.firstClearedName} (mo. ${avResult.firstClearedMonth})`
      : "—";

    document.getElementById("debt-sb-interest").innerText = formatCurrency(sbResult.interest);
    document.getElementById("debt-sb-time").innerText     = fmtMonths(sbResult.months);
    document.getElementById("debt-sb-apr").innerText      = blendedApr.toFixed(1) + "%";
    document.getElementById("debt-sb-first").innerText    = sbResult.firstClearedName
      ? `${sbResult.firstClearedName} (mo. ${sbResult.firstClearedMonth})`
      : "—";

    const interestSaved = Math.max(0, sbResult.interest - avResult.interest);
    const monthsSaved   = Math.max(0, sbResult.months   - avResult.months);

    document.getElementById("debt-savings").innerText      = interestSaved > 0 ? formatCurrency(interestSaved) : "—";
    document.getElementById("debt-months-saved").innerText = monthsSaved > 0 ? monthsSaved : "0";

    // Chart bars (shorter timeline = wider bar = more "progress" visually)
    const maxMonths = Math.max(avResult.months, sbResult.months, 1);
    document.getElementById("chart-av-time-val").innerText = fmtMonths(avResult.months);
    document.getElementById("chart-sb-time-val").innerText = fmtMonths(sbResult.months);
    document.getElementById("chart-av-bar").style.width = Math.round((avResult.months / maxMonths) * 100) + "%";
    document.getElementById("chart-sb-bar").style.width = Math.round((sbResult.months / maxMonths) * 100) + "%";

    // Smart Advisory Banner
    const banner   = document.getElementById("debt-method-banner");
    const recTitle = document.getElementById("debt-rec-title");
    const recSub   = document.getElementById("debt-rec-subtitle");
    const recIcon  = document.getElementById("debt-rec-icon");

    if (interestSaved > 50) {
      // Avalanche wins mathematically
      banner.className = "p-6 rounded-2xl border flex flex-col gap-3 transition-all duration-300 bg-brand-500/10 border-brand-500/30";
      recTitle.innerText = `🏆 Choose Avalanche — Save ${formatCurrency(interestSaved)}`;
      recSub.innerText   = monthsSaved > 0
        ? `By targeting highest-rate debt first, you'll be debt-free ${monthsSaved} month${monthsSaved > 1 ? 's' : ''} sooner and pay ${formatCurrency(interestSaved)} less interest.`
        : `Mathematically optimal. Saves ${formatCurrency(interestSaved)} in total interest over the Snowball method.`;
      recIcon.className  = "p-3 rounded-xl bg-brand-500/20 text-brand-400 hidden sm:flex items-center justify-center flex-shrink-0";
      recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`;
    } else if (sbResult.months < avResult.months) {
      // Snowball wins on speed (unusual but possible)
      banner.className = "p-6 rounded-2xl border flex flex-col gap-3 transition-all duration-300 bg-emerald-500/10 border-emerald-500/30";
      recTitle.innerText = `♥ Snowball Wins On Speed — ${Math.abs(monthsSaved)} Months Faster`;
      recSub.innerText   = "With these debts, Snowball clears balances faster. Stick with Snowball for the quickest debt-free date.";
      recIcon.className  = "p-3 rounded-xl bg-emerald-500/20 text-emerald-400 hidden sm:flex items-center justify-center flex-shrink-0";
      recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
    } else {
      // Essentially tied
      banner.className = "p-6 rounded-2xl border flex flex-col gap-3 transition-all duration-300 bg-amber-500/10 border-amber-500/30";
      recTitle.innerText = `Both Methods Are Essentially Equal`;
      recSub.innerText   = "Your debts have similar rates/balances. Either method works — pick Snowball for motivation, Avalanche for discipline.";
      recIcon.className  = "p-3 rounded-xl bg-amber-500/20 text-amber-400 hidden sm:flex items-center justify-center flex-shrink-0";
      recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>`;
    }
  }

  // Unified Run Calculations
  function runCalculations() {
    calculateBBD();
    calculateTax();
    calculateDebt();
  }

  // ==========================================
  // TAB CONTROLLERS
  // ==========================================

  function setActiveTabDOM(tabId) {
    // Buttons toggling
    document.querySelectorAll(".tab-btn").forEach(btn => {
      const isSelected = btn.id === `tab-btn-${tabId}`;
      btn.setAttribute("aria-selected", isSelected);
      if (isSelected) {
        btn.classList.add("active-tab");
        btn.classList.remove("inactive-tab");
      } else {
        btn.classList.remove("active-tab");
        btn.classList.add("inactive-tab");
      }
    });

    // Panels toggling
    document.querySelectorAll(".tab-panel").forEach(panel => {
      if (panel.id === `panel-${tabId}`) {
        panel.classList.remove("hidden");
      } else {
        panel.classList.add("hidden");
      }
    });
  }

  function handleTabClick(e) {
    const btn = e.currentTarget;
    const tabId = btn.id.replace("tab-btn-", "");
    state.activeTab = tabId;
    setActiveTabDOM(tabId);
    saveState();
  }

  // Bind Listeners to state changes
  function bindListeners() {
    
    // Tab Button bindings
    document.querySelectorAll(".tab-btn").forEach(btn => {
      btn.addEventListener("click", handleTabClick);
    });

    // Auto-save toggle binding
    document.getElementById("toggle-autosave").addEventListener("click", () => {
      state.autoSave = !state.autoSave;
      localStorage.setItem(AUTOSAVE_KEY, state.autoSave ? "true" : "false");
      saveState(true);
      triggerAutosaveIndicator();
    });

    // Reset button binding
    document.getElementById("reset-state").addEventListener("click", () => {
      if (confirm("Are you sure you want to clear all calculations and reset to baseline empty states?")) {
        // 1. Clear LocalStorage
        localStorage.removeItem(STORAGE_KEY);
        
        const currentActiveTab = state.activeTab;
        const currentAutoSave = state.autoSave;
        
        // Reset in-memory state to baseline empty states
        state = JSON.parse(JSON.stringify(DEFAULT_STATE));
        state.activeTab = currentActiveTab;
        state.autoSave = currentAutoSave;

        // 2. Reset HTML Form Inputs
        document.querySelectorAll(".tab-panel input, .tab-panel select, .tab-panel textarea").forEach(input => {
          if (input.tagName === "SELECT") {
            input.value = input.options[0].value;
          } else if (input.type === "range") {
            input.value = input.min || 5;
          } else {
            input.value = "0";
          }
        });

        // Reset display values
        updateCurrencySymbols("USD");

        // Re-run calculations with empty state
        runCalculations();

        // 3. Dispatch Custom Event
        window.dispatchEvent(new Event('financial-hub-reset'));

        // 4. Provide Visual Feedback
        const btn = document.getElementById("reset-state");
        const btnText = document.getElementById("reset-btn-text");
        if (btn && btnText) {
          const originalText = btnText.innerText;
          const originalClass = btn.className;

          btnText.innerText = "Cleared! ✓";
          btn.className = btn.className.replace("text-slate-400", "text-emerald-400 bg-emerald-500/10 border-emerald-500/30");

          setTimeout(() => {
            btnText.innerText = originalText;
            btn.className = originalClass;
          }, 1500);
        }
      }
    });

    // Form inputs bindings (dynamic input changes trigger calculations & local storage saves)
    
    // BBD inputs
    const bbdInputs = [
      { id: "bbd-portfolio", prop: "portfolio" },
      { id: "bbd-basis", prop: "basis" },
      { id: "bbd-tax-rate", prop: "taxRate" },
      { id: "bbd-borrow-amount", prop: "borrowAmount" },
      { id: "bbd-interest-rate", prop: "interestRate" }
    ];
    bbdInputs.forEach(({ id, prop }) => {
      const el = document.getElementById(id);
      el.addEventListener("input", (e) => {
        const val = parseFloat(e.target.value) || 0;
        state.bbd[prop] = val;
        saveState();
        calculateBBD();
      });
    });

    // Currency selector listener
    document.getElementById("bbd-currency").addEventListener("change", (e) => {
      const currency = e.target.value;
      state.bbd.currency = currency;
      saveState();
      updateCurrencySymbols(currency);
      calculateBBD();
    });

    // Tax preset button listener
    document.querySelectorAll(".tax-preset-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const rate = parseFloat(e.currentTarget.getAttribute("data-rate")) || 0;
        const taxInput = document.getElementById("bbd-tax-rate");
        taxInput.value = rate;
        state.bbd.taxRate = rate;
        saveState();
        calculateBBD();
      });
    });

    // Tax country selector
    document.getElementById("tax-country").addEventListener("change", (e) => {
      state.tax.country = e.target.value;
      updateTaxCountryUI(state.tax.country);
      saveState();
      calculateTax();
    });

    // Tax number inputs
    const taxInputs = [
      { id: "tax-revenue",  prop: "revenue"  },
      { id: "tax-expenses", prop: "expenses" },
      { id: "tax-w2",       prop: "w2"       }
    ];
    taxInputs.forEach(({ id, prop }) => {
      const el = document.getElementById(id);
      el.addEventListener("input", (e) => {
        state.tax[prop] = parseFloat(e.target.value) || 0;
        saveState();
        calculateTax();
      });
    });

    // Listen for financial-hub-reset to clear tax panel outputs
    window.addEventListener("financial-hub-reset", () => {
      updateTaxCountryUI("US");
    });

    // ── DEBT: Add row button
    document.getElementById("debt-add-row").addEventListener("click", addDebtRow);

    // ── DEBT: Event delegation for row inputs (name/balance/rate/min)
    document.getElementById("debt-rows-container").addEventListener("input", (e) => {
      const target = e.target;
      if (!target.classList.contains("debt-row-input")) return;
      const idx   = parseInt(target.getAttribute("data-idx"), 10);
      const field = target.getAttribute("data-field");
      if (isNaN(idx) || !field) return;
      if (!state.debt.rows[idx]) return;
      if (field === "name") {
        state.debt.rows[idx][field] = target.value;
      } else {
        state.debt.rows[idx][field] = parseFloat(target.value) || 0;
      }
      saveState();
      calculateDebt();
    });

    // ── DEBT: Event delegation for remove buttons
    document.getElementById("debt-rows-container").addEventListener("click", (e) => {
      const btn = e.target.closest(".debt-remove-btn");
      if (!btn) return;
      const idx = parseInt(btn.getAttribute("data-idx"), 10);
      if (!isNaN(idx)) removeDebtRow(idx);
    });

    // ── DEBT: Extra payment input
    document.getElementById("debt-extra").addEventListener("input", (e) => {
      state.debt.extra = parseFloat(e.target.value) || 0;
      saveState();
      calculateDebt();
    });

    // ── DEBT: Reset handler — clear all rows
    window.addEventListener("financial-hub-reset", () => {
      state.debt.rows = [];
      state.debt.extra = 0;
      renderDebtRows();
      document.getElementById("debt-extra").value = "";
    });
  }

  // Execution Lifecycles
  window.addEventListener("DOMContentLoaded", () => {
    loadState();
    syncStateToInputs();
    bindListeners();
    runCalculations();
  });
</script>
