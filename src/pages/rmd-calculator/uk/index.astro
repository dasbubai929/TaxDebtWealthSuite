---
import Layout from "../../../layouts/Layout.astro";
import RmdCalculator from "../../../components/RmdCalculator.astro";
---

<Layout
  title="UK Pension Drawdown Calculator"
  description="Estimate a sustainable statutory-style drawdown from your UK defined contribution pension."
>
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Pension Drawdown Calculator (UK)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": {
          "@id": "https://taxdebtwealthsuite.com/#organization"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "GBP"
        },
        "description": "Estimate a sustainable statutory-style drawdown from your UK defined contribution pension."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Are there required minimum distributions in the UK?",
            "acceptedAnswer": {
               "@type": "Answer",
               "text": "Unlike the US, the UK does not have a strict statutory minimum drawdown for defined contribution pensions until age 75. However, planning a sustainable drawdown rate is critical to ensure your pension pot lasts throughout retirement."
            }
          },
          {
            "@type": "Question",
            "name": "What is a safe drawdown rate?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Many financial planners suggest a 4% to 5% withdrawal rate in early retirement, increasing slightly as you age, depending on your investment returns and life expectancy."
            }
          }
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://taxdebtwealthsuite.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "UK Pension Drawdown Calculator",
            "item": "https://taxdebtwealthsuite.com/rmd-calculator/uk/"
          }
        ]
      }
    ]
  }
  </script>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    <!-- Title Section -->
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Pension Drawdown Calculator (UK)
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-xs font-medium text-slate-500 bg-slate-900/50 inline-flex px-3 py-1.5 rounded-lg border border-slate-800">
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#00F5D4]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>Reviewed by <a href="/editorial-policy/" class="text-slate-400 hover:text-[#00F5D4] transition-colors underline decoration-slate-700 underline-offset-2">Editorial Staff</a></span>
        </div>
      </div>
      <p class="text-sm text-slate-400 mt-2 max-w-2xl leading-relaxed">
        Estimate a sustainable statutory-style drawdown from your UK defined contribution pension.
      </p>
    </div>

    <!-- Calculator Component Island -->
    <RmdCalculator country="uk" />

    <!-- Explainer Content -->
    <div class="border-t border-slate-800/60 mt-12 bg-gradient-to-b from-slate-950 to-slate-950/95">
      <div class="max-w-4xl mx-auto py-16">
        <section>
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Financial Tool</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight leading-snug">
              Understanding UK Pension Drawdowns
            </h2>
          </div>

          <div class="space-y-8 text-sm text-slate-400 leading-relaxed">
            <article>
              <h3 class="text-xl font-bold text-slate-100 mb-3">Introduction</h3>
              <p>In the UK, pension freedoms introduced in 2015 give individuals complete flexibility over how they access their defined contribution pension savings from age 55 (rising to 57 in 2028). While there are no mandatory "required minimum distributions" before age 75, calculating a sustainable withdrawal rate is essential to ensure you don't run out of money in retirement.</p>
              <p class="mt-2">To learn more about the rules and best practices for withdrawing from your pension, read our detailed guide on <a href="/blog/rmd-calculator-uk/" class="text-[#00F5D4] hover:underline">UK Pension Withdrawal Rules Explained</a>.</p>
            </article>
            
            <article>
              <h3 class="text-xl font-bold text-slate-100 mb-3">Related Tools</h3>
              <p>Consider looking at our <a href="/roth-conversion-calculator/" class="text-[#00F5D4] hover:underline">Roth Conversion Calculator</a> if you are navigating cross-border tax issues or optimizing your tax-advantaged accounts.</p>
            </article>
          </div>

          <!-- FAQ Accordion -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-amber-500/10 text-amber-400 border border-amber-500/20 mb-4">FAQ</span>
            <h3 class="text-2xl font-bold text-white mb-6">Frequently Asked Questions</h3>

            <div class="space-y-4">
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">Are there required minimum distributions in the UK?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  Unlike the US, the UK does not have a strict statutory minimum drawdown for defined contribution pensions until age 75. However, planning a sustainable drawdown rate is critical to ensure your pension pot lasts throughout retirement.
                </div>
              </div>
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">What is a safe drawdown rate?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  Many financial planners suggest a 4% to 5% withdrawal rate in early retirement, increasing slightly as you age, depending on your investment returns and life expectancy.
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
