---
import Layout from '../../../layouts/Layout.astro';
import TaxLossHarvestingCalculator from '../../../components/TaxLossHarvestingCalculator.astro';
---

<Layout
  title="Tax Loss Harvesting Calculator (Canada) | Superficial Loss Rules"
  description="Calculate your estimated tax savings from harvesting capital losses in Canada. Understand the CRA superficial loss rule and inclusion rate impact."
  ogImage="https://taxdebtwealthsuite.com/images/og-tax-loss-harvesting.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/tax-loss-harvesting-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Tax Loss Harvesting Calculator (Canada)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CAD" },
        "description": "Calculate your estimated tax savings from harvesting capital losses in Canada under CRA rules."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the superficial loss rule in Canada?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The superficial loss rule denies a capital loss if you or an affiliated person buys the identical property within 30 days before or after the sale."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Tax Loss Harvesting Calculator (Canada)
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Calculate your potential CRA tax savings by harvesting allowable capital losses, factoring in the 50% inclusion rate and superficial loss rules.
      </p>
    </div>

    <TaxLossHarvestingCalculator defaultCountry="canada" />
  </main>
</Layout>
