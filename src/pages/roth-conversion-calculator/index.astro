---
import Layout from "../../layouts/Layout.astro";
import RothConversionCalculator from "../../components/RothConversionCalculator.astro";
---

<Layout
  title="Roth Conversion Calculator | Traditional IRA to Roth Tax Impact"
  description="Model the tax cost of converting a traditional IRA or 401(k) to a Roth IRA, and see the breakeven retirement tax rate where conversion pays off."
>
  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Roth Conversion Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "description": "Model the tax cost of converting a traditional IRA or 401(k) to a Roth IRA, and see the breakeven retirement tax rate where conversion pays off."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is a Roth IRA conversion?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "A Roth conversion transfers pre-tax traditional IRA or 401(k) funds to a Roth IRA. Income tax is paid on the converted amount now, allowing future growth and withdrawals to be 100% tax-free."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Roth Conversion Calculator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Model the tax cost of converting a Traditional IRA or 401(k) to a Roth IRA. Find the breakeven retirement tax rate where conversion pays off.
      </p>
    </div>

    <RothConversionCalculator />
  </main>
</Layout>
