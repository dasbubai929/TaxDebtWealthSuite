---
interface Props {
  defaultCurrency?: string;
}

const { defaultCurrency = "USD" } = Astro.props;
---

<section id="panel-debt" class="space-y-6" data-default-currency={defaultCurrency}>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

    <!-- LEFT: Dynamic Debt Input -->
    <div class="space-y-5">
      <div class="glass-panel p-6 rounded-2xl shadow-xl space-y-5 border border-slate-800">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="text-lg font-bold text-white tracking-wide">Liability Schedules</h3>
            <p class="text-xs text-slate-400 mt-1">Add each debt and your extra monthly budget to run both simulations.</p>
          </div>
          <button id="debt-add-row" class="flex items-center gap-1.5 px-3 py-1.5 bg-brand-500/15 hover:bg-brand-500/25 border border-brand-500/30 rounded-lg text-brand-300 text-xs font-semibold transition-all duration-200 flex-shrink-0 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Add Debt
          </button>
        </div>

        <!-- Column Headers — desktop only -->
        <div class="hidden sm:grid grid-cols-12 gap-2 px-1 text-3xs font-bold uppercase tracking-wider text-slate-500">
          <span class="col-span-4">Debt Name</span>
          <span class="col-span-2 text-right">Balance</span>
          <span class="col-span-2 text-right">Rate %</span>
          <span class="col-span-2 text-right">Min / Mo</span>
          <span class="col-span-2"></span>
        </div>

        <!-- Dynamic Debt Rows Container -->
        <div id="debt-rows-container" class="space-y-3">
          <!-- Rows injected by JS -->
        </div>

        <!-- Empty state -->
        <div id="debt-empty-state" class="py-8 flex flex-col items-center justify-center space-y-2 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          <p class="text-sm font-semibold text-slate-500">No debts added yet</p>
          <p class="text-xs text-slate-600">Click "Add Debt" above to begin</p>
        </div>
      </div>

      <!-- Extra Monthly Budget -->
      <div class="glass-panel p-5 rounded-2xl border border-slate-800">
        <label for="debt-extra" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-3">
          Extra Monthly Payment Budget
          <span class="ml-1 text-brand-400">(Above all minimums)</span>
        </label>
        <div class="relative rounded-lg shadow-sm">
          <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium debt-currency-symbol">$</div>
          <input type="number" id="debt-extra" class="focus-ring block w-full pl-8 pr-16 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="50" placeholder="0" />
          <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-slate-500 text-xs">/month</div>
        </div>
        <p class="text-3xs text-slate-600 mt-2">This "snowball fuel" is applied to the target debt each month after all minimums are paid.</p>
      </div>

      <!-- Strategy Explainer Card -->
      <div class="bg-gradient-to-br from-slate-900 to-indigo-950/30 p-5 rounded-2xl border border-slate-850 space-y-3">
        <h4 class="text-xs font-bold tracking-wider text-brand-300 uppercase">Strategy Difference</h4>
        <div class="space-y-2 text-xs text-slate-400 leading-relaxed">
          <p><span class="text-brand-300 font-semibold">Avalanche</span> — Targets the highest interest rate debt first. Minimizes total interest paid. Mathematically optimal.</p>
          <p><span class="text-emerald-400 font-semibold">Snowball</span> — Targets the smallest balance first. Provides quick psychological wins. Great for motivation.</p>
        </div>
      </div>
    </div>

    <!-- RIGHT: Real-Time Simulation Outputs -->
    <div class="space-y-5">

      <!-- Smart Advisory Banner -->
      <div id="debt-method-banner" class="p-6 rounded-2xl border flex flex-col gap-3 transition-all duration-300 bg-slate-900 border-slate-800">
        <div class="flex items-start gap-4">
          <div id="debt-rec-icon" class="p-3 rounded-xl bg-slate-800 text-slate-400 hidden sm:flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-xs font-bold uppercase tracking-widest text-slate-400">Smart Advisory</p>
            <h4 id="debt-rec-title" class="text-lg font-extrabold text-white mt-0.5">Add debts to run simulation</h4>
            <p id="debt-rec-subtitle" class="text-xs text-slate-400 mt-1"></p>
          </div>
          <div class="text-right flex-shrink-0">
            <p class="text-2xs font-semibold uppercase tracking-wider text-slate-500">Interest Saved</p>
            <p id="debt-savings" class="text-xl font-black text-white mt-0.5">—</p>
          </div>
        </div>
      </div>

      <!-- Share Results — Debt -->
      <div class="flex justify-end">
        <button
          onclick="shareResults('debt')"
          class="group flex items-center gap-2 px-3.5 py-2 rounded-xl border border-[#00F5D4]/20 bg-[#00F5D4]/5 hover:bg-[#00F5D4]/10 hover:border-[#00F5D4]/40 text-[#94A3B8] hover:text-[#00F5D4] text-xs font-semibold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-[#00F5D4]/30"
          aria-label="Share your Debt Payoff Planner results"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0 transition-transform duration-200 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          <span>Share Results</span>
        </button>
      </div>

      <!-- Side-by-Side Comparison Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <!-- Avalanche Card -->
        <div class="glass-panel p-5 rounded-2xl border border-brand-500/20 bg-gradient-to-br from-indigo-950/20 to-slate-900/40 space-y-4 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-20 h-20 bg-brand-500/5 rounded-full blur-2xl"></div>
          <div class="flex justify-between items-start">
            <div>
              <span class="text-3xs font-bold uppercase tracking-widest text-brand-400">Method 1</span>
              <p class="text-sm font-bold text-white mt-0.5">Debt Avalanche</p>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-2xs font-semibold bg-brand-500/15 text-brand-300 border border-brand-500/25 uppercase tracking-widest flex-shrink-0">★ Math King</span>
          </div>
          <div>
            <p class="text-3xs uppercase tracking-wider text-slate-400">Total Interest Paid</p>
            <p id="debt-av-interest" class="text-3xl font-black text-brand-300 mt-0.5">—</p>
          </div>
          <div class="space-y-2 pt-3 border-t border-brand-500/10 text-xs text-slate-400">
            <div class="flex justify-between">
              <span>Payoff Timeline:</span>
              <span id="debt-av-time" class="text-white font-semibold">—</span>
            </div>
            <div class="flex justify-between">
              <span>Blended APR:</span>
              <span id="debt-av-apr" class="text-white font-medium">0%</span>
            </div>
            <div class="flex justify-between">
              <span>First Debt Cleared:</span>
              <span id="debt-av-first" class="text-brand-300 font-semibold">—</span>
            </div>
          </div>
        </div>

        <!-- Snowball Card -->
        <div class="glass-panel p-5 rounded-2xl border border-emerald-500/20 bg-gradient-to-br from-emerald-950/10 to-slate-900/40 space-y-4 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-20 h-20 bg-emerald-500/5 rounded-full blur-2xl"></div>
          <div class="flex justify-between items-start">
            <div>
              <span class="text-3xs font-bold uppercase tracking-widest text-emerald-400">Method 2</span>
              <p class="text-sm font-bold text-white mt-0.5">Debt Snowball</p>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-2xs font-semibold bg-emerald-500/15 text-emerald-300 border border-emerald-500/25 uppercase tracking-widest flex-shrink-0">♥ Quick Win</span>
          </div>
          <div>
            <p class="text-3xs uppercase tracking-wider text-slate-400">Total Interest Paid</p>
            <p id="debt-sb-interest" class="text-3xl font-black text-emerald-300 mt-0.5">—</p>
          </div>
          <div class="space-y-2 pt-3 border-t border-emerald-500/10 text-xs text-slate-400">
            <div class="flex justify-between">
              <span>Payoff Timeline:</span>
              <span id="debt-sb-time" class="text-white font-semibold">—</span>
            </div>
            <div class="flex justify-between">
              <span>Blended APR:</span>
              <span id="debt-sb-apr" class="text-white font-medium">0%</span>
            </div>
            <div class="flex justify-between">
              <span>First Debt Cleared:</span>
              <span id="debt-sb-first" class="text-emerald-300 font-semibold">—</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Visual Timeline Comparison Bar Chart -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-5">
        <div class="flex items-center justify-between">
          <h4 class="text-sm font-bold text-white uppercase tracking-wider">Repayment Timeline</h4>
          <span class="text-2xs text-slate-500 font-semibold uppercase tracking-wider">Shorter = Better</span>
        </div>

        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-xs text-slate-400 mb-1.5">
              <span>Avalanche</span>
              <span id="chart-av-time-val" class="font-semibold text-brand-300">—</span>
            </div>
            <div class="h-5 w-full bg-slate-900 rounded-full overflow-hidden border border-slate-800">
              <div id="chart-av-bar" class="h-full bg-gradient-to-r from-indigo-700 to-brand-400 transition-all duration-500 rounded-full" style="width: 0%"></div>
            </div>
          </div>

          <div>
            <div class="flex justify-between text-xs text-slate-400 mb-1.5">
              <span>Snowball</span>
              <span id="chart-sb-time-val" class="font-semibold text-emerald-300">—</span>
            </div>
            <div class="h-5 w-full bg-slate-900 rounded-full overflow-hidden border border-slate-800">
              <div id="chart-sb-bar" class="h-full bg-gradient-to-r from-emerald-700 to-emerald-400 transition-all duration-500 rounded-full" style="width: 0%"></div>
            </div>
          </div>
        </div>

        <!-- Totals summary row -->
        <div class="grid grid-cols-3 gap-2 pt-4 border-t border-slate-800/80 text-center">
          <div>
            <p class="text-3xs sm:text-2xs font-semibold text-slate-400 uppercase tracking-wider">Total Debt</p>
            <p id="debt-total-balance" class="text-xs sm:text-sm font-bold text-white mt-1">—</p>
          </div>
          <div>
            <p class="text-3xs sm:text-2xs font-semibold text-slate-400 uppercase tracking-wider">Debts Listed</p>
            <p id="debt-row-count" class="text-xs sm:text-sm font-bold text-white mt-1">0</p>
          </div>
          <div>
            <p class="text-3xs sm:text-2xs font-semibold text-slate-400 uppercase tracking-wider">Months Saved</p>
            <p id="debt-months-saved" class="text-xs sm:text-sm font-bold text-brand-400 mt-1">0</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (function() {
    const STORAGE_KEY = "taxdebtwealthsuite_state_v1";
    const AUTOSAVE_KEY = "taxdebtwealthsuite_autosave_pref";

    // Read default currency from data attribute
    const container = document.getElementById("panel-debt");
    const defaultCurrency = container ? container.getAttribute("data-default-currency") || "USD" : "USD";

    const DEFAULT_STATE = {
      activeTab: "debt",
      autoSave: true,
      debt: {
        rows: [],
        extra: 0
      }
    };

    let state = JSON.parse(JSON.stringify(DEFAULT_STATE));

    function loadState() {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        try {
          const parsed = JSON.parse(raw);
          if (parsed && parsed.debt) {
            state.debt = {
              rows: Array.isArray(parsed.debt.rows) ? parsed.debt.rows : [],
              extra: parsed.debt.extra ?? 0
            };
          }
        } catch (e) {}
      }
    }

    function saveState() {
      const autoSave = localStorage.getItem(AUTOSAVE_KEY) !== "false";
      const raw = localStorage.getItem(STORAGE_KEY);
      let existing = {};
      if (raw) {
        try { existing = JSON.parse(raw); } catch (e) {}
      }
      existing.debt = state.debt;
      
      if (autoSave) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(existing));
        window.dispatchEvent(new Event("financial-hub-saving"));
        
        setTimeout(() => {
          window.dispatchEvent(new Event("financial-hub-saved"));
        }, 300);
      }
    }

    function formatCurrency(val) {
      let formatted = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: defaultCurrency,
        maximumFractionDigits: 0
      }).format(val);
      
      if (defaultCurrency === 'CAD') {
        formatted = formatted.replace('CA$', 'C$');
      }
      return formatted;
    }

    function renderDebtRows() {
      const container = document.getElementById("debt-rows-container");
      const emptyState = document.getElementById("debt-empty-state");
      if (!container) return;

      container.innerHTML = "";

      const rows = state.debt.rows || [];
      emptyState.style.display = rows.length === 0 ? "flex" : "none";

      rows.forEach((row, idx) => {
        const el = document.createElement("div");
        el.className = "debt-row group relative";
        el.setAttribute("data-idx", idx);
        el.innerHTML = `
          <!-- Mobile layout: stacked -->
          <div class="sm:hidden p-3 bg-slate-900/60 border border-slate-800 rounded-xl space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-3xs font-bold uppercase tracking-widest text-slate-500">Debt #${idx + 1}</span>
              <button class="debt-remove-btn text-slate-600 hover:text-rose-400 transition-colors p-1 rounded" data-idx="${idx}" title="Remove debt">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
            <input type="text" class="debt-row-input focus-ring block w-full px-3 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="name" placeholder="Debt name (e.g. Visa, Student Loan)" value="${row.name || ''}" />
            <div class="grid grid-cols-3 gap-1.5">
              <div>
                <label class="block text-4xs font-bold uppercase tracking-wider text-slate-600 mb-0.5">Balance</label>
                <input type="number" class="debt-row-input focus-ring block w-full px-2 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="balance" placeholder="0" min="0" step="100" value="${row.balance || ''}" />
              </div>
              <div>
                <label class="block text-4xs font-bold uppercase tracking-wider text-slate-600 mb-0.5">Rate %</label>
                <input type="number" class="debt-row-input focus-ring block w-full px-2 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="rate" placeholder="0" min="0" max="100" step="0.1" value="${row.rate || ''}" />
              </div>
              <div>
                <label class="block text-4xs font-bold uppercase tracking-wider text-slate-600 mb-0.5">Min / Mo</label>
                <input type="number" class="debt-row-input focus-ring block w-full px-2 py-1.5 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs" data-idx="${idx}" data-field="min" placeholder="0" min="0" step="5" value="${row.min || ''}" />
              </div>
            </div>
          </div>

          <!-- Desktop layout: row grid -->
          <div class="hidden sm:grid grid-cols-12 gap-2 items-center p-2 bg-slate-900/40 border border-slate-800/60 rounded-xl hover:border-slate-700/80 transition-all duration-150">
            <div class="col-span-4">
              <input type="text" class="debt-row-input focus-ring block w-full px-2.5 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9" data-idx="${idx}" data-field="name" placeholder="e.g. Visa Card" value="${row.name || ''}" />
            </div>
            <div class="col-span-2">
              <input type="number" class="debt-row-input focus-ring block w-full px-2 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9 text-right" data-idx="${idx}" data-field="balance" placeholder="0" min="0" step="100" value="${row.balance || ''}" />
            </div>
            <div class="col-span-2">
              <input type="number" class="debt-row-input focus-ring block w-full px-2 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9 text-right" data-idx="${idx}" data-field="rate" placeholder="0.00" min="0" max="100" step="0.1" value="${row.rate || ''}" />
            </div>
            <div class="col-span-2">
              <input type="number" class="debt-row-input focus-ring block w-full px-2 py-2 bg-slate-950 border border-slate-800 rounded-lg text-white font-medium text-xs h-9 text-right" data-idx="${idx}" data-field="min" placeholder="0" min="0" step="5" value="${row.min || ''}" />
            </div>
            <div class="col-span-2 flex justify-end">
              <button class="debt-remove-btn text-slate-600 hover:text-rose-400 transition-colors p-1.5 rounded-lg hover:bg-rose-500/10 opacity-0 group-hover:opacity-100 cursor-pointer" data-idx="${idx}" title="Remove debt">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </div>
        `;
        container.appendChild(el);
      });

      calculateDebt();
    }

    function addDebtRow() {
      if (!state.debt.rows) state.debt.rows = [];
      state.debt.rows.push({ name: "", balance: 0, rate: 0, min: 0 });
      saveState();
      renderDebtRows();
    }

    function removeDebtRow(idx) {
      state.debt.rows.splice(idx, 1);
      saveState();
      renderDebtRows();
    }

    function calculateDebt() {
      const rows = state.debt.rows || [];
      const debts = rows
        .map((r, i) => ({
          idx: i,
          name: r.name || `Debt #${i + 1}`,
          balance: parseFloat(r.balance) || 0,
          rate:    parseFloat(r.rate)    || 0,
          min:     parseFloat(r.min)     || 0
        }))
        .filter(d => d.balance > 0);

      const extraPayment = parseFloat(state.debt.extra) || 0;
      const totalBalance = rows.reduce((s, r) => s + (parseFloat(r.balance) || 0), 0);

      document.getElementById("debt-total-balance").innerText = formatCurrency(totalBalance);
      document.getElementById("debt-row-count").innerText = debts.length;

      if (debts.length === 0) {
        const dash = "—";
        document.getElementById("debt-av-interest").innerText = formatCurrency(0);
        document.getElementById("debt-av-time").innerText = dash;
        document.getElementById("debt-av-apr").innerText = "0%";
        document.getElementById("debt-av-first").innerText = dash;
        document.getElementById("debt-sb-interest").innerText = formatCurrency(0);
        document.getElementById("debt-sb-time").innerText = dash;
        document.getElementById("debt-sb-apr").innerText = "0%";
        document.getElementById("debt-sb-first").innerText = dash;
        document.getElementById("debt-savings").innerText = dash;
        document.getElementById("debt-months-saved").innerText = "0";
        document.getElementById("chart-av-time-val").innerText = dash;
        document.getElementById("chart-sb-time-val").innerText = dash;
        document.getElementById("chart-av-bar").style.width = "0%";
        document.getElementById("chart-sb-bar").style.width = "0%";
        const banner = document.getElementById("debt-method-banner");
        banner.className = "p-6 rounded-2xl border flex flex-col gap-3 transition-all duration-300 bg-slate-900 border-slate-800";
        document.getElementById("debt-rec-title").innerText = "Add debts to run simulation";
        document.getElementById("debt-rec-subtitle").innerText = "";
        return;
      }

      const initialTotal = debts.reduce((s, d) => s + d.balance, 0);
      const weightedRate = debts.reduce((s, d) => s + d.balance * d.rate, 0);
      const blendedApr = initialTotal > 0 ? (weightedRate / initialTotal) : 0;

      function simulate(sortFn) {
        let pool = debts.map(d => ({ ...d }));
        let totalInterest = 0;
        let months = 0;
        let firstClearedName = null;
        let firstClearedMonth = null;

        while (pool.some(d => d.balance > 0.01) && months < 600) {
          months++;
          pool.sort(sortFn);

          for (const d of pool) {
            if (d.balance > 0) {
              const interest = (d.balance * (d.rate / 100)) / 12;
              totalInterest += interest;
              d.balance += interest;
            }
          }

          let rollover = extraPayment;
          for (const d of pool) {
            if (d.balance > 0) {
              const payment = Math.min(d.balance, d.min);
              d.balance = Math.max(0, d.balance - payment);
            }
          }

          for (const d of pool) {
            if (d.balance > 0.01 && rollover > 0) {
              const payment = Math.min(d.balance, rollover);
              d.balance = Math.max(0, d.balance - payment);
              rollover -= payment;
            }
          }

          if (firstClearedName === null) {
            const cleared = pool.find(d => d.balance <= 0.01 && d.balance >= 0);
            if (cleared && months > 0) {
              firstClearedName = cleared.name;
              firstClearedMonth = months;
            }
          }
        }

        return {
          interest: totalInterest,
          months,
          firstClearedName,
          firstClearedMonth,
          apr: blendedApr
        };
      }

      const avResult = simulate((a, b) => b.rate - a.rate);
      const sbResult = simulate((a, b) => a.balance - b.balance);

      function fmtMonths(m) {
        if (m >= 600) return ">50 yrs";
        const yrs = Math.floor(m / 12);
        const mos = m % 12;
        if (yrs === 0) return `${mos} mo`;
        if (mos === 0) return `${yrs} yr`;
        return `${yrs} yr ${mos} mo`;
      }

      document.getElementById("debt-av-interest").innerText = formatCurrency(avResult.interest);
      document.getElementById("debt-av-time").innerText     = fmtMonths(avResult.months);
      document.getElementById("debt-av-apr").innerText      = blendedApr.toFixed(1) + "%";
      document.getElementById("debt-av-first").innerText    = avResult.firstClearedName
        ? `${avResult.firstClearedName} (mo. ${avResult.firstClearedMonth})`
        : "—";

      document.getElementById("debt-sb-interest").innerText = formatCurrency(sbResult.interest);
      document.getElementById("debt-sb-time").innerText     = fmtMonths(sbResult.months);
      document.getElementById("debt-sb-apr").innerText      = blendedApr.toFixed(1) + "%";
      document.getElementById("debt-sb-first").innerText    = sbResult.firstClearedName
        ? `${sbResult.firstClearedName} (mo. ${sbResult.firstClearedMonth})`
        : "—";

      const interestSaved = Math.max(0, sbResult.interest - avResult.interest);
      const monthsSaved   = Math.max(0, sbResult.months   - avResult.months);

      document.getElementById("debt-savings").innerText      = interestSaved > 0 ? formatCurrency(interestSaved) : "—";
      document.getElementById("debt-months-saved").innerText = monthsSaved > 0 ? monthsSaved : "0";

      const maxMonths = Math.max(avResult.months, sbResult.months, 1);
      document.getElementById("chart-av-time-val").innerText = fmtMonths(avResult.months);
      document.getElementById("chart-sb-time-val").innerText = fmtMonths(sbResult.months);
      document.getElementById("chart-av-bar").style.width = Math.round((avResult.months / maxMonths) * 100) + "%";
      document.getElementById("chart-sb-bar").style.width = Math.round((sbResult.months / maxMonths) * 100) + "%";

      const banner   = document.getElementById("debt-method-banner");
      const recTitle = document.getElementById("debt-rec-title");
      const recSub   = document.getElementById("debt-rec-subtitle");
      const recIcon  = document.getElementById("debt-rec-icon");

      if (interestSaved > 50) {
        banner.className = "p-6 rounded-lg border flex flex-col gap-3 transition-all duration-300 bg-[var(--accent-primary)]/10 border-[var(--accent-primary)]/30";
        recTitle.innerText = `🏆 Choose Avalanche — Save ${formatCurrency(interestSaved)}`;
        recSub.innerText   = monthsSaved > 0
          ? `By targeting highest-rate debt first, you'll be debt-free ${monthsSaved} month${monthsSaved > 1 ? 's' : ''} sooner and pay ${formatCurrency(interestSaved)} less interest.`
          : `Mathematically optimal. Saves ${formatCurrency(interestSaved)} in total interest over the Snowball method.`;
        recIcon.className  = "p-3 rounded-lg bg-[var(--accent-primary)]/20 text-[var(--accent-primary)] hidden sm:flex items-center justify-center flex-shrink-0";
        recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`;
      } else if (sbResult.months < avResult.months) {
        banner.className = "p-6 rounded-lg border flex flex-col gap-3 transition-all duration-300 bg-[var(--color-safe)]/10 border-[var(--color-safe)]/30";
        recTitle.innerText = `♥ Snowball Wins On Speed — ${Math.abs(monthsSaved)} Months Faster`;
        recSub.innerText   = "With these debts, Snowball clears balances faster. Stick with Snowball for the quickest debt-free date.";
        recIcon.className  = "p-3 rounded-lg bg-[var(--color-safe)]/20 text-[var(--color-safe)] hidden sm:flex items-center justify-center flex-shrink-0";
        recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
      } else {
        banner.className = "p-6 rounded-lg border flex flex-col gap-3 transition-all duration-300 bg-amber-500/10 border-amber-500/30";
        recTitle.innerText = `Both Methods Are Essentially Equal`;
        recSub.innerText   = "Your debts have similar rates/balances. Either method works — pick Snowball for motivation, Avalanche for discipline.";
        recIcon.className  = "p-3 rounded-lg bg-amber-500/20 text-amber-400 hidden sm:flex items-center justify-center flex-shrink-0";
        recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>`;
      }
    }

    function updateCurrencySymbols(currency) {
      const symbols = { USD: "$", GBP: "£", CAD: "C$", AUD: "A$" };
      const symbol = symbols[currency] || "$";
      document.querySelectorAll(".debt-currency-symbol").forEach(el => {
        el.innerText = symbol;
      });
      const input = document.getElementById("debt-extra");
      if (input) {
        if (symbol.length > 1) {
          input.classList.remove("pl-8");
          input.classList.add("pl-12");
        } else {
          input.classList.remove("pl-12");
          input.classList.add("pl-8");
        }
      }
    }

    function syncStateToInputs() {
      renderDebtRows();
      document.getElementById("debt-extra").value = state.debt.extra || "";
    }

    function runCalculations() {
      calculateDebt();
    }

    function bindListeners() {
      document.getElementById("debt-add-row").addEventListener("click", addDebtRow);

      document.getElementById("debt-rows-container").addEventListener("input", (e) => {
        const target = e.target;
        if (!target.classList.contains("debt-row-input")) return;
        const idx   = parseInt(target.getAttribute("data-idx"), 10);
        const field = target.getAttribute("data-field");
        if (isNaN(idx) || !field) return;
        if (!state.debt.rows[idx]) return;
        if (field === "name") {
          state.debt.rows[idx][field] = target.value;
        } else {
          state.debt.rows[idx][field] = parseFloat(target.value) || 0;
        }
        saveState();
        calculateDebt();
      });

      document.getElementById("debt-rows-container").addEventListener("click", (e) => {
        const btn = e.target.closest(".debt-remove-btn");
        if (!btn) return;
        const idx = parseInt(btn.getAttribute("data-idx"), 10);
        if (!isNaN(idx)) removeDebtRow(idx);
      });

      document.getElementById("debt-extra").addEventListener("input", (e) => {
        state.debt.extra = parseFloat(e.target.value) || 0;
        saveState();
        calculateDebt();
      });
    }

    loadState();

    window.addEventListener("DOMContentLoaded", () => {
      updateCurrencySymbols(defaultCurrency);
      syncStateToInputs();
      bindListeners();
      runCalculations();
    });

    window.addEventListener("financial-hub-reset", () => {
      state.debt.rows = [];
      state.debt.extra = 0;
      renderDebtRows();
      document.getElementById("debt-extra").value = "";
      runCalculations();
    });
  })();
</script>
