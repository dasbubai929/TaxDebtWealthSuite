---
interface Props {
  defaultCountry?: string;
}

const { defaultCountry = "US" } = Astro.props;
---

<section id="panel-tax" class="space-y-6" data-default-country={defaultCountry}>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

    <!-- LEFT: Inputs -->
    <div class="space-y-6">
      <div class="glass-panel p-6 rounded-2xl shadow-xl space-y-5 border border-slate-800">
        <div>
          <h3 class="text-lg font-bold text-white tracking-wide">Business &amp; Income Details</h3>
          <p class="text-xs text-slate-400 mt-1">Enter your figures to compare unincorporated vs. corporate tax structures.</p>
        </div>

        <div class="space-y-4">
          <!-- Country Selector -->
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Country / Jurisdiction</label>
            <div class="flex flex-wrap gap-2 mb-2">
              <a href="/s-corp-tax-calculator/" class={`px-4 py-2 rounded-lg text-sm font-semibold transition-colors border ${defaultCountry === 'US' ? 'bg-[#00F5D4]/10 text-[#00F5D4] border-[#00F5D4]/30' : 'bg-slate-900 text-slate-400 border-slate-700 hover:text-white hover:bg-slate-800'}`} onclick="try{const s=JSON.parse(localStorage.getItem('financial_hub_state')||'{}');if(!s.tax)s.tax={};s.tax.country='US';localStorage.setItem('financial_hub_state',JSON.stringify(s))}catch(e){}">US</a>
              <a href="/s-corp-tax-calculator/uk/" class={`px-4 py-2 rounded-lg text-sm font-semibold transition-colors border ${defaultCountry === 'UK' ? 'bg-[#00F5D4]/10 text-[#00F5D4] border-[#00F5D4]/30' : 'bg-slate-900 text-slate-400 border-slate-700 hover:text-white hover:bg-slate-800'}`} onclick="try{const s=JSON.parse(localStorage.getItem('financial_hub_state')||'{}');if(!s.tax)s.tax={};s.tax.country='UK';localStorage.setItem('financial_hub_state',JSON.stringify(s))}catch(e){}">UK</a>
              <a href="/s-corp-tax-calculator/canada/" class={`px-4 py-2 rounded-lg text-sm font-semibold transition-colors border ${defaultCountry === 'CA' ? 'bg-[#00F5D4]/10 text-[#00F5D4] border-[#00F5D4]/30' : 'bg-slate-900 text-slate-400 border-slate-700 hover:text-white hover:bg-slate-800'}`} onclick="try{const s=JSON.parse(localStorage.getItem('financial_hub_state')||'{}');if(!s.tax)s.tax={};s.tax.country='CA';localStorage.setItem('financial_hub_state',JSON.stringify(s))}catch(e){}">Canada</a>
              <a href="/s-corp-tax-calculator/australia/" class={`px-4 py-2 rounded-lg text-sm font-semibold transition-colors border ${defaultCountry === 'AU' ? 'bg-[#00F5D4]/10 text-[#00F5D4] border-[#00F5D4]/30' : 'bg-slate-900 text-slate-400 border-slate-700 hover:text-white hover:bg-slate-800'}`} onclick="try{const s=JSON.parse(localStorage.getItem('financial_hub_state')||'{}');if(!s.tax)s.tax={};s.tax.country='AU';localStorage.setItem('financial_hub_state',JSON.stringify(s))}catch(e){}">Australia</a>
            </div>
            <select id="tax-country" class="hidden">
              <option value="US">🇺🇸 United States</option>
              <option value="UK">🇬🇧 United Kingdom</option>
              <option value="CA">🇨🇦 Canada</option>
              <option value="AU">🇦🇺 Australia</option>
            </select>
          </div>

          <!-- Gross Revenue -->
          <div>
            <label for="tax-revenue" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Annual Side-Hustle Gross Revenue</label>
            <div class="relative rounded-lg shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium tax-currency-symbol">$</div>
              <input type="number" id="tax-revenue" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="1000" placeholder="0" />
            </div>
          </div>

          <!-- Business Expenses -->
          <div>
            <label for="tax-expenses" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">Annual Deductible Business Expenses</label>
            <div class="relative rounded-lg shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium tax-currency-symbol">$</div>
              <input type="number" id="tax-expenses" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="500" placeholder="0" />
            </div>
          </div>

          <!-- Day Job Income -->
          <div>
            <label for="tax-w2" class="block text-xs font-semibold uppercase tracking-wider text-slate-300 mb-2">
              <span id="tax-w2-label">W2 / PAYE Day-Job Annual Income</span>
            </label>
            <div class="relative rounded-lg shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400 font-medium tax-currency-symbol">$</div>
              <input type="number" id="tax-w2" class="focus-ring block w-full pl-8 pr-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white font-medium text-sm h-12" min="0" step="1000" placeholder="0" />
            </div>
            <p class="text-3xs text-slate-500 mt-1">Used to calculate your marginal tax bracket — crucial for accuracy.</p>
          </div>
        </div>
      </div>

      <!-- S-Corp Salary vs. Distributions Optimizer Card -->
      <div id="tax-optimizer-card" class="glass-panel p-6 rounded-2xl shadow-xl space-y-5 border border-slate-800 hidden">
        <div>
          <h3 id="opt-title" class="text-lg font-bold text-white tracking-wide">S-Corp Salary vs. Distributions Optimizer</h3>
          <p id="opt-subtitle" class="text-xs text-slate-400 mt-1">Optimize your corporate salary split to minimize taxes and audit risk.</p>
        </div>

        <!-- Notice Banner for Low Net Profit -->
        <div id="opt-notice-banner" class="p-4 rounded-xl text-xs leading-relaxed bg-amber-500/10 border border-amber-500/20 text-amber-300 hidden">
          S-Corp optimization is generally not cost-effective below $40,000 in net profit due to compliance overhead.
        </div>

        <!-- Interactive Controls (Shown when net profit > threshold) -->
        <div id="opt-controls" class="space-y-5">
          <!-- Slider -->
          <div class="space-y-2">
            <div class="flex justify-between items-center text-xs">
              <label id="opt-slider-label" for="opt-salary-pct" class="font-semibold uppercase tracking-wider text-slate-300">Salary Percentage</label>
              <span id="opt-salary-pct-val" class="font-mono text-brand-300 font-bold text-sm">40%</span>
            </div>
            <input type="range" id="opt-salary-pct" min="30" max="70" step="1" class="w-full accent-[#00F5D4] cursor-pointer bg-slate-900 h-2 rounded-lg border border-slate-700 appearance-none" />
            <div class="flex justify-between text-4xs uppercase tracking-wider text-slate-500 font-bold px-1">
              <span>30% (Aggressive)</span>
              <span>50%</span>
              <span>70% (Conservative)</span>
            </div>
          </div>

          <!-- Visual Audit Risk Gauge -->
          <div class="space-y-2">
            <div class="flex justify-between items-center text-xs">
              <span class="font-semibold uppercase tracking-wider text-slate-300">Audit Risk Level</span>
              <div class="h-6 flex items-center justify-end min-w-[7.5rem]">
                <span id="opt-risk-status" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold uppercase transition-all duration-300">Safe</span>
              </div>
            </div>
            
            <!-- Progress/Gauge Bar -->
            <div class="relative w-full h-3 bg-slate-950 rounded-full overflow-hidden border border-slate-800 flex">
              <div class="h-full bg-rose-500/80 border-r border-rose-500/20" style="width: 25%"></div>
              <div class="h-full bg-amber-500/80 border-r border-amber-500/20" style="width: 25%"></div>
              <div class="h-full bg-emerald-500/80" style="width: 50%"></div>
              <div id="opt-risk-pointer" class="absolute top-0 bottom-0 w-1.5 bg-white shadow-[0_0_8px_rgba(255,255,255,0.8)] transition-all duration-300" style="left: 25%; transform: translateX(-50%);"></div>
            </div>

            <!-- Risk explanation -->
            <div class="min-h-[3.25rem] flex items-center p-3 bg-slate-950/50 border border-slate-900 rounded-xl text-3xs text-slate-400 leading-relaxed overflow-hidden">
              <p id="opt-risk-desc" class="m-0"></p>
            </div>
          </div>

          <!-- Interactive Results Breakdown -->
          <div class="grid grid-cols-2 gap-4 pt-2 border-t border-slate-800/80">
            <div>
              <p id="opt-salary-label" class="text-3xs uppercase tracking-wider text-slate-400">Salary Amount</p>
              <p id="opt-salary-val" class="text-sm font-bold text-white mt-0.5">$0</p>
            </div>
            <div>
              <p id="opt-dist-label" class="text-3xs uppercase tracking-wider text-slate-400">Distributions</p>
              <p id="opt-dist-val" class="text-sm font-bold text-white mt-0.5">$0</p>
            </div>
          </div>
          
          <div class="p-4 bg-emerald-500/5 border border-emerald-500/20 rounded-xl flex justify-between items-center">
            <div>
              <p id="opt-savings-label" class="text-2xs font-semibold text-slate-300 uppercase tracking-wider">Salary Split Net Savings</p>
              <p class="text-3xs text-slate-500 mt-0.5">Additional tax saved vs. default unincorporated route.</p>
            </div>
            <p id="opt-savings-val" class="text-lg font-black text-[#00F5D4] mono-data">$0</p>
          </div>
        </div>
      </div>

      <!-- Country Explainer Card -->
      <div id="tax-country-tip" class="bg-gradient-to-br from-slate-900 to-indigo-950/40 p-5 rounded-2xl border border-slate-850 space-y-3">
        <h4 class="text-xs font-bold tracking-wider text-brand-300 uppercase">How Your Country Is Calculated</h4>
        <p id="tax-country-tip-text" class="text-xs text-slate-300 leading-relaxed">
          Select your country above to see jurisdiction-specific tax rates and corporate structure guidance.
        </p>
      </div>
    </div>

    <!-- RIGHT: Real-Time Outputs -->
    <div class="space-y-6">

      <!-- Break-Even / Recommendation Banner -->
      <div id="tax-recommendation-banner" class="p-6 rounded-2xl border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-slate-900 border-slate-800">
        <div class="flex items-center space-x-4">
          <div id="tax-rec-icon" class="p-3 rounded-xl bg-slate-800 text-slate-400 hidden sm:flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-400">Optimal Structure</p>
            <h4 id="tax-rec-title" class="text-lg font-extrabold text-white mt-0.5">Enter revenue to begin</h4>
            <p id="tax-breakeven-msg" class="text-xs text-slate-400 mt-1"></p>
          </div>
        </div>
        <div class="text-left sm:text-right flex-shrink-0">
          <p class="text-2xs font-semibold uppercase tracking-wider text-slate-400">Annual Tax Saved</p>
          <p id="tax-rec-savings" class="text-2xl font-black text-white mt-0.5">—</p>
        </div>
      </div>

      <!-- Share Results — Tax -->
      <div class="flex justify-end">
        <button
          onclick="shareResults('tax')"
          class="group flex items-center gap-2 px-3.5 py-2 rounded-xl border border-[#00F5D4]/20 bg-[#00F5D4]/5 hover:bg-[#00F5D4]/10 hover:border-[#00F5D4]/40 text-[#94A3B8] hover:text-[#00F5D4] text-xs font-semibold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-[#00F5D4]/30"
          aria-label="Share your Side-Hustle Tax Predictor results"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0 transition-transform duration-200 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          <span>Share Results</span>
        </button>
      </div>

      <!-- Scenario A vs B Comparison Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <!-- Scenario A: Unincorporated -->
        <div class="glass-panel p-5 rounded-lg border border-[#EF4444]/20 space-y-4">
          <div class="flex justify-between items-start">
            <div>
              <span class="text-3xs font-bold uppercase tracking-widest text-rose-400">Scenario A</span>
              <p id="tax-sole-label" class="text-sm font-bold text-white mt-0.5">Sole Trader / Unincorporated</p>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-2xs font-semibold bg-slate-800 text-slate-400 border border-slate-700 uppercase tracking-widest flex-shrink-0">Default</span>
          </div>
          <div>
            <p class="text-3xs uppercase tracking-wider text-slate-400">Total Annual Tax Burden</p>
            <p id="tax-sole-total" class="focal-metric text-[#EF4444] mt-0.5">$0</p>
          </div>
          <div class="space-y-2 pt-3 border-t border-rose-500/10 text-xs text-slate-400">
            <div class="flex justify-between">
              <span id="tax-sole-se-label">Self-Employment / NI Tax:</span>
              <span id="tax-sole-se" class="text-white font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span>Income Tax on Profits:</span>
              <span id="tax-sole-income" class="text-white font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span>Effective Tax Rate:</span>
              <span id="tax-sole-rate" class="text-rose-400 font-semibold">0%</span>
            </div>
          </div>
        </div>

        <!-- Scenario B: Incorporated -->
        <div class="glass-panel p-5 rounded-lg border border-[#00F5D4]/20 space-y-4">
          <div class="flex justify-between items-start">
            <div>
              <span class="text-3xs font-bold uppercase tracking-widest text-brand-400">Scenario B</span>
              <p id="tax-corp-label" class="text-sm font-bold text-white mt-0.5">S-Corp / Ltd Company</p>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-2xs font-semibold bg-brand-500/15 text-brand-300 border border-brand-500/25 uppercase tracking-widest flex-shrink-0">Optimized</span>
          </div>
          <div>
            <p class="text-3xs uppercase tracking-wider text-slate-400">Total Annual Tax Burden</p>
            <p id="tax-scorp-total" class="focal-metric text-[#00F5D4] mt-0.5">$0</p>
          </div>
          <div class="space-y-2 pt-3 border-t border-brand-500/10 text-xs text-slate-400">
            <div class="flex justify-between">
              <span id="tax-scorp-se-label">Payroll / Corp Tax:</span>
              <span id="tax-scorp-se" class="text-white font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span id="tax-scorp-income-label">Salary + Dividend Tax:</span>
              <span id="tax-scorp-income" class="text-white font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span>Effective Tax Rate:</span>
              <span id="tax-corp-rate" class="text-brand-400 font-semibold">0%</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Tax Drag Bar Chart -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-5">
        <div class="flex items-center justify-between">
          <h4 class="text-sm font-bold text-white uppercase tracking-wider">Tax Burden Comparison</h4>
          <span class="text-2xs text-slate-500 uppercase font-semibold tracking-wider">Lower = Better</span>
        </div>

        <div class="space-y-4">
          <!-- Sole Trader bar -->
          <div>
            <div class="flex justify-between text-xs text-slate-400 mb-1.5">
              <span id="chart-sole-bar-label">Sole Trader Tax Burden</span>
              <span id="chart-sole-tax-perc" class="font-semibold text-rose-400">0%</span>
            </div>
            <div class="h-5 w-full bg-slate-900 rounded-full overflow-hidden border border-slate-800">
              <div id="chart-sole-tax-bar" class="h-full bg-gradient-to-r from-rose-700 to-rose-400 transition-all duration-500 rounded-full" style="width: 0%"></div>
            </div>
          </div>

          <!-- Incorporated bar -->
          <div>
            <div class="flex justify-between text-xs text-slate-400 mb-1.5">
              <span id="chart-corp-bar-label">Incorporated Tax Burden</span>
              <span id="chart-scorp-tax-perc" class="font-semibold text-brand-400">0%</span>
            </div>
            <div class="h-5 w-full bg-slate-900 rounded-full overflow-hidden border border-slate-800">
              <div id="chart-scorp-tax-bar" class="h-full bg-gradient-to-r from-indigo-700 to-brand-400 transition-all duration-500 rounded-full" style="width: 0%"></div>
            </div>
          </div>
        </div>

        <!-- Net Profit & Effective Rates summary row -->
        <div class="grid grid-cols-3 gap-2 pt-4 border-t border-slate-800/80 text-center">
          <div>
            <p class="text-3xs sm:text-2xs font-semibold text-slate-400 uppercase tracking-wider">Net Profit</p>
            <p id="tax-net-profit" class="text-xs sm:text-sm font-bold text-white mt-1">$0</p>
          </div>
          <div>
            <p class="text-3xs sm:text-2xs font-semibold text-slate-400 uppercase tracking-wider">Sole Rate</p>
            <p id="tax-sole-eff-rate" class="text-xs sm:text-sm font-bold text-rose-400 mt-1">0%</p>
          </div>
          <div>
            <p class="text-3xs sm:text-2xs font-semibold text-slate-400 uppercase tracking-wider">Corp Rate</p>
            <p id="tax-corp-eff-rate" class="text-xs sm:text-sm font-bold text-brand-400 mt-1">0%</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (function() {
    const STORAGE_KEY = "taxdebtwealthsuite_state_v1";
    const AUTOSAVE_KEY = "taxdebtwealthsuite_autosave_pref";

    const DEFAULT_STATE = {
      activeTab: "tax",
      autoSave: true,
      tax: {
        country: "US",
        revenue: 0,
        expenses: 0,
        w2: 0,
        salaryPct: 40,
        isSliderDirty: false
      }
    };

    let state = JSON.parse(JSON.stringify(DEFAULT_STATE));

    const TAX_CONFIGS = {
      US: {
        symbol: "$", currency: "USD",
        w2Label: "W2 Day-Job Annual Income",
        soleLabel: "Sole Proprietor / Self-Employed",
        corpLabel: "LLC with S-Corp Election",
        soleSELabel: "Self-Employment Tax (15.3%):",
        corpTaxLabel: "Payroll Tax on Salary (FICA):",
        corpIncomeLabel: "Income Tax on Pass-Through:",
        breakEvenRevenue: 40000,
        corpOverheadCost: 1500,
        tip: "In the US, Sole Proprietors pay 15.3% SE tax on all net profit up to $184,500 (2026 SS wage base). An S-Corp election lets you split income into a 'reasonable salary' (FICA applies) and profit distributions (no FICA). Savings typically kick in above ~$40k net profit."
      },
      UK: {
        symbol: "£", currency: "GBP",
        w2Label: "PAYE Employed Income (Gross)",
        soleLabel: "Sole Trader / Self-Employed",
        corpLabel: "Private Ltd Company (Ltd)",
        soleSELabel: "Class 4 National Insurance (6%):",
        corpTaxLabel: "Corporation Tax (19%):",
        corpIncomeLabel: "Dividend + Salary Income Tax:",
        breakEvenRevenue: 30000,
        corpOverheadCost: 1200,
        tip: "UK Sole Traders pay Class 4 NI at 6% on profits between £12,570–£50,270 (2% above). An Ltd company pays 19% Corp Tax on profits under £50k (small profits rate), then directors draw a low PAYE salary (~£12,570 tax-free) and top up with dividends taxed at 8.75% basic rate."
      },
      CA: {
        symbol: "$", currency: "CAD",
        w2Label: "Employment (T4) Annual Income",
        soleLabel: "Sole Proprietor / Self-Employed",
        corpLabel: "Canadian Controlled Corp (CCPC)",
        soleSELabel: "CPP Self-Employed Contributions:",
        corpTaxLabel: "Small Business Tax (9% SBD):",
        corpIncomeLabel: "Salary + Dividend Income Tax:",
        breakEvenRevenue: 50000,
        corpOverheadCost: 2000,
        tip: "Canadian Sole Proprietors pay both employee + employer CPP (~9.9% total) on net business income up to ~$73,200. A CCPC qualifies for the Small Business Deduction: 9% federal tax on up to $500k active income (vs 15% general). Retained earnings compound at the low rate."
      },
      AU: {
        symbol: "$", currency: "AUD",
        w2Label: "PAYG Employer Income (Gross)",
        soleLabel: "Sole Trader / Self-Employed",
        corpLabel: "Pty Ltd Company (Small Business)",
        soleSELabel: "Medicare Levy (2%):",
        corpTaxLabel: "Company Tax (25%):",
        corpIncomeLabel: "Div + Salary Income Tax (net):",
        breakEvenRevenue: 80000,
        corpOverheadCost: 1800,
        tip: "Australian Sole Traders add business profit to personal income and face marginal rates up to 45% + 2% Medicare levy. A Pty Ltd with turnover under $50M pays 25% company tax. Directors draw a tax-free salary up to the tax-free threshold ($18,200), then distribute franked dividends."
      }
    };

    function loadState() {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        try {
          const parsed = JSON.parse(raw);
          if (parsed && parsed.tax) {
            state.tax = { ...DEFAULT_STATE.tax, ...parsed.tax };
          }
        } catch (e) {}
      }

      const container = document.getElementById("panel-tax");
      if (container) {
        const defaultCountry = container.getAttribute("data-default-country");
        if (defaultCountry) {
          state.tax.country = defaultCountry;
        }
      }
    }

    function saveState() {
      const autoSave = localStorage.getItem(AUTOSAVE_KEY) !== "false";
      const raw = localStorage.getItem(STORAGE_KEY);
      let existing = {};
      if (raw) {
        try { existing = JSON.parse(raw); } catch (e) {}
      }
      existing.tax = state.tax;
      
      if (autoSave) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(existing));
        window.dispatchEvent(new Event("financial-hub-saving"));
        
        setTimeout(() => {
          window.dispatchEvent(new Event("financial-hub-saved"));
        }, 300);
      }
    }

    function getSalaryAndDist(country, netProfit, pct, isSliderDirty) {
      let salary = 0;
      if (country === "US") {
        if (!isSliderDirty) {
          salary = Math.max(netProfit * 0.40, 45000);
          salary = Math.min(salary, 160000);
          salary = Math.min(salary, netProfit);
        } else {
          salary = netProfit * (pct / 100);
        }
      } else if (country === "UK") {
        if (!isSliderDirty) {
          salary = Math.min(netProfit, 12570);
        } else {
          salary = netProfit * (pct / 100);
        }
      } else if (country === "CA") {
        salary = netProfit * (pct / 100);
      } else if (country === "AU") {
        if (!isSliderDirty) {
          salary = Math.min(netProfit, 18200);
        } else {
          salary = netProfit * (pct / 100);
        }
      }
      const dist = Math.max(0, netProfit - salary);
      return { salary, dist };
    }

    function calculateTax() {
      const country = state.tax.country || "US";
      const cfg = TAX_CONFIGS[country] || TAX_CONFIGS.US;
      const rev  = parseFloat(state.tax.revenue)  || 0;
      const exp  = parseFloat(state.tax.expenses) || 0;
      const w2   = parseFloat(state.tax.w2)       || 0;
      const netProfit = Math.max(0, rev - exp);

      let soleSE = 0, soleIT = 0, soleTotalTax = 0;
      let corpTax = 0, corpIT = 0, corpTotalTax = 0;

      let salaryPct = state.tax.salaryPct || 40;
      if (!state.tax.isSliderDirty) {
        const { salary: defaultSalary } = getSalaryAndDist(country, netProfit, 40, false);
        const defaultPct = netProfit > 0 ? Math.round((defaultSalary / netProfit) * 100) : 40;
        salaryPct = Math.max(30, Math.min(70, defaultPct));
        state.tax.salaryPct = salaryPct;
      }

      const optSlider = document.getElementById("opt-salary-pct");
      if (optSlider) {
        optSlider.value = salaryPct;
      }

      if (country === "US") {
        function usIT(income) {
          const i = Math.max(0, income - 15000);
          if (i <= 11925)  return i * 0.10;
          if (i <= 48475)  return 1192.5 + (i - 11925) * 0.12;
          if (i <= 103350) return 5578.5 + (i - 48475) * 0.22;
          if (i <= 197300) return 17651 + (i - 103350) * 0.24;
          if (i <= 250525) return 40199 + (i - 197300) * 0.32;
          if (i <= 626350) return 57231 + (i - 250525) * 0.35;
          return 188769.75 + (i - 626350) * 0.37;
        }
        const ssCap = 184500;
        const net9235 = netProfit * 0.9235;
        const ssPortion = Math.min(net9235, ssCap) * 0.124;
        const medPortion = net9235 * 0.029;
        soleSE = ssPortion + medPortion;
        const soleDeduction = soleSE * 0.5;
        soleIT = Math.max(0, usIT(w2 + netProfit - soleDeduction) - usIT(w2));
        soleTotalTax = soleSE + soleIT;

        const { salary: sSalary, dist: sDist } = getSalaryAndDist("US", netProfit, salaryPct, state.tax.isSliderDirty);
        const ssCapCorpSalary = Math.min(sSalary * 0.9235, ssCap);
        corpTax = ssCapCorpSalary * 0.124 + sSalary * 0.9235 * 0.029;
        const corpDeductEmployer = corpTax * 0.5;
        corpIT = Math.max(0, usIT(w2 + sSalary + sDist - corpDeductEmployer) - usIT(w2));
        corpTotalTax = corpTax + corpIT;
      }
      else if (country === "UK") {
        function ukIT(income) {
          const pa = 12570;
          const taxable = Math.max(0, income - pa);
          if (taxable <= 37700)  return taxable * 0.20;
          if (taxable <= 125140) return 7540 + (taxable - 37700) * 0.40;
          return 42140 + (taxable - 125140) * 0.45;
        }
        const cls4Low = 12570, cls4High = 50270;
        const cl4Base = Math.max(0, Math.min(netProfit, cls4High) - cls4Low) * 0.06;
        const cl4Extra = Math.max(0, netProfit - cls4High) * 0.02;
        soleSE = cl4Base + cl4Extra;
        soleIT = Math.max(0, ukIT(w2 + netProfit) - ukIT(w2));
        soleTotalTax = soleSE + soleIT;

        const { salary: ltdSalary } = getSalaryAndDist("UK", netProfit, salaryPct, state.tax.isSliderDirty);
        const corpProfit = Math.max(0, netProfit - ltdSalary);
        corpTax = corpProfit <= 50000 ? corpProfit * 0.19 :
                  corpProfit <= 250000 ? corpProfit * (0.19 + (corpProfit - 50000) / 200000 * 0.06) :
                  corpProfit * 0.25;
        const dividendIncome = Math.max(0, corpProfit - corpTax);
        function divTax(div, totalIncome) {
          const allowance = 500;
          const taxableDiv = Math.max(0, div - allowance);
          const baseSpace = Math.max(0, 50270 - totalIncome);
          const basicDiv = Math.min(taxableDiv, baseSpace);
          const higherDiv = Math.max(0, taxableDiv - basicDiv);
          return basicDiv * 0.0875 + higherDiv * 0.3375;
        }
        corpIT = divTax(dividendIncome, w2 + ltdSalary);
        corpTotalTax = corpTax + corpIT;
      }
      else if (country === "CA") {
        function caIT(income) {
          if (income <= 57375)  return income * 0.15;
          if (income <= 114750) return 8606.25 + (income - 57375) * 0.205;
          if (income <= 177882) return 20349.38 + (income - 114750) * 0.26;
          if (income <= 253414) return 36764.70 + (income - 177882) * 0.29;
          return 58676.78 + (income - 253414) * 0.33;
        }
        const cppMax = 73200, cppMin = 3500;
        const cppBase = Math.max(0, Math.min(netProfit, cppMax) - cppMin);
        soleSE = cppBase * 0.099;
        const soleTaxable = w2 + netProfit;
        soleIT = Math.max(0, (caIT(soleTaxable) + soleTaxable * 0.0915) - (caIT(w2) + w2 * 0.0915));
        soleTotalTax = soleSE + soleIT;

        const { salary: corpSalary } = getSalaryAndDist("CA", netProfit, salaryPct, state.tax.isSliderDirty);
        const corpTaxable = Math.max(0, netProfit - corpSalary);
        corpTax = Math.min(corpTaxable, 500000) * 0.12;
        const dividends = Math.max(0, corpTaxable - corpTax);
        const corpSalaryCPP = Math.max(0, Math.min(corpSalary, cppMax) - cppMin) * 0.0495;
        const divIncomeTax = dividends * 0.1502;
        corpIT = Math.max(0, (caIT(w2 + corpSalary) + (w2 + corpSalary) * 0.0915) - (caIT(w2) + w2 * 0.0915)) + divIncomeTax;
        corpTotalTax = corpTax + corpSalaryCPP + corpIT;
      }
      else if (country === "AU") {
        function auIT(income) {
          if (income <= 18200)  return 0;
          if (income <= 45000)  return (income - 18200) * 0.19;
          if (income <= 120000) return 5092 + (income - 45000) * 0.325;
          if (income <= 180000) return 29467 + (income - 120000) * 0.37;
          return 51667 + (income - 180000) * 0.45;
        }
        const medicareLevy = (income) => income > 26000 ? income * 0.02 : 0;
        soleSE = medicareLevy(netProfit);
        soleIT = Math.max(0, auIT(w2 + netProfit) + medicareLevy(w2 + netProfit) - auIT(w2) - medicareLevy(w2));
        soleTotalTax = soleSE + soleIT;

        const { salary: auSalary } = getSalaryAndDist("AU", netProfit, salaryPct, state.tax.isSliderDirty);
        const corpTaxable = Math.max(0, netProfit - auSalary);
        corpTax = corpTaxable * 0.25;
        const dividends = Math.max(0, corpTaxable - corpTax);
        const grossDiv = dividends / 0.75;
        const frankingCredit = grossDiv - dividends;
        const divMarginalTax = Math.max(0, auIT(w2 + auSalary + grossDiv) + medicareLevy(w2 + auSalary + grossDiv)
          - auIT(w2 + auSalary) - medicareLevy(w2 + auSalary));
        corpIT = Math.max(0, divMarginalTax - frankingCredit);
        corpTotalTax = corpTax + corpIT;
      }

      function fmt(v) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: cfg.currency, maximumFractionDigits: 0 }).format(v);
      }

      const savings = Math.max(0, soleTotalTax - corpTotalTax);
      const soleEffRate = netProfit > 0 ? (soleTotalTax / netProfit) * 100 : 0;
      const corpEffRate = netProfit > 0 ? (corpTotalTax / netProfit) * 100 : 0;

      document.getElementById("tax-sole-total").innerText = fmt(soleTotalTax);
      document.getElementById("tax-sole-se").innerText    = fmt(soleSE);
      document.getElementById("tax-sole-income").innerText = fmt(soleIT);
      document.getElementById("tax-sole-rate").innerText  = soleEffRate.toFixed(1) + "%";
      document.getElementById("tax-sole-eff-rate").innerText = soleEffRate.toFixed(1) + "%";

      document.getElementById("tax-scorp-total").innerText  = fmt(corpTotalTax);
      document.getElementById("tax-scorp-se").innerText     = fmt(corpTax);
      document.getElementById("tax-scorp-income").innerText = fmt(corpIT);
      document.getElementById("tax-corp-rate").innerText    = corpEffRate.toFixed(1) + "%";
      document.getElementById("tax-corp-eff-rate").innerText = corpEffRate.toFixed(1) + "%";

      document.getElementById("tax-net-profit").innerText  = fmt(netProfit);
      document.getElementById("tax-rec-savings").innerText = savings > 0 ? fmt(savings) : "—";

      const optimizerCard = document.getElementById("tax-optimizer-card");
      if (optimizerCard) {
        if (netProfit > 0) {
          optimizerCard.classList.remove("hidden");
          const threshold = cfg.breakEvenRevenue;
          const noticeBanner = document.getElementById("opt-notice-banner");
          const controls = document.getElementById("opt-controls");
          
          if (netProfit < threshold) {
            noticeBanner.classList.remove("hidden");
            controls.classList.add("hidden");
            noticeBanner.innerText = `${cfg.corpLabel.replace("LLC with ", "")} optimization is generally not cost-effective below ${fmt(threshold)} in net profit due to compliance overhead.`;
          } else {
            noticeBanner.classList.add("hidden");
            controls.classList.remove("hidden");

            document.getElementById("opt-title").innerText = `${cfg.symbol}-Corp Salary vs. Distributions Optimizer`.replace("$-Corp", "S-Corp").replace("£-Corp", "Ltd Company").replace("C$-Corp", "CCPC").replace("A$-Corp", "Pty Ltd");
            
            const sliderLabel = document.getElementById("opt-slider-label");
            const salaryLabel = document.getElementById("opt-salary-label");
            const distLabel = document.getElementById("opt-dist-label");
            const savingsLabel = document.getElementById("opt-savings-label");

            if (country === "UK") {
              sliderLabel.innerText = "Director's Salary %";
              salaryLabel.innerText = "Director's Salary";
              distLabel.innerText = "Dividend Distributions";
              savingsLabel.innerText = "Ltd Dividend Split Savings";
            } else if (country === "CA") {
              sliderLabel.innerText = "Salary Split %";
              salaryLabel.innerText = "Director's Salary";
              distLabel.innerText = "Dividends / Retained";
              savingsLabel.innerText = "CCPC Integration Savings";
            } else if (country === "AU") {
              sliderLabel.innerText = "Salary Split %";
              salaryLabel.innerText = "Director's Salary";
              distLabel.innerText = "Franked Dividends";
              savingsLabel.innerText = "Pty Ltd Net Savings";
            } else {
              sliderLabel.innerText = "Salary Percentage";
              salaryLabel.innerText = "Salary Amount";
              distLabel.innerText = "Distributions";
              savingsLabel.innerText = "Salary Split Net Savings";
            }

            const { salary, dist } = getSalaryAndDist(country, netProfit, salaryPct, state.tax.isSliderDirty);
            document.getElementById("opt-salary-pct-val").innerText = salaryPct + "%";
            document.getElementById("opt-salary-val").innerText = fmt(salary);
            document.getElementById("opt-dist-val").innerText = fmt(dist);
            document.getElementById("opt-savings-val").innerText = savings > 0 ? fmt(savings) : fmt(0);

            const riskStatus = document.getElementById("opt-risk-status");
            const riskDesc = document.getElementById("opt-risk-desc");
            const riskPointer = document.getElementById("opt-risk-pointer");

            const pointerLeft = Math.max(0, Math.min(100, ((salaryPct - 30) / 40) * 100));
            riskPointer.style.left = pointerLeft + "%";

            let riskLevel = "Safe";
            let riskClass = "bg-emerald-500/10 text-[var(--color-safe)] border border-[var(--color-safe)]/30";
            let descText = "";

            if (country === "US") {
              const actualPct = (salary / netProfit) * 100;
              if (actualPct >= 40 && actualPct <= 60) {
                riskLevel = "Safe";
                riskClass = "bg-emerald-500/10 text-[var(--color-safe)] border border-[var(--color-safe)]/30";
                descText = "Low risk. The salary is within the recommended 40%-60% range, satisfying the IRS 'reasonable compensation' guideline.";
              } else if (actualPct >= 30 && actualPct < 40) {
                riskLevel = "Moderate";
                riskClass = "bg-amber-500/10 text-amber-400 border border-amber-500/30";
                descText = "Moderate risk. A salary between 30%-39% is aggressive. Ensure you can support this with industry wage surveys for your role.";
              } else if (actualPct < 30) {
                riskLevel = "High Risk";
                riskClass = "bg-rose-500/10 text-[var(--color-risk)] border border-[var(--color-risk)]/30";
                descText = "High risk! A salary below 30% is a primary audit trigger for S-Corporations. The IRS may recharacterize distributions as salary.";
              } else {
                riskLevel = "Conservative";
                riskClass = "bg-emerald-500/10 text-[var(--color-safe)] border border-[var(--color-safe)]/30";
                descText = "Very safe from audit, but higher salary reduces your FICA tax savings advantage.";
              }
            } else if (country === "UK") {
              if (salary <= 12570) {
                riskLevel = "Optimal";
                riskClass = "bg-emerald-500/10 text-[var(--color-safe)] border border-[var(--color-safe)]/30";
                descText = "Optimal UK setup. Paying a salary around £12,570 minimizes National Insurance while maintaining state pension credits.";
              } else {
                riskLevel = "Sub-optimal";
                riskClass = "bg-amber-500/10 text-amber-400 border border-amber-500/30";
                descText = "Sub-optimal tax setup. Salaries above the NI threshold trigger Income Tax and National Insurance contributions.";
              }
            } else if (country === "CA") {
              if (salaryPct <= 50) {
                riskLevel = "Optimal";
                riskClass = "bg-emerald-500/10 text-[var(--color-safe)] border border-[var(--color-safe)]/30";
                descText = "Low risk. The salary/dividend mix leverages the Small Business Deduction and fits standard corporate tax integration.";
              } else {
                riskLevel = "Sub-optimal";
                riskClass = "bg-amber-500/10 text-amber-400 border border-amber-500/30";
                descText = "Sub-optimal. High salary reduces corporate retained earnings that could benefit from tax-deferred compounding under SBD.";
              }
            } else if (country === "AU") {
              if (salaryPct <= 50) {
                riskLevel = "Safe";
                riskClass = "bg-emerald-500/10 text-[var(--color-safe)] border border-[var(--color-safe)]/30";
                descText = "Low risk. Dividends are fully franked and director salary is processed under standard Single Touch Payroll (STP).";
              } else {
                riskLevel = "Div 7A Alert";
                riskClass = "bg-amber-500/10 text-amber-400 border border-amber-500/30";
                descText = "Ensure all payments to directors are formalised as salary or franked dividends to prevent Division 7A deemed dividend triggers.";
              }
            }

            riskStatus.innerText = riskLevel;
            riskStatus.className = `inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold uppercase transition-all duration-300 ${riskClass}`;
            riskDesc.innerText = descText;
          }
        } else {
          optimizerCard.classList.add("hidden");
        }
      }

      const banner    = document.getElementById("tax-recommendation-banner");
      const recTitle  = document.getElementById("tax-rec-title");
      const recIcon   = document.getElementById("tax-rec-icon");
      const msgEl     = document.getElementById("tax-breakeven-msg");
      const isWorthIt = netProfit > cfg.breakEvenRevenue && savings > cfg.corpOverheadCost;

      if (netProfit === 0) {
        banner.className = "p-6 rounded-lg border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-[#141C32] border-[#1E294B]";
        recTitle.innerText = "Enter revenue to begin";
        recIcon.className  = "p-3 rounded-lg bg-[#1E294B] text-slate-400 hidden sm:flex items-center justify-center flex-shrink-0";
        recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`;
        msgEl.innerText   = "";
      } else if (isWorthIt) {
        banner.className = "p-6 rounded-lg border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-[var(--color-safe)]/10 border-[var(--color-safe)]/30";
        recTitle.innerText = `Incorporate — Switch to ${cfg.corpLabel}`;
        recIcon.className  = "p-3 rounded-lg bg-[var(--color-safe)]/20 text-[var(--color-safe)] hidden sm:flex items-center justify-center flex-shrink-0";
        recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`;
        msgEl.innerText   = `Incorporation overhead ~${fmt(cfg.corpOverheadCost)}/yr. You save ${fmt(savings)}/yr — net advantage ${fmt(savings - cfg.corpOverheadCost)}.`;
      } else {
        const stillNeeded = Math.max(0, cfg.breakEvenRevenue - netProfit);
        banner.className = "p-6 rounded-lg border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 transition-all duration-300 bg-amber-500/10 border-amber-500/30";
        recTitle.innerText = `Stay ${cfg.soleLabel} For Now`;
        recIcon.className  = "p-3 rounded-lg bg-amber-500/20 text-amber-400 hidden sm:flex items-center justify-center flex-shrink-0";
        recIcon.innerHTML  = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`;
        msgEl.innerText   = stillNeeded > 0
          ? `Grow net profit by another ${fmt(stillNeeded)} to hit the break-even milestone for corporate overhead.`
          : `Savings (${fmt(savings)}) don't yet cover annual corporate overheads (~${fmt(cfg.corpOverheadCost)}). Keep scaling.`;
      }

      const maxBurden = Math.max(soleTotalTax, corpTotalTax, 1);
      document.getElementById("chart-sole-tax-perc").innerText = soleEffRate.toFixed(1) + "%";
      document.getElementById("chart-sole-tax-bar").style.width = Math.round((soleTotalTax / maxBurden) * 100) + "%";
      document.getElementById("chart-scorp-tax-perc").innerText = corpEffRate.toFixed(1) + "%";
      document.getElementById("chart-scorp-tax-bar").style.width = Math.round((corpTotalTax / maxBurden) * 100) + "%";
    }

    function updateTaxCountryUI(country) {
      const cfg = TAX_CONFIGS[country] || TAX_CONFIGS.US;
      document.querySelectorAll(".tax-currency-symbol").forEach(el => el.innerText = cfg.symbol);
      document.getElementById("tax-w2-label").innerText = cfg.w2Label;
      document.getElementById("tax-sole-label").innerText = cfg.soleLabel;
      document.getElementById("tax-corp-label").innerText = cfg.corpLabel;
      document.getElementById("tax-sole-se-label").innerText = cfg.soleSELabel;
      document.getElementById("tax-scorp-se-label").innerText = cfg.corpTaxLabel;
      document.getElementById("tax-scorp-income-label").innerText = cfg.corpIncomeLabel;
      document.getElementById("chart-sole-bar-label").innerText = cfg.soleLabel + " Burden";
      document.getElementById("chart-corp-bar-label").innerText = cfg.corpLabel + " Burden";
      document.getElementById("tax-country-tip-text").innerText = cfg.tip;
    }

    function syncStateToInputs() {
      document.getElementById("tax-country").value = state.tax.country || "US";
      document.getElementById("tax-revenue").value = state.tax.revenue || "";
      document.getElementById("tax-expenses").value = state.tax.expenses || "";
      document.getElementById("tax-w2").value = state.tax.w2 || "";
      const optSlider = document.getElementById("opt-salary-pct");
      if (optSlider) {
        optSlider.value = state.tax.salaryPct || 40;
      }
      updateTaxCountryUI(state.tax.country || "US");
    }

    function runCalculations() {
      calculateTax();
    }

    function bindListeners() {
      document.getElementById("tax-country").addEventListener("change", (e) => {
        state.tax.country = e.target.value;
        state.tax.isSliderDirty = false;
        updateTaxCountryUI(state.tax.country);
        saveState();
        calculateTax();
      });

      const taxInputs = [
        { id: "tax-revenue",  prop: "revenue"  },
        { id: "tax-expenses", prop: "expenses" },
        { id: "tax-w2",       prop: "w2"       }
      ];
      taxInputs.forEach(({ id, prop }) => {
        const el = document.getElementById(id);
        if (el) {
          el.addEventListener("input", (e) => {
            state.tax[prop] = parseFloat(e.target.value) || 0;
            state.tax.isSliderDirty = false;
            saveState();
            calculateTax();
          });
        }
      });

      const optSlider = document.getElementById("opt-salary-pct");
      if (optSlider) {
        optSlider.addEventListener("input", (e) => {
          state.tax.salaryPct = parseFloat(e.target.value) || 40;
          state.tax.isSliderDirty = true;
          saveState();
          calculateTax();
        });
      }
    }

    loadState();

    window.addEventListener("DOMContentLoaded", () => {
      syncStateToInputs();
      bindListeners();
      runCalculations();
    });

    window.addEventListener("financial-hub-reset", () => {
      state.tax = JSON.parse(JSON.stringify(DEFAULT_STATE.tax));
      updateTaxCountryUI("US");
      const slider = document.getElementById("opt-salary-pct");
      if (slider) {
        slider.value = 40;
      }
      syncStateToInputs();
      runCalculations();
    });
  })();
</script>
