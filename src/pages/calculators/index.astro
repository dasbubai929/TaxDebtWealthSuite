---
import Layout from "../../layouts/Layout.astro";

const title = "Financial Calculators Hub | Tax, Debt, Retirement & Wealth Tools";
const description = "Interactive calculators for smarter financial planning. Explore tax, retirement, debt, and wealth tools with linked guides and blogs.";
---

<Layout title={title} description={description}>
  <main class="flex-grow pt-24 pb-20">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight font-sans mb-6">
        Financial Calculators <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00F5D4] to-blue-400">Hub</span>
      </h1>
      <p class="text-base sm:text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Explore interactive calculators for tax, debt, wealth, and retirement planning.
      </p>
    </section>

    <!-- Filters Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-10">
      <div class="flex flex-wrap items-center justify-center gap-3">
        <button class="filter-btn active px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-[#00F5D4]/10 text-[#00F5D4] border border-[#00F5D4]/30" data-filter="all">All</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="tax">Tax</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="debt">Debt</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="wealth">Wealth</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="retirement">Retirement</button>
      </div>
    </section>

    <!-- Calculators Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="calculators-grid">

        <!-- Tax: S-Corp Tax -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="tax">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">Side-Hustle S-Corp Tax</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Compare sole proprietorship taxes against corporate structures in the US, UK, Canada, and Australia. Run reasonable salary splits and overhead break-even audits.
            </p>
          </div>
          <div class="mt-8">
            <a href="/s-corp-tax-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try the S-Corp Tax Predictor
            </a>
          </div>
        </div>

        <!-- Tax: QBI Deduction -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="tax">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">QBI Deduction (Sec 199A)</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Calculate Section 199A pass-through tax savings. See how 20% deductions, W-2 wage/UBIA limits, and SSTB phase-outs affect your net savings.
            </p>
          </div>
          <div class="mt-8">
            <a href="/qbi-deduction-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try QBI Deduction Calculator
            </a>
          </div>
        </div>

        <!-- Tax: SALT Cap Deduction -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="tax">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">SALT Cap Deduction</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              See your exact allowed state and local tax deduction under the new $40,400 SALT cap, including the high-income phase-down.
            </p>
          </div>
          <div class="mt-8">
            <a href="/salt-cap-deduction-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try the SALT Cap Calculator
            </a>
          </div>
        </div>

        <!-- Debt: Debt Payoff Planner -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="debt">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">Debt Payoff Planner</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Simulate Debt Snowball vs. Debt Avalanche strategies. Compare total interest costs, payoff times, and map monthly roll-over schedules to accelerate freedom.
            </p>
          </div>
          <div class="mt-8">
            <a href="/debt-payoff-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try the Debt Payoff Planner
            </a>
          </div>
        </div>

        <!-- Tax: Capital Gains Tax -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="tax">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-lime-500/10 border border-lime-500/20 flex items-center justify-center text-lime-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">Capital Gains Tax Calculator</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Estimate your short-term or long-term capital gains tax liability for the US, UK, Canada, or Australia.
            </p>
          </div>
          <div class="mt-8">
            <a href="/capital-gains-tax-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try the CGT Calculator
            </a>
          </div>
        </div>

        <!-- Wealth: Buy, Borrow, Die -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="wealth">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">Buy, Borrow, Die</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Model Securities-Based Lines of Credit (SBLOC) vs. capital gains liquidation. Analyze margin call liquidation buffers and capital gains tax drag avoidance.
            </p>
          </div>
          <div class="mt-8">
            <a href="/buy-borrow-die-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try the Buy, Borrow, Die Calculator
            </a>
          </div>
        </div>

        <!-- Retirement: Roth Conversion -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="retirement">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">Roth Conversion</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Model the tax cost of converting a traditional IRA or 401(k) to a Roth IRA, and find your personal breakeven future tax rate.
            </p>
          </div>
          <div class="mt-8">
            <a href="/roth-conversion-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try the Roth Conversion Calculator
            </a>
          </div>
        </div>

        <!-- Retirement: RMD Calculator -->
        <div class="calculator-card glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card" data-category="retirement">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white tracking-wide font-sans">Required Minimum Distributions</h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Calculate your mandatory retirement withdrawals based on age and country rules (US, UK, CA, AU).
            </p>
          </div>
          <div class="mt-8">
            <a href="/rmd-calculator/" class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5">
              Try the RMD Calculator
            </a>
          </div>
        </div>

      </div>
      
      <!-- Empty State for Filters -->
      <div id="no-results" class="hidden text-center py-12">
        <p class="text-slate-500">No calculators found in this category.</p>
      </div>
    </section>

    <!-- Related Blogs CTA -->
    <section class="border-t border-slate-800/60 bg-gradient-to-b from-slate-950 to-slate-950/95 py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-white mb-4">Want to dive deeper?</h2>
        <p class="text-slate-400 mb-8 max-w-2xl mx-auto">
          Our financial calculators are paired with comprehensive guides and case studies. Explore our blog to master the strategies behind the math.
        </p>
        <a href="/blog/" class="inline-flex items-center justify-center px-8 py-3.5 border border-transparent text-sm font-bold rounded-xl text-slate-950 bg-[#00F5D4] hover:bg-white transition-colors duration-300 shadow-lg shadow-[#00F5D4]/20 uppercase tracking-widest">
          Read the Blog
        </a>
      </div>
    </section>
  </main>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.calculator-card');
      const noResults = document.getElementById('no-results');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // Update active styles
          filterBtns.forEach(b => {
            b.classList.remove('active', 'bg-[#00F5D4]/10', 'text-[#00F5D4]', 'border-[#00F5D4]/30');
            b.classList.add('bg-slate-900', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:bg-slate-800');
          });
          btn.classList.add('active', 'bg-[#00F5D4]/10', 'text-[#00F5D4]', 'border-[#00F5D4]/30');
          btn.classList.remove('bg-slate-900', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:bg-slate-800');

          // Filter logic
          const filter = btn.getAttribute('data-filter');
          let visibleCount = 0;

          cards.forEach(card => {
            if (filter === 'all' || card.getAttribute('data-category') === filter) {
              card.style.display = 'flex';
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          });

          if (visibleCount === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        });
      });
    });
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Which calculators are available in the Financial Hub?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our hub includes tools for tax planning (S-Corp Tax Predictor, QBI Deduction, SALT Cap), retirement (Roth Conversion, Required Minimum Distributions), wealth management (Buy, Borrow, Die strategy), and debt (Debt Payoff Planner)."
          }
        },
        {
          "@type": "Question",
          "name": "Are these calculators country-specific?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Many of our calculators, such as the Side-Hustle S-Corp Tax Predictor, Buy, Borrow, Die calculator, and Required Minimum Distributions tool, support multiple jurisdictions including the US, UK, Canada, and Australia."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use the calculators?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Simply click on any calculator card to open the tool. You can adjust your financial parameters dynamically, and the interactive visualizations will update in real-time. Our auto-save feature ensures your inputs are preserved."
          }
        }
      ]
    }
  </script>
</Layout>
