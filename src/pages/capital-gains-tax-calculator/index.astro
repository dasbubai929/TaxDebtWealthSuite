---
import Layout from "../../layouts/Layout.astro";
import CapitalGainsTaxCalculator from "../../components/CapitalGainsTaxCalculator.astro";
---

<Layout
  title="Capital Gains Tax Calculator (US) | Estimate Your Tax Liability"
  description="Free capital gains tax calculator for the US. Estimate short-term and long-term tax rates, including the Net Investment Income Tax (NIIT)."
  ogImage="https://taxdebtwealthsuite.com/images/og-capital-gains-tax.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Capital Gains Tax Calculator (US)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "description": "Estimate short-term and long-term capital gains tax liability under IRS rules, including the 3.8% NIIT."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How is long-term capital gains tax calculated in the US?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Long-term capital gains apply to assets held longer than one year. The profit is taxed at 0%, 15%, or 20% based on your filing status and taxable income for the year."
            }
          },
          {
            "@type": "Question",
            "name": "What is the Net Investment Income Tax (NIIT)?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The NIIT is a 3.8% surcharge on investment income for individuals whose modified adjusted gross income exceeds certain thresholds ($200,000 for Single, $250,000 for Married Filing Jointly)."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Capital Gains Tax Calculator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Model your potential tax liability on the sale of assets like stocks, real estate, or crypto under IRS rules including short-term, long-term rates, and the 3.8% NIIT.
      </p>
    </div>

    <CapitalGainsTaxCalculator defaultCountry="US" />
  </main>
</Layout>
