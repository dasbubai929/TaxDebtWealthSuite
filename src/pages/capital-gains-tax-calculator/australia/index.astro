---
import Layout from "../../../layouts/Layout.astro";
import CapitalGainsTaxCalculator from "../../../components/CapitalGainsTaxCalculator.astro";
---

<Layout
  title="Capital Gains Tax Calculator (Australia) | ATO CGT Discount"
  description="Estimate your Australian capital gains tax liability. Automatically applies the 50% CGT discount for assets held over 12 months."
  ogImage="https://taxdebtwealthsuite.com/images/og-capital-gains-tax.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Capital Gains Tax Calculator (Australia)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "AUD" },
        "description": "Estimate Australian capital gains tax liability with automatic 50% CGT discount for assets held over 12 months."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the 50% CGT discount in Australia?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Australian individuals who hold a CGT asset for more than 12 months can apply a 50% discount, meaning only half of the net capital gain is included in their assessable income."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Capital Gains Tax Calculator (Australia)
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Estimate your ATO capital gains tax liability with automatic 50% CGT discount calculations for assets held over 12 months.
      </p>
    </div>

    <CapitalGainsTaxCalculator defaultCountry="AU" />
  </main>
</Layout>
