---
import Layout from "../../layouts/Layout.astro";
import BuyBorrowDieCalculator from "../../components/BuyBorrowDieCalculator.astro";
---

<Layout 
  title="Buy a House with Stock Portfolio (Without Selling) Calculator"
  description="Model how to use a margin loan or SBLOC to fund a real estate down payment without triggering capital gains tax on your stock portfolio."
>
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Real Estate Down Payment via Stock Portfolio Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": {
          "@id": "https://taxdebtwealthsuite.com/#organization"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": "Model how to use a margin loan or SBLOC to fund a real estate down payment without triggering capital gains tax on your stock portfolio."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Can I use a margin loan for a mortgage down payment?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Most traditional mortgage lenders allow you to source a down payment from an SBLOC or margin loan, provided it is secured by the asset and factored into your Debt-to-Income (DTI) ratio. Always consult your loan officer."
            }
          },
          {
            "@type": "Question",
            "name": "What happens if the stock market crashes after I buy the house?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "If your portfolio value falls below the maintenance margin, your broker will issue a margin call. If you cannot deposit cash to cover the call, they will liquidate your stock to pay down the loan."
            }
          }
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://taxdebtwealthsuite.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Real Estate Down Payment via Stock Portfolio Calculator",
            "item": "https://taxdebtwealthsuite.com/stock-portfolio-down-payment-calculator/"
          }
        ]
      }
    ]
  }
  </script>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    
    <!-- Title Section -->
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Real Estate Down Payment via Stock Portfolio Calculator
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-xs font-medium text-slate-500 bg-slate-900/50 inline-flex px-3 py-1.5 rounded-lg border border-slate-800">
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#00F5D4]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>Reviewed by <a href="/editorial-policy/" class="text-slate-400 hover:text-[#00F5D4] transition-colors underline decoration-slate-700 underline-offset-2">Editorial Staff</a></span>
        </div>
        <span class="hidden sm:inline text-slate-700">&bull;</span>
        <time datetime="2026-07-07" class="text-slate-400">Updated: July 2026</time>
      </div>
      <p class="text-sm text-slate-400 mt-2 max-w-2xl leading-relaxed">
        Model how to use a margin loan or SBLOC to fund a real estate down payment without triggering capital gains tax on your stock portfolio.
      </p>
    </div>

    <!-- Calculator Component Island -->
    <BuyBorrowDieCalculator />

    <!-- Explainer Content -->
    <div class="border-t border-slate-800/60 mt-12 bg-gradient-to-b from-slate-950 to-slate-950/95">
      <div class="max-w-4xl mx-auto py-16">
        <section>
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Financial Tool</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight leading-snug">
              Leverage Equities for Real Estate
            </h2>
          </div>

          <div class="space-y-8 text-sm text-slate-400 leading-relaxed">
            <article>
              <h3 class="text-xl font-bold text-slate-100 mb-3">Introduction</h3>
              <p>Want to buy a house but all your wealth is tied up in the stock market? Liquidating your portfolio for a down payment triggers massive taxes and stops your compound interest in its tracks. Use this tool to model pledging your stock as collateral to fund your down payment, creating a powerful real-estate-to-equities wealth bridge.</p>
            </article>

            <article>
              <h3 class="text-xl font-bold text-slate-100 mb-3">Key Benefits</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Fund your down payment entirely tax-free.</li>
                <li>Own both appreciating real estate and an appreciating stock portfolio simultaneously.</li>
                <li>Avoid the timing risk of selling stocks during a market dip just to close on a house.</li>
              </ul>
            </article>
          </div>

          <!-- FAQ Accordion -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-amber-500/10 text-amber-400 border border-amber-500/20 mb-4">FAQ</span>
            <h3 class="text-2xl font-bold text-white mb-6">Frequently Asked Questions</h3>
            
            <div class="space-y-4">
              
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">Can I use a margin loan for a mortgage down payment?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  Most traditional mortgage lenders allow you to source a down payment from an SBLOC or margin loan, provided it is secured by the asset and factored into your Debt-to-Income (DTI) ratio. Always consult your loan officer.
                </div>
              </div>
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">What happens if the stock market crashes after I buy the house?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  If your portfolio value falls below the maintenance margin, your broker will issue a margin call. If you cannot deposit cash to cover the call, they will liquidate your stock to pay down the loan.
                </div>
              </div>
            </div>
          </div>

          <!-- Internal Links -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <h3 class="text-xl font-bold text-white mb-4">Related Calculators & Resources</h3>
            <div class="flex flex-col space-y-2">
              <a href="/debt-avalanche-calculator/" class="text-[#00F5D4] hover:underline">Debt Avalanche Planner</a>
              <a href="/sbloc-calculator/" class="text-[#00F5D4] hover:underline">SBLOC Interest Calculator</a>
            </div>
          </div>

        
          <!-- Related Articles -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <h3 class="text-xl font-bold text-white mb-4">Related Articles</h3>
            <div class="flex flex-col space-y-2">
              <a href="/blog/sbloc-vs-heloc-accessing-cash/" class="text-slate-400 hover:text-white transition-colors">SBLOC vs HELOC: Accessing Cash</a>
            </div>
          </div>
        
          <!-- Methodology & Sources -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Methodology</span>
            <h3 class="text-2xl font-bold text-white mb-4">How This is Calculated</h3>
            <div class="text-sm text-slate-400 space-y-3 leading-relaxed">
              <p>This calculator models the opportunity cost of portfolio liquidation vs margin borrowing. When selling, it immediately reduces your total portfolio size by your marginal capital gains rate, preventing those funds from compounding.</p>
              <p>When borrowing (SBLOC / Margin), the portfolio remains fully invested, but accrues monthly compounding margin interest. The "Margin Call Liquidation Price" is calculated using the formula: <code>Loan Amount / (1 - Maintenance Margin Requirement)</code>. A standard Reg T maintenance margin is assumed unless modified in advanced settings.</p>
              <p><strong>Reference:</strong> <a href="https://www.finra.org/rules-guidance/rulebooks/finra-rules/4210" target="_blank" rel="noopener noreferrer" class="text-indigo-400 hover:underline">FINRA Rule 4210 (Margin Requirements)</a></p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
