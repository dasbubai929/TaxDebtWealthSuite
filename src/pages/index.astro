---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = allPosts.slice(0, 6);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

const toolLabels: Record<string, string> = {
  "buy-borrow-die-calculator": "Buy, Borrow, Die",
  "s-corp-tax-calculator": "S-Corp Tax",
  "qbi-deduction-calculator": "QBI Deduction",
  "debt-payoff-calculator": "Debt Payoff",
  "salt-cap-deduction-calculator": "SALT Cap Deduction",
  "roth-conversion-calculator": "Roth Conversion",
  "rmd-calculator": "RMD Calculator",
  "capital-gains-tax-calculator": "Capital Gains Tax",
  "tax-loss-harvesting-calculator": "Tax Loss Harvesting",
  "social-security-pension-estimator": "Social Security Estimator",
  "superannuation-rrsp-withdrawal-calculator": "Super & RRSP Calculator",
  "mortgage-recast-calculator": "Mortgage Recast Calculator",
};

const searchablePosts = allPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  slug: post.slug,
}));

const searchableTools = [
  {
    name: "Roth Conversion Calculator",
    variants: [
      { label: "United States (Default)", url: "/roth-conversion-calculator/" },
    ],
  },
  {
    name: "SALT Cap Deduction Calculator",
    variants: [
      { label: "United States (Default)", url: "/salt-cap-deduction-calculator/" },
    ],
  },
  {
    name: "QBI Deduction Calculator (Section 199A)",
    variants: [
      { label: "United States (Default)", url: "/qbi-deduction-calculator/" },
    ],
  },
  {
    name: "Buy, Borrow, Die Calculator",
    variants: [
      { label: "United States (Default)", url: "/buy-borrow-die-calculator/" },
      { label: "United Kingdom (Lombard Loan)", url: "/buy-borrow-die-calculator/uk/" },
      { label: "Canada (Margin Loan)", url: "/buy-borrow-die-calculator/canada/" },
      { label: "Australia (Margin Lending)", url: "/buy-borrow-die-calculator/australia/" },
    ],
  },
  {
    name: "S-Corp Tax Calculator",
    variants: [
      { label: "United States (Default)", url: "/s-corp-tax-calculator/" },
      { label: "United Kingdom (Ltd Company)", url: "/s-corp-tax-calculator/uk/" },
      { label: "Canada (CCPC)", url: "/s-corp-tax-calculator/canada/" },
      { label: "Australia (Pty Ltd)", url: "/s-corp-tax-calculator/australia/" },
    ],
  },
  {
    name: "Debt Payoff Calculator",
    variants: [
      { label: "Global / Universal", url: "/debt-payoff-calculator/" },
    ],
  },
  {
    name: "Required Minimum Distributions (RMD) Calculator",
    variants: [
      { label: "United States (Default)", url: "/rmd-calculator/" },
      { label: "United Kingdom", url: "/rmd-calculator/uk/" },
      { label: "Canada", url: "/rmd-calculator/canada/" },
      { label: "Australia", url: "/rmd-calculator/australia/" },
    ],
  },
  {
    name: "Capital Gains Tax Calculator",
    variants: [
      { label: "United States (Default)", url: "/capital-gains-tax-calculator/" },
      { label: "United Kingdom", url: "/capital-gains-tax-calculator/uk/" },
      { label: "Canada", url: "/capital-gains-tax-calculator/canada/" },
      { label: "Australia", url: "/capital-gains-tax-calculator/australia/" },
    ],
  },
  {
    name: "Tax Loss Harvesting Calculator",
    variants: [
      { label: "United States (Default)", url: "/tax-loss-harvesting-calculator/" },
      { label: "United Kingdom", url: "/tax-loss-harvesting-calculator/uk/" },
      { label: "Canada", url: "/tax-loss-harvesting-calculator/canada/" },
      { label: "Australia", url: "/tax-loss-harvesting-calculator/australia/" },
    ],
  },
];

const searchDataJson = JSON.stringify({
  tools: searchableTools,
  posts: searchablePosts,
});
---

<Layout
  title="Free Tax & Debt Calculators — S-Corp, Buy Borrow Die, Debt Payoff | TaxDebtWealthSuite"
  description="Three free financial calculators: S-Corp vs sole trader tax optimizer, Buy Borrow Die / SBLOC strategy modeler, and debt snowball vs avalanche planner. US, UK, Canada, Australia."
  ogImage="https://taxdebtwealthsuite.com/images/og-home.png"
>
  <!-- Hero / Intro Section -->
  <section class="py-12 sm:py-20 text-center max-w-4xl mx-auto px-4">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-[#00F5D4]/10 text-[#00F5D4] border border-[#00F5D4]/20 mb-6">
      Strategic Financial Modeling
    </div>
    <h1 class="text-4xl sm:text-6xl font-black text-white tracking-tight leading-none font-sans">
      Free Tax, Debt &amp; Wealth Strategy Calculators
    </h1>
    <p class="mt-6 text-sm sm:text-base text-slate-400 leading-relaxed max-w-2xl mx-auto">
      Free, professional-grade interactive calculators designed to model advanced tax strategies, run multi-method debt payoffs, and optimize leverage risk.
    </p>
    <p class="mt-4 text-xs sm:text-sm text-slate-500 leading-relaxed max-w-2xl mx-auto">
      Precision-grade Tax, Debt and Wealth engines tailored for the US, UK, Canada and Australia
    </p>

    <!-- Predictive Search Bar -->
    <div id="search-container" class="relative mt-8 max-w-xl mx-auto">
      <form id="search-form" action="javascript:void(0);" onsubmit="return false;">
        <div class="search-bar-wrapper">
          <div class="search-bar-glow"></div>
          <div class="search-bar-inner">
            <svg xmlns="http://www.w3.org/2000/svg" class="search-bar-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              id="predictive-search-input"
              type="text"
              placeholder="Search calculators, tools, articles..."
              class="search-bar-input"
              autocomplete="off"
              aria-label="Search calculators and articles"
            />
            <kbd class="search-bar-kbd">ESC</kbd>
          </div>
        </div>
      </form>
      <div id="search-results-dropdown" class="hidden absolute left-0 right-0 top-full mt-2 z-[300]"></div>
    </div>
  </section>

  <!-- Recent Articles — Swipeable Cards -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg sm:text-xl font-bold text-white tracking-tight font-sans">Recent Articles</h2>
      <div class="flex items-center gap-3">
        <div class="hidden sm:flex items-center gap-1.5">
          <button id="carousel-prev" class="carousel-nav-btn" aria-label="Previous articles">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="carousel-next" class="carousel-nav-btn" aria-label="Next articles">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
        <a href="/blog/" class="text-xs font-semibold text-[#00F5D4] hover:text-white transition-colors flex items-center gap-1">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
    <div id="carousel-track" class="carousel-track">
      {latestPosts.map((post) => {
        return (
          <a
            href={`/blog/${post.slug}/`}
            class="carousel-card"
            draggable="false"
          >
            <div class="space-y-3">
              <div class="flex items-center justify-between gap-2">
                <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-[#00F5D4]/10 text-[#00F5D4] border border-[#00F5D4]/20">
                  {toolLabels[post.data.relatedTool] || "General"}
                </span>
                <span class="text-[10px] text-slate-500 font-mono whitespace-nowrap">{formatDate(post.data.pubDate)}</span>
              </div>
              <h3 class="text-sm font-bold text-white leading-snug font-sans">{post.data.title}</h3>
              <p class="text-xs text-slate-400 leading-relaxed line-clamp-3">{post.data.description}</p>
            </div>
            <div class="mt-4">
              <span class="inline-flex items-center gap-1 text-xs font-semibold text-[#00F5D4] group-hover:text-white transition-colors">
                Read Article
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Large Cards / CTAs Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Card 1: S-Corp Tax -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">Side-Hustle S-Corp Tax</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Compare sole proprietorship taxes against corporate structures in the US, UK, Canada, and Australia. Run reasonable salary splits and overhead break-even audits.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/s-corp-tax-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try the S-Corp Tax Predictor
          </a>
        </div>
      </div>

      <!-- Card 2: Debt Payoff -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">Debt Payoff Planner</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Simulate Debt Snowball vs. Debt Avalanche strategies. Compare total interest costs, payoff times, and map monthly roll-over schedules to accelerate freedom.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/debt-payoff-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try the Debt Payoff Planner
          </a>
        </div>
      </div>

      <!-- Card 3: Buy, Borrow, Die -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">Buy, Borrow, Die</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Model Securities-Based Lines of Credit (SBLOC) vs. capital gains liquidation. Analyze margin call liquidation buffers and capital gains tax drag avoidance.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/buy-borrow-die-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try the Buy, Borrow, Die Calculator
          </a>
        </div>
      </div>

      <!-- Card 4: QBI Deduction -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">QBI Deduction (Sec 199A)</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Calculate Section 199A pass-through tax savings. See how 20% deductions, W-2 wage/UBIA limits, and SSTB phase-outs affect your net savings.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/qbi-deduction-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try QBI Deduction Calculator
          </a>
        </div>
      </div>

      <!-- Card 5: SALT Cap Deduction -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">SALT Cap Deduction</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            See your exact allowed state and local tax deduction under the new $40,400 SALT cap, including the high-income phase-down.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/salt-cap-deduction-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try the SALT Cap Calculator
          </a>
        </div>
      </div>

      <!-- Card 6: Roth Conversion -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">Roth Conversion</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Model the tax cost of converting a traditional IRA or 401(k) to a Roth IRA, and find your personal breakeven future tax rate.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/roth-conversion-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try the Roth Conversion Calculator
          </a>
        </div>
      </div>

      <!-- Card 7: RMD Calculator -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">Required Minimum Distributions</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Calculate your mandatory retirement withdrawals based on age and country rules (US, UK, CA, AU).
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/rmd-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try the RMD Calculator
          </a>
        </div>
      </div>

      <!-- Card 8: Capital Gains Tax Calculator -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-lime-500/10 border border-lime-500/20 flex items-center justify-center text-lime-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">Capital Gains Tax Calculator</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Estimate your short-term or long-term capital gains tax liability for the US, UK, Canada, or Australia.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/capital-gains-tax-calculator/"
            class="w-full flex items-center justify-center px-4 py-3 bg-[#00F5D4]/10 hover:bg-[#00F5D4] border border-[#00F5D4]/30 hover:border-transparent text-brand-300 hover:text-slate-950 font-bold text-xs rounded-xl tracking-wider uppercase transition-all duration-300 shadow-md shadow-[#00F5D4]/5"
          >
            Try the CGT Calculator
          </a>
        </div>
      </div>

      <!-- Card 9: Tax Loss Harvesting Calculator -->
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 flex flex-col justify-between hover:border-[#00F5D4]/40 transition-all duration-300 relative group glow-card">
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-xl bg-teal-500/10 border border-teal-500/20 flex items-center justify-center text-teal-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white tracking-wide font-sans">Tax Loss Harvesting Calculator</h3>
