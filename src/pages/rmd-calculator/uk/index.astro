---
import Layout from "../../../layouts/Layout.astro";
import RmdCalculator from "../../../components/RmdCalculator.astro";
---

<Layout
  title="UK Pension Drawdown Calculator"
  description="Estimate a sustainable statutory-style drawdown from your UK defined contribution pension."
  ogImage="https://taxdebtwealthsuite.com/images/og-rmd-calculator.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/rmd-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/rmd-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/rmd-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/rmd-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/rmd-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Pension Drawdown Calculator (UK)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GBP" },
        "description": "Estimate a sustainable statutory-style drawdown from your UK defined contribution pension."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Are there required minimum distributions in the UK?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Unlike the US, the UK does not mandate minimum pension withdrawals. You can draw down as much or as little as you like from age 57 onwards under flexi-access drawdown rules."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        UK Pension Drawdown Calculator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Estimate a sustainable statutory-style drawdown from your UK defined contribution pension, including the 25% tax-free lump sum.
      </p>
    </div>

    <RmdCalculator country="uk" />
  </main>
</Layout>
