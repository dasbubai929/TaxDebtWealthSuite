---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="Terms & Conditions — TaxDebtWealthSuite"
  description="Terms and conditions for utilizing the TaxDebtWealthSuite calculation suite, including disclaimer of warranties and intellectual property rights."
>
  <main class="flex-grow max-w-3xl w-full mx-auto px-4 sm:px-6 py-12 sm:py-16">
    
    <!-- Back Link for Mobile/SEO -->
    <div class="mb-8">
      <a href="/" class="inline-flex items-center text-xs font-semibold uppercase tracking-wider text-brand-400 hover:text-brand-300 transition-colors">
        &larr; Back to Home
      </a>
    </div>

    <!-- Article Base -->
    <article class="space-y-8">
      <header class="border-b border-slate-800 pb-6">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight font-sans">Terms & Conditions</h1>
        <p class="text-xs text-slate-500 mt-2">Last Updated: June 25, 2026</p>
      </header>

      <!-- Section 1 -->
      <section class="space-y-4">
        <h2 class="text-xl sm:text-2xl font-bold text-white tracking-wide">1. Agreement to Terms</h2>
        <p class="text-sm text-slate-300 leading-relaxed">
          By accessing or using TaxDebtWealthSuite (located at this domain), you agree to be bound by these Terms & Conditions. If you do not agree with any part of these terms, you are prohibited from using our calculators, sheets, or content.
