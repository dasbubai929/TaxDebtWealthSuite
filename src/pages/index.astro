<!-- Client-Side State and Calculator Calculations Script -->
<script is:inline>
  // Central Local Storage Keys
  const STORAGE_KEY = "taxdebtwealthsuite_state_v1";
  const AUTOSAVE_KEY = "taxdebtwealthsuite_autosave_pref";

  // Beautiful Default Values
  const DEFAULT_STATE = {
    activeTab: "bbd",
    autoSave: true,
    bbd: {
      portfolio: 0,
      basis: 0,
      taxRate: 0,
      borrowAmount: 0,
      interestRate: 0,
      currency: "USD"
    },
    tax: {
      country: "US",
      revenue: 0,
      expenses: 0,
      w2: 0
    },
    debt: {
      rows: [],
      extra: 0
    }
  };

  let state = JSON.parse(JSON.stringify(DEFAULT_STATE));

  // Helper: Format Money
  function formatCurrency(val) {
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 0
    }).format(val);
  }

  let autoSaveTimeout = null;

  // Load state from local storage or set defaults
  function loadState() {
    // Load autosave preference first
    const autoSaveRaw = localStorage.getItem(AUTOSAVE_KEY);
    const savedAutoSavePref = autoSaveRaw !== null ? autoSaveRaw === "true" : true;

    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      try {
        state = JSON.parse(raw);
        // Ensure subproperties are complete
        state.bbd = { ...DEFAULT_STATE.bbd, ...state.bbd };
        state.tax = { ...DEFAULT_STATE.tax, ...state.tax };
        // Debt: preserve rows array, merge scalar fields
        state.debt = {
          rows: Array.isArray(state.debt?.rows) ? state.debt.rows : [],
          extra: state.debt?.extra ?? 0
        };
        state.autoSave = savedAutoSavePref;
      } catch (e) {
        state = JSON.parse(JSON.stringify(DEFAULT_STATE));
        state.autoSave = savedAutoSavePref;
      }
    } else {
      state = JSON.parse(JSON.stringify(DEFAULT_STATE));
      state.autoSave = savedAutoSavePref;
    }
    saveState();
  }

  // Save current state to local storage
  function saveState(force = false) {
    if (state.autoSave || force) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      if (state.autoSave) {
        triggerAutosaveIndicator("saving");
        if (autoSaveTimeout) clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(() => {
          triggerAutosaveIndicator("saved");
        }, 800);
      }
    }
  }

  function triggerAutosaveIndicator(status) {
    const dot = document.getElementById("autosave-dot");
    const text = document.getElementById("autosave-text");
    const btn = document.getElementById("toggle-autosave");
    if (!dot || !text || !btn) return;

    if (!state.autoSave) {
      // Off State
      btn.className = "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-slate-800/40 text-slate-400 border-slate-700 hover:bg-slate-800/80 hover:border-slate-600 transition-all duration-200 cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900";
      dot.className = "w-1.5 h-1.5 mr-1.5 rounded-full bg-slate-500";
      text.innerText = "Auto-Save: Off";
    } else if (status === "saving") {
      // Actively saving (feedback)
      btn.className = "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-emerald-500/10 text-emerald-400 border-emerald-500/30 transition-all duration-200 cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900";
      dot.className = "w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-400 animate-pulse";
      text.innerText = "Saving...";
    } else {
      // Saved & Idle
      btn.className = "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-emerald-500/5 text-emerald-400/80 border-emerald-500/10 hover:bg-emerald-500/10 hover:border-emerald-500/20 transition-all duration-200 cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:ring-offset-slate-900";
      dot.className = "w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-500";
      text.innerText = "Saved (Local)";
    }
  }

  // Initialize Input Fields DOM based on state
  function syncStateToInputs() {
    // Tab active switcher sync
    setActiveTabDOM(state.activeTab || "bbd");
    triggerAutosaveIndicator();

    // Tab 1 Inputs
    document.getElementById("bbd-currency").value = state.bbd.currency || "USD";
    document.getElementById("bbd-portfolio").value = state.bbd.portfolio;
    document.getElementById("bbd-basis").value = state.bbd.basis;
    document.getElementById("bbd-tax-rate").value = state.bbd.taxRate;
    document.getElementById("bbd-borrow-amount").value = state.bbd.borrowAmount;
    document.getElementById("bbd-interest-rate").value = state.bbd.interestRate;
    updateCurrencySymbols(state.bbd.currency || "USD");

    // Tab 2 Inputs
    document.getElementById("tax-country").value = state.tax.country || "US";
    document.getElementById("tax-revenue").value = state.tax.revenue;
    document.getElementById("tax-expenses").value = state.tax.expenses;
    document.getElementById("tax-w2").value = state.tax.w2;
    updateTaxCountryUI(state.tax.country || "US");

    // Tab 3 Inputs — dynamic rows
    renderDebtRows();
    document.getElementById("debt-extra").value = state.debt.extra || "";
  }

  // ==========================================
  // CALCULATOR LOGICS
  // ==========================================

  // Helper: update currency labels across fields
  function updateCurrencySymbols(currency) {
    const symbols = {
      USD: "$",
      GBP: "£",
      CAD: "C$",
      AUD: "A$"
    };
    const symbol = symbols[currency] || "$";
    document.querySelectorAll(".bbd-currency-symbol").forEach(el => {
      el.innerText = symbol;
    });
  }

  // Tab 1: Buy, Borrow, Die Portfolio Wealth Optimizer
  function calculateBBD() {
    const currency = state.bbd.currency || "USD";
    const P = parseFloat(state.bbd.portfolio) || 0;
    const B = parseFloat(state.bbd.basis) || 0;
    const T = (parseFloat(state.bbd.taxRate) || 0) / 100;
    const C = parseFloat(state.bbd.borrowAmount) || 0;
    const Ib = (parseFloat(state.bbd.interestRate) || 0) / 100;

    // 1. Sell Route Calculations
    let taxDrag = 0;
    let netRemainingPortfolio = P;

    if (P > 0 && C > 0) {
      // Appreciation Ratio (Gain Ratio)
      const gainRatio = Math.max(0, (P - B) / P);
      // Gross assets to sell to net C: C = G * (1 - gainRatio * T)
      // G = C / (1 - gainRatio * T)
      const denominator = Math.max(0.01, 1 - gainRatio * T);
      const grossSale = C / denominator;
      taxDrag = grossSale - C;
      netRemainingPortfolio = Math.max(0, P - grossSale);
    }

    // 2. Borrow (SBLOC) Route Calculations
    const annualInterest = C * Ib;
    const ltv = P > 0 ? (C / P) * 100 : 0;

    // 3. Net Savings Advantage
    const netSaved = taxDrag - annualInterest;

    // Helper: format currency dynamically
    function formatWithCurrency(val) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: currency,
        maximumFractionDigits: 0
      }).format(val);
    }

    document.getElementById("bbd-sell-tax").innerText = formatWithCurrency(taxDrag);
    document.getElementById("bbd-sell-net").innerText = formatWithCurrency(netRemainingPortfolio);
    document.getElementById("bbd-borrow-interest").innerText = formatWithCurrency(annualInterest);
    document.getElementById("bbd-borrow-ltv").innerText = ltv.toFixed(1) + "%";

    const savedEl = document.getElementById("bbd-net-saved");
    const savedBanner = document.getElementById("bbd-savings-banner");
    const savedIcon = document.getElementById("bbd-savings-icon");

    if (C > 0 && P > 0) {
      savedEl.innerText = formatWithCurrency(netSaved);
      if (netSaved > 0) {
        savedEl.className = "text-xl sm:text-2xl font-black text-emerald-400 Outfit font-extrabold";
        savedBanner.className = "p-5 rounded-2xl border transition-all duration-300 flex items-center justify-between bg-emerald-500/10 border-emerald-500/30";
        savedIcon.className = "p-2.5 rounded-xl bg-emerald-500/20 text-emerald-400";
      } else {
        savedEl.className = "text-xl sm:text-2xl font-black text-rose-400 Outfit font-extrabold";
        savedBanner.className = "p-5 rounded-2xl border transition-all duration-300 flex items-center justify-between bg-rose-500/10 border-rose-500/30";
        savedIcon.className = "p-2.5 rounded-xl bg-rose-500/20 text-rose-400";
      }
    } else {
      savedEl.innerText = formatWithCurrency(0);
      savedEl.className = "text-xl sm:text-2xl font-black text-slate-300 Outfit font-extrabold";
      savedBanner.className = "p-5 rounded-2xl border transition-all duration-300 flex items-center justify-between bg-slate-900 border-slate-800";
      savedIcon.className = "p-2.5 rounded-xl bg-slate-800 text-slate-400";
    }

    // 4. Margin Call & Price Drop Risk Meter
    const riskStatusEl = document.getElementById("bbd-risk-status");
    const riskAlertEl = document.getElementById("bbd-risk-alert");
    const ltvLabelEl = document.getElementById("bbd-risk-ltv-label");
    const pointerEl = document.getElementById("bbd-risk-pointer");
    const priceDropEl = document.getElementById("bbd-price-drop");

    ltvLabelEl.innerText = ltv.toFixed(1) + "%";
    const pointerLeft = Math.min(100, ltv);
    pointerEl.style.left = pointerLeft + "%";

    if (C <= 0 || P <= 0) {
      riskStatusEl.innerText = "No Loan";
      riskStatusEl.className = "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-800 text-slate-400 border border-slate-700 uppercase";
      riskAlertEl.innerText = "Enter portfolio and loan parameters to analyze liquidation risk and margin call buffers.";
      riskAlertEl.className = "p-4 rounded-xl text-xs leading-relaxed transition-all duration-300 bg-slate-900/50 border border-slate-800 text-slate-300";
      priceDropEl.innerText = "N/A";
      priceDropEl.className = "text-lg sm:text-2xl font-black text-slate-400 Outfit font-extrabold";
    } else {
      const maintenanceLtv = 70;
      const priceDropBuffer = Math.max(0, (1 - (ltv / maintenanceLtv)) * 100);
      priceDropEl.innerText = priceDropBuffer.toFixed(1) + "%";

      if (ltv < 30) {
        riskStatusEl.innerText = "Low Risk";
        riskStatusEl.className = "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 uppercase";
        riskAlertEl.innerText = `Your SBLOC strategy is in a highly secure zone (LTV is under 30%). Your portfolio value must drop by ${priceDropBuffer.toFixed(1)}% before triggering a margin call.`;
        riskAlertEl.className = "p-4 rounded-xl text-xs leading-relaxed transition-all duration-300 bg-emerald-500/10 border border-emerald-500/20 text-emerald-300";
        priceDropEl.className = "text-lg sm:text-2xl font-black text-emerald-400 Outfit font-extrabold";
      } else if (ltv <= 50) {
        riskStatusEl.innerText = "Moderate Risk";
        riskStatusEl.className = "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 border border-amber-500/30 uppercase";
        riskAlertEl.innerText = `LTV is in the moderate range (30-50%). Avoid additional leverage. A portfolio drop of ${priceDropBuffer.toFixed(1)}% will trigger a margin call.`;
        riskAlertEl.className = "p-4 rounded-xl text-xs leading-relaxed transition-all duration-300 bg-amber-500/10 border border-amber-500/20 text-emerald-300";
        priceDropEl.className = "text-lg sm:text-2xl font-black text-amber-400 Outfit font-extrabold";
      } else {
        riskStatusEl.innerText = "High Risk";
        riskStatusEl.className = "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-rose-500/10 text-rose-400 border border-rose-500/30 uppercase";
        if (ltv >= 70) {
          riskAlertEl.innerText = "ALERT: Current LTV is at or above the 70% Maintenance Threshold! You are in danger of immediate liquidation. Reduce debt or add collateral.";
          priceDropEl.innerText = "0.0%";
        } else {
          riskAlertEl.innerText = `WARNING: High LTV detected (>50%). Extremely vulnerable to volatility. A small drop of ${priceDropBuffer.toFixed(1)}% will trigger a margin call.`;
        }
        riskAlertEl.className = "p-4 rounded-xl text-xs leading-relaxed transition-all duration-300 bg-rose-500/10 border border-rose-500/20 text-rose-300";
        priceDropEl.className = "text-lg sm:text-2xl font-black text-rose-400 Outfit font-extrabold";
      }
    }
  }

