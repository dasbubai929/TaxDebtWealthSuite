  <script is:inline define:vars={{ searchDataJson }}>
    // @ts-nocheck
    (function() {
      var searchData = JSON.parse(searchDataJson);
      var input = document.getElementById("predictive-search-input");
      var dropdown = document.getElementById("search-results-dropdown");
      var searchForm = document.getElementById("search-form");
      var kbdHint = document.querySelector(".search-bar-kbd");
      if (!input || !dropdown) return;

      var activeIndex = -1;

      function hl(text, q) {
        if (!q) return text;
        var esc = q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        return text.replace(new RegExp("(" + esc + ")", "gi"), '<mark style="color:#00F5D4;font-weight:600;background:none">$1</mark>');
      }

      function updateActiveItem(items) {
        for (var i = 0; i < items.length; i++) {
          if (i === activeIndex) {
            items[i].classList.add("search-item-active");
            items[i].style.background = "rgba(0,245,212,0.12)";
            items[i].style.borderLeftColor = "#00F5D4";
            items[i].scrollIntoView({ block: "nearest" });
          } else {
            items[i].classList.remove("search-item-active");
            items[i].style.background = "transparent";
            items[i].style.borderLeftColor = "transparent";
          }
        }
      }

      function renderDropdown(query) {
        var trimmed = query.trim().toLowerCase();
        activeIndex = -1;
        if (!trimmed) {
          dropdown.classList.add("hidden");
          if (kbdHint) kbdHint.style.display = "none";
          return;
        }
        if (kbdHint) kbdHint.style.display = "inline-flex";

        var matchedTools = [];
        var matchedPosts = [];

        for (var t = 0; t < searchData.tools.length; t++) {
          var tool = searchData.tools[t];
          for (var v = 0; v < tool.variants.length; v++) {
            var variant = tool.variants[v];
            var haystack = (tool.name + " " + variant.label).toLowerCase();
            if (haystack.indexOf(trimmed) !== -1) {
              matchedTools.push({ name: tool.name, label: variant.label, url: variant.url });
            }
          }
        }

        for (var p = 0; p < searchData.posts.length; p++) {
          var post = searchData.posts[p];
          var haystack = (post.title + " " + post.description).toLowerCase();
          if (haystack.indexOf(trimmed) !== -1) {
            matchedPosts.push(post);
          }
        }

        if (matchedTools.length === 0 && matchedPosts.length === 0) {
          dropdown.innerHTML = '<div style="padding:18px 14px;text-align:center;font-size:12px;color:#475569;font-family:Inter,system-ui,sans-serif">No results for \u201c' + trimmed + '\u201d</div>';
          dropdown.classList.remove("hidden");
          return;
        }

        // Style constants — all inline to bypass Astro scoping
        var S_HEAD = 'style="padding:9px 14px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:#00F5D4;font-family:Outfit,Inter,system-ui,sans-serif;background:rgba(0,245,212,0.06);border-bottom:1px solid rgba(0,245,212,0.12);margin:0"';
        var S_ROW = 'style="display:block;padding:8px 14px 8px 20px;text-decoration:none;color:#E2E8F0;font-size:13px;font-weight:400;font-family:Inter,system-ui,sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;border-left:2px solid transparent;transition:background .12s ease"';
        var S_ROW_HOVER = 'onmouseover="this.style.background=\'rgba(0,245,212,0.06)\';this.style.borderLeftColor=\'#00F5D4\'" onmouseout="if(!this.classList.contains(\'search-item-active\')){this.style.background=\'transparent\';this.style.borderLeftColor=\'transparent\'}"';
        var S_SUB = 'style="font-size:11px;color:#64748B;margin-left:6px;font-weight:400"';
        var S_DIV = 'style="height:1px;background:#1E294B;margin:0"';

        var html = '';

        if (matchedTools.length > 0) {
          html += '<div ' + S_HEAD + '>Calculators \u0026 Tools</div>';
          for (var i = 0; i < matchedTools.length; i++) {
            var item = matchedTools[i];
            html += '<a href="' + item.url + '" class="search-result-item" ' + S_ROW + ' ' + S_ROW_HOVER + '>' +
              hl(item.name, trimmed) +
              '<span ' + S_SUB + '>' + hl(item.label, trimmed) + '</span>' +
              '</a>';
          }
        }

        if (matchedPosts.length > 0) {
          if (matchedTools.length > 0) html += '<div ' + S_DIV + '></div>';
          html += '<div ' + S_HEAD + '>Blog Posts</div>';
          for (var j = 0; j < matchedPosts.length; j++) {
            var postItem = matchedPosts[j];
            html += '<a href="/blog/' + postItem.slug + '/" class="search-result-item" ' + S_ROW + ' ' + S_ROW_HOVER + '>' +
              hl(postItem.title, trimmed) +
              '</a>';
          }
        }

        dropdown.innerHTML = html;
        dropdown.classList.remove("hidden");

        var resultItems = dropdown.querySelectorAll(".search-result-item");
        for (var k = 0; k < resultItems.length; k++) {
          (function(idx) {
            resultItems[idx].addEventListener("mouseenter", function() {
              activeIndex = idx;
              updateActiveItem(resultItems);
            });
          })(k);
        }
      }

      function submitSearch() {
        var items = dropdown.querySelectorAll(".search-result-item");
        if (items.length > 0) {
          var targetIdx = activeIndex >= 0 && activeIndex < items.length ? activeIndex : 0;
          var targetUrl = items[targetIdx].getAttribute("href");
          if (targetUrl) {
            window.location.href = targetUrl;
          }
        }
      }

      if (searchForm) {
        searchForm.addEventListener("submit", function(e) {
          e.preventDefault();
          submitSearch();
        });
      }

      input.addEventListener("input", function() {
        renderDropdown(this.value);
      });

      document.addEventListener("click", function(e) {
        if (!dropdown.contains(e.target) && e.target !== input) {
          dropdown.classList.add("hidden");
          if (kbdHint) kbdHint.style.display = "none";
        }
      });

      input.addEventListener("focus", function() {
        if (this.value.trim()) {
          renderDropdown(this.value);
        }
      });

      input.addEventListener("keydown", function(e) {
        var items = dropdown.querySelectorAll(".search-result-item");

        if (e.key === "ArrowDown") {
          e.preventDefault();
          if (items.length > 0) {
            activeIndex = (activeIndex + 1) % items.length;
            updateActiveItem(items);
          }
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          if (items.length > 0) {
            activeIndex = (activeIndex - 1 + items.length) % items.length;
            updateActiveItem(items);
          }
        } else if (e.key === "Enter") {
          e.preventDefault();
          submitSearch();
        } else if (e.key === "Escape") {
          e.preventDefault();
          dropdown.classList.add("hidden");
          if (kbdHint) kbdHint.style.display = "none";
          this.blur();
        }
      });
    })();
  </script>

  <!-- Carousel Drag/Swipe + Nav Logic -->
  <script is:inline>
    // @ts-nocheck
    (function() {
      var track = document.getElementById('carousel-track');
      var prevBtn = document.getElementById('carousel-prev');
      var nextBtn = document.getElementById('carousel-next');
      if (!track) return;

      var CARD_WIDTH = 320; // card width + gap

      // Navigation buttons
      if (prevBtn) {
        prevBtn.addEventListener('click', function() {
          track.scrollBy({ left: -CARD_WIDTH, behavior: 'smooth' });
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', function() {
          track.scrollBy({ left: CARD_WIDTH, behavior: 'smooth' });
        });
      }

      // Pointer-based drag (works for both mouse and touch)
      var isPointerDown = false;
      var isDragging = false;
      var startX = 0;
      var scrollStart = 0;
      var dragDistance = 0;
      var dragThreshold = 6; // pixels before we consider it a drag gesture

      track.addEventListener('pointerdown', function(e) {
        if (e.button !== 0) return;
        isPointerDown = true;
        isDragging = false;
        dragDistance = 0;
        startX = e.clientX;
        scrollStart = track.scrollLeft;
      });

      track.addEventListener('pointermove', function(e) {
        if (!isPointerDown) return;
        var dx = e.clientX - startX;
        dragDistance = Math.abs(dx);

        if (!isDragging && dragDistance > dragThreshold) {
          isDragging = true;
          try {
            track.setPointerCapture(e.pointerId);
          } catch (err) {}
          track.style.cursor = 'grabbing';
          track.style.scrollSnapType = 'none';
          track.style.userSelect = 'none';
        }

        if (isDragging) {
          e.preventDefault();
          track.scrollLeft = scrollStart - dx;
        }
      });

      function stopDrag(e) {
        if (!isPointerDown) return;
        isPointerDown = false;
        if (isDragging) {
          isDragging = false;
          try {
            track.releasePointerCapture(e.pointerId);
          } catch (err) {}
          track.style.cursor = '';
          track.style.userSelect = '';
          setTimeout(function() {
            track.style.scrollSnapType = 'x mandatory';
          }, 50);
        }
      }

      track.addEventListener('pointerup', stopDrag);
      track.addEventListener('pointercancel', stopDrag);

      // Prevent link navigation ONLY if a real drag occurred
      track.addEventListener('click', function(e) {
        if (dragDistance > dragThreshold) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);

      // Prevent native image drag
      track.addEventListener('dragstart', function(e) {
        e.preventDefault();
      });
    })();
  </script>

