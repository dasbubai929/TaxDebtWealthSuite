---
import Layout from "../../layouts/Layout.astro";
import SaltCapCalculator from "../../components/SaltCapCalculator.astro";
---

<Layout
  title="SALT Cap Deduction Calculator | 2026 $40,400 Limit Explained"
  description="See exactly how much of your state and local tax deduction you can claim under the new $40,400 SALT cap, including the high-income phase-down."
>
  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "SALT Cap Deduction Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "description": "See exactly how much of your state and local tax deduction you can claim under the new $40,400 SALT cap, including the high-income phase-down."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the SALT cap limit?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The SALT cap limits federal itemized deductions for State and Local Taxes (income, sales, and property taxes). For 2026, the cap is $40,400 with a phase-down for high earners."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        SALT Cap Deduction Calculator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Calculate your allowable SALT deduction under the 2026 $40,400 cap. Model the high-income phase-down and PTET workaround savings.
      </p>
    </div>

    <SaltCapCalculator />
  </main>
</Layout>
