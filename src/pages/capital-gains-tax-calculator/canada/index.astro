---
import Layout from "../../../layouts/Layout.astro";
import CapitalGainsTaxCalculator from "../../../components/CapitalGainsTaxCalculator.astro";
---

<Layout
  title="Capital Gains Tax Calculator (Canada) | CRA Inclusion Rates"
  description="Estimate your Canadian capital gains tax liability. Automatically applies the 50% inclusion rate and provincial tax brackets."
  ogImage="https://taxdebtwealthsuite.com/images/og-capital-gains-tax.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/capital-gains-tax-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Capital Gains Tax Calculator (Canada)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CAD" },
        "description": "Estimate Canadian capital gains tax liability with 50% inclusion rate and provincial tax brackets."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the capital gains inclusion rate in Canada?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Historically, 50% of your capital gain is included in your taxable income. The 2024 Federal Budget introduced a two-tiered system for amounts exceeding $250,000."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Capital Gains Tax Calculator (Canada)
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Estimate your CRA capital gains tax liability with automatic inclusion rate calculations and provincial tax bracket modeling.
      </p>
    </div>

    <CapitalGainsTaxCalculator defaultCountry="CA" />
  </main>
</Layout>
