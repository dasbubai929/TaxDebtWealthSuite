---
import Layout from "../../layouts/Layout.astro";
import DebtPayoffCalculator from "../../components/DebtPayoffCalculator.astro";
---

<Layout
  title="Debt Snowball vs Avalanche Calculator | TaxDebtWealthSuite"
  description="See which debt payoff method saves you more. Compare Snowball vs Avalanche side-by-side. Calculate total interest and payoff dates."
  ogImage="https://taxdebtwealthsuite.com/images/og-debt-payoff.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/debt-payoff-calculator/" slot="head" />
  <link rel="alternate" hreflang="en" href="https://taxdebtwealthsuite.com/debt-payoff-calculator/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "Debt Snowball vs Avalanche Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "description": "See which debt payoff method saves you more. Compare Snowball vs Avalanche side-by-side."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the difference between Debt Snowball and Debt Avalanche?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Debt Snowball pays off smallest balances first for psychological quick wins. Debt Avalanche pays off highest interest rate debts first to mathematically minimize total interest paid."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        Debt Snowball vs Avalanche Calculator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Compare Snowball vs Avalanche debt payoff strategies side-by-side. Calculate total interest, payoff dates, and find the fastest path to debt freedom.
      </p>
    </div>

    <DebtPayoffCalculator defaultCurrency="USD" />
  </main>
</Layout>
