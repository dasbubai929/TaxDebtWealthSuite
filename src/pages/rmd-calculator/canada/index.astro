---
import Layout from "../../../layouts/Layout.astro";
import RmdCalculator from "../../../components/RmdCalculator.astro";
---

<Layout
  title="Canada RRIF Minimum Withdrawal Calculator"
  description="Calculate your mandatory CRA minimum withdrawal for your Registered Retirement Income Fund."
>
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "RRIF Minimum Withdrawal Calculator (Canada)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": {
          "@id": "https://taxdebtwealthsuite.com/#organization"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "CAD"
        },
        "description": "Calculate your mandatory CRA minimum withdrawal for your Registered Retirement Income Fund."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "When do I have to convert my RRSP to a RRIF?",
            "acceptedAnswer": {
               "@type": "Answer",
               "text": "In Canada, you must convert your Registered Retirement Savings Plan (RRSP) into a Registered Retirement Income Fund (RRIF) by the end of the year you turn 71."
            }
          },
          {
            "@type": "Question",
            "name": "How is the minimum RRIF withdrawal calculated?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The minimum withdrawal is calculated using a percentage factor set by the CRA that increases as you age, applied to your RRIF balance at the start of the year."
            }
          }
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://taxdebtwealthsuite.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Canada RRIF Minimum Withdrawal Calculator",
            "item": "https://taxdebtwealthsuite.com/rmd-calculator/canada/"
          }
        ]
      }
    ]
  }
  </script>

  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    <!-- Title Section -->
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        RRIF Minimum Withdrawal Calculator (Canada)
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-xs font-medium text-slate-500 bg-slate-900/50 inline-flex px-3 py-1.5 rounded-lg border border-slate-800">
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#00F5D4]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>Reviewed by <a href="/editorial-policy/" class="text-slate-400 hover:text-[#00F5D4] transition-colors underline decoration-slate-700 underline-offset-2">Editorial Staff</a></span>
        </div>
      </div>
      <p class="text-sm text-slate-400 mt-2 max-w-2xl leading-relaxed">
        Calculate your mandatory CRA minimum withdrawal for your Registered Retirement Income Fund.
      </p>
    </div>

    <!-- Calculator Component Island -->
    <RmdCalculator country="canada" />

    <!-- Explainer Content -->
    <div class="border-t border-slate-800/60 mt-12 bg-gradient-to-b from-slate-950 to-slate-950/95">
      <div class="max-w-4xl mx-auto py-16">
        <section>
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">Financial Tool</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight leading-snug">
              Understanding RRIF Minimum Withdrawals
            </h2>
          </div>

          <div class="space-y-8 text-sm text-slate-400 leading-relaxed">
            <article>
              <h3 class="text-xl font-bold text-slate-100 mb-3">Introduction</h3>
              <p>In Canada, you must collapse your Registered Retirement Savings Plan (RRSP) by December 31 of the year you turn 71. Most Canadians transfer their RRSP into a Registered Retirement Income Fund (RRIF). Once you have a RRIF, the Canada Revenue Agency (CRA) mandates that you withdraw a minimum percentage of its value each year.</p>
              <p class="mt-2">To understand more about optimal withdrawal strategies, check out our guide on <a href="/blog/rmd-calculator-canada/" class="text-[#00F5D4] hover:underline">RRSP/RRIF Withdrawal Strategies</a>.</p>
            </article>

          </div>

          <!-- FAQ Accordion -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-amber-500/10 text-amber-400 border border-amber-500/20 mb-4">FAQ</span>
            <h3 class="text-2xl font-bold text-white mb-6">Frequently Asked Questions</h3>

            <div class="space-y-4">
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">When do I have to convert my RRSP to a RRIF?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  In Canada, you must convert your Registered Retirement Savings Plan (RRSP) into a Registered Retirement Income Fund (RRIF) by the end of the year you turn 71.
                </div>
              </div>
              <div class="border border-slate-800 rounded-lg overflow-hidden bg-slate-900/50">
                <button class="w-full flex items-center justify-between px-6 py-5 text-left group cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-180');">
                  <span class="font-semibold text-white">How is the minimum RRIF withdrawal calculated?</span>
                  <svg class="h-5 w-5 text-slate-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="hidden px-6 pb-6 text-sm text-slate-400">
                  The minimum withdrawal is calculated using a percentage factor set by the CRA that increases as you age, applied to your RRIF balance at the start of the year.
                </div>
              </div>
            </div>
          </div>

          <!-- Internal Links -->
          <div class="mt-12 border-t border-slate-800/80 pt-10">
            <h3 class="text-xl font-bold text-white mb-4">Related Calculators</h3>
            <div class="flex flex-col space-y-2">
              <a href="/roth-conversion-calculator/" class="text-[#00F5D4] hover:underline">Roth Conversion Calculator</a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
