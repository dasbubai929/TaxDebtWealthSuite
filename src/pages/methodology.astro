  "debt-payoff": { label: "Debt Payoff Planner", href: "/debt-payoff-calculator/", color: "text-[#F43F5E]" },
  "mortgage-recast": { label: "Mortgage Recast Calculator", href: "/mortgage-recast-calculator/", color: "text-[#14B8A6]" },
  "buy-borrow-die": { label: "Buy, Borrow, Die Calculator", href: "/buy-borrow-die-calculator/", color: "text-[#00F5D4]" },
  "roth-conversion": { label: "Roth Conversion Calculator", href: "/roth-conversion-calculator/", color: "text-[#F59E0B]" },
  "rmd-calculator": { label: "RMD Calculator", href: "/rmd-calculator/", color: "text-[#3B82F6]" },
  "social-security": { label: "Social Security & Pension Estimator", href: "/social-security-pension-estimator/", color: "text-[#10B981]" },
  "superannuation-rrsp": { label: "Superannuation & RRSP Withdrawal", href: "/superannuation-rrsp-withdrawal-calculator/", color: "text-[#A855F7]" }
};
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs}>
  <main class="flex-grow pt-24 pb-20">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-[#7B61FF]/10 text-[#7B61FF] border border-[#7B61FF]/20 mb-4">The Math</span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight font-sans mb-6">
        Calculator <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00F5D4] to-[#7B61FF]">Methodology</span>
      </h1>
      <p class="text-base sm:text-lg text-slate-400 max-w-3xl mx-auto leading-relaxed">
        We believe in complete transparency. Below is a detailed breakdown of the mathematical frameworks, official sources, and country-specific rules that power every calculator on TaxDebtWealthSuite.
      </p>
    </section>

    <!-- Intro Section -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <div class="glass-panel p-6 rounded-2xl border border-slate-800 space-y-4">
        <h2 class="text-xl font-bold text-white">How Our Calculations Work</h2>
        <p class="text-sm text-slate-400 leading-relaxed">
          All mathematical functions execute in your local browser using client-side JavaScript. We do not use server-side APIs to process your financial data, ensuring complete privacy. Our formulas are based on official government publications and regulatory guidelines from the IRS, HMRC, CRA, and ATO.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[#00F5D4]/10 text-[#00F5D4] border border-[#00F5D4]/20">Client-Side Only</span>
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[#7B61FF]/10 text-[#7B61FF] border border-[#7B61FF]/20">No Data Storage</span>
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[#FF6B6B]/10 text-[#FF6B6B] border border-[#FF6B6B]/20">Open Formulas</span>
        </div>
      </div>
    </section>

    <!-- Category Filters -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <div class="flex flex-wrap items-center justify-center gap-3">
        <button class="filter-btn active px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-[#00F5D4]/10 text-[#00F5D4] border border-[#00F5D4]/30" data-filter="all">All</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="tax">Tax</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="debt">Debt</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="wealth">Wealth</button>
        <button class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-slate-900 text-slate-400 border border-slate-700 hover:text-white hover:bg-slate-800" data-filter="retirement">Retirement</button>
      </div>
    </section>

    <!-- Methodology Entries -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8 mb-16">
      {calculators.map((calc) => (
        <article class="methodology-card glass-panel p-6 sm:p-8 rounded-2xl border border-slate-800 space-y-6" data-category={calc.category}>
          <!-- Header -->
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
            <div class="space-y-2 flex-1">
              <div class="flex items-center gap-3">
                <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest" style={`background-color: ${calc.color}15; color: ${calc.color}; border: 1px solid ${calc.color}30`}>
                  {calc.category}
                </span>
              </div>
              <h2 class="text-2xl font-bold text-white">{calc.title}</h2>
              <p class="text-sm text-slate-400 leading-relaxed">{calc.description}</p>
            </div>
            <a href={calc.href} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold transition-all duration-200 hover:scale-105 shrink-0" style={`background-color: ${calc.color}15; color: ${calc.color}; border: 1px solid ${calc.color}30;`}>
              Try Calculator →
            </a>
          </div>

          <!-- Methodology Content -->
          <div class="prose prose-invert prose-sm max-w-none">
            <div class="text-sm text-slate-300 leading-relaxed whitespace-pre-line">{calc.methodology}</div>
          </div>

          <!-- Official Sources -->
          <div class="space-y-3">
            <h3 class="text-sm font-bold text-white uppercase tracking-wider">Official Sources</h3>
            <div class="flex flex-wrap gap-2">
              {calc.sources.map((source) => (
                <a href={source.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-slate-900 text-slate-300 border border-slate-700 hover:border-[#00F5D4]/40 hover:text-[#00F5D4] transition-all focus-ring">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  {source.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Related Calculators -->
          <div class="pt-4 border-t border-slate-800">
            <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-3">Related Calculators</h3>
            <div class="flex flex-wrap gap-2">
              {calc.related.map((relKey) => {
                const rel = relatedCalcMap[relKey];
                return rel ? (
                  <a href={rel.href} class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-slate-900 border border-slate-700 hover:border-[#00F5D4]/40 transition-all focus-ring ${rel.color}`}>
                    {rel.label}
                  </a>
                ) : null;
              })}
            </div>
          </div>

          <!-- Blog Link -->
          <div class="pt-2">
            <a href={calc.blog} class="inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-[#00F5D4] transition-colors font-semibold">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              Read the full guide →
            </a>
          </div>
        </article>
      ))}
    </section>

    <!-- Future Calculators Note -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <div class="glass-panel p-6 rounded-2xl border border-[#00F5D4]/20 bg-[#00F5D4]/5 space-y-3">
        <h2 class="text-lg font-bold text-[#00F5D4]">Adding New Calculators</h2>
        <p class="text-sm text-slate-400 leading-relaxed">
          Whenever a new calculator is added to TaxDebtWealthSuite, a corresponding methodology entry is automatically generated on this page following the standardized template above. Each entry includes the calculation methodology, official sources, internal links to the calculator and blog guide, and related calculator cross-links.
        </p>
      </div>
    </section>
  </main>

  <!-- Filter Script -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.methodology-card');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          filterBtns.forEach(b => {
            b.classList.remove('active', 'bg-[#00F5D4]/10', 'text-[#00F5D4]', 'border-[#00F5D4]/30');
            b.classList.add('bg-slate-900', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:bg-slate-800');
          });
          btn.classList.add('active', 'bg-[#00F5D4]/10', 'text-[#00F5D4]', 'border-[#00F5D4]/30');
          btn.classList.remove('bg-slate-900', 'text-slate-400', 'border-slate-700', 'hover:text-white', 'hover:bg-slate-800');

          const filter = btn.getAttribute('data-filter');
          cards.forEach(card => {
            if (filter === 'all' || card.getAttribute('data-category') === filter) {
              card.style.display = 'block';
            } else {
              card.style.display = 'none';
            }
          });
        });
      });
    });
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How are calculations performed on TaxDebtWealthSuite?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All mathematical functions execute in your local browser using client-side JavaScript. We do not use server-side APIs to process your financial data, ensuring complete privacy. Our formulas are based on official government publications from the IRS, HMRC, CRA, and ATO."
          }
        },
        {
          "@type": "Question",
          "name": "Are these calculators country-specific?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Many calculators support multiple jurisdictions including the US, UK, Canada, and Australia. Each country variant uses country-specific tax rates, pension rules, and regulatory formulas. For example, the S-Corp Tax Calculator models S-Corps in the US, Ltd companies in the UK, CCPCs in Canada, and Pty Ltd companies in Australia."
          }
        },
        {
          "@type": "Question",
          "name": "Which official sources are used for the calculations?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our calculators use official sources including IRS.gov (US tax rules), HMRC.gov.uk (UK tax rules), Canada.ca/CRA (Canadian tax rules), and ATO.gov.au (Australian tax rules). Each methodology entry on this page links directly to the relevant official publications."
          }
        },
        {
          "@type": "Question",
          "name": "What is the methodology for the Debt Payoff Calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Debt Payoff Planner uses the standard amortization formula N = -log(1 - (r * P) / A) / log(1 + r) to calculate payoff timelines. It compares Snowball (smallest balance first) and Avalanche (highest interest rate first) strategies with month-by-month schedules."
          }
        },
        {
          "@type": "Question",
          "name": "How does the Buy, Borrow, Die calculator work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Buy, Borrow, Die calculator models two wealth-access strategies: selling appreciated assets (triggering capital gains tax) versus borrowing against them via a Securities-Based Line of Credit (SBLOC). It calculates tax drag, SBLOC costs, margin call risk (LTV), and net wealth advantage over time."
          }
        }
      ]
    }
  </script>
</Layout>
