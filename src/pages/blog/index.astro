---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const toolLabels: Record<string, { label: string; href: string; color: string }> = {
  "buy-borrow-die-calculator": {
    label: "Buy, Borrow, Die",
    href: "/buy-borrow-die-calculator/",
    color: "text-[#00F5D4] bg-[#00F5D4]/10 border-[#00F5D4]/20",
  },
  "s-corp-tax-calculator": {
    label: "S-Corp Tax",
    href: "/s-corp-tax-calculator/",
    color: "text-[#10B981] bg-[#10B981]/10 border-[#10B981]/20",
  },
  "debt-payoff-calculator": {
    label: "Debt Payoff",
    href: "/debt-payoff-calculator/",
    color: "text-[#F43F5E] bg-[#F43F5E]/10 border-[#F43F5E]/20",
  },
  "qbi-deduction-calculator": {
    label: "QBI Deduction",
    href: "/qbi-deduction-calculator/",
    color: "text-[#06B6D4] bg-[#06B6D4]/10 border-[#06B6D4]/20",
  },
  "salt-cap-deduction-calculator": {
    label: "SALT Cap",
    href: "/salt-cap-deduction-calculator/",
    color: "text-[#A855F7] bg-[#A855F7]/10 border-[#A855F7]/20",
  },
  "roth-conversion-calculator": {
    label: "Roth Conversion",
    href: "/roth-conversion-calculator/",
    color: "text-[#F59E0B] bg-[#F59E0B]/10 border-[#F59E0B]/20",
  },
};
---

<Layout
  title="Financial Strategy Blog — Tax, Debt & Wealth Tips | TaxDebtWealthSuite"
  description="Expert articles on S-Corp tax strategies, Buy Borrow Die wealth planning, and debt payoff methods. Long-tail guides with real numbers for US, UK, Canada & Australia."
  ogImage="https://taxdebtwealthsuite.com/images/og-home.png"
>
  <!-- Hero -->
  <section class="py-14 sm:py-20 text-center max-w-4xl mx-auto px-4">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-[#00F5D4]/10 text-[#00F5D4] border border-[#00F5D4]/20 mb-6">
      Strategy Hub
    </div>
    <h1 class="text-4xl sm:text-6xl font-black text-white tracking-tight leading-none font-sans">
      Financial Strategy Blog
    </h1>
    <p class="mt-6 text-sm sm:text-base text-slate-400 leading-relaxed max-w-2xl mx-auto">
      Deep-dive guides on tax optimization, wealth-building leverage strategies, and debt elimination — all with real numbers and links to free calculators.
    </p>
    <!-- RSS Link -->
    <a
      href="/blog/rss.xml"
      class="inline-flex items-center gap-2 mt-6 text-xs text-slate-500 hover:text-orange-400 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93z"/>
      </svg>
      Subscribe via RSS
    </a>
  </section>

  <!-- Article Grid -->
  <section class="max-w-6xl mx-auto px-4 pb-20">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {allPosts.map((post) => {
        const tool = toolLabels[post.data.relatedTool] || {
          label: "Calculator",
          href: `/${post.data.relatedTool}/`,
          color: "text-[#00F5D4] bg-[#00F5D4]/10 border-[#00F5D4]/20",
        };
        return (
          <a
            href={`/blog/${post.slug}/`}
            class="group relative flex flex-col rounded-2xl border border-white/5 bg-white/[0.03] p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/[0.06] hover:-translate-y-1"
          >
            <!-- Tool badge -->
            <span class={`inline-flex w-fit items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest border mb-4 ${tool.color}`}>
              {tool.label}
            </span>
            <h2 class="text-base font-semibold text-white leading-snug group-hover:text-[#00F5D4] transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-2 text-sm text-slate-400 leading-relaxed flex-1">
              {post.data.description}
            </p>
            <div class="mt-4 flex items-center justify-between text-xs text-slate-600">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
              </time>
              <span class="text-slate-500 group-hover:text-[#00F5D4] transition-colors">Read →</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Calculator CTA strip -->
  <section class="max-w-4xl mx-auto px-4 pb-20">
    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8 text-center">
      <p class="text-sm text-slate-400 mb-4">Ready to run the numbers yourself?</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/s-corp-tax-calculator/" class="px-4 py-2 rounded-lg bg-[#10B981]/10 border border-[#10B981]/20 text-[#10B981] text-sm font-semibold hover:bg-[#10B981]/20 transition-colors">
          S-Corp Tax Calculator →
        </a>
        <a href="/debt-payoff-calculator/" class="px-4 py-2 rounded-lg bg-[#F43F5E]/10 border border-[#F43F5E]/20 text-[#F43F5E] text-sm font-semibold hover:bg-[#F43F5E]/20 transition-colors">
          Debt Payoff Planner →
        </a>
        <a href="/buy-borrow-die-calculator/" class="px-4 py-2 rounded-lg bg-[#00F5D4]/10 border border-[#00F5D4]/20 text-[#00F5D4] text-sm font-semibold hover:bg-[#00F5D4]/20 transition-colors">
          Buy, Borrow, Die Calculator →
        </a>
        <a href="/qbi-deduction-calculator/" class="px-4 py-2 rounded-lg bg-[#06B6D4]/10 border border-[#06B6D4]/20 text-[#06B6D4] text-sm font-semibold hover:bg-[#06B6D4]/20 transition-colors">
          QBI Deduction Calculator →
        </a>
        <a href="/salt-cap-deduction-calculator/" class="px-4 py-2 rounded-lg bg-[#A855F7]/10 border border-[#A855F7]/20 text-[#A855F7] text-sm font-semibold hover:bg-[#A855F7]/20 transition-colors">
          SALT Cap Calculator →
        </a>
        <a href="/roth-conversion-calculator/" class="px-4 py-2 rounded-lg bg-[#F59E0B]/10 border border-[#F59E0B]/20 text-[#F59E0B] text-sm font-semibold hover:bg-[#F59E0B]/20 transition-colors">
          Roth Conversion Calculator →
        </a>
        <a href="/rmd-calculator/" class="px-4 py-2 rounded-lg bg-[#3B82F6]/10 border border-[#3B82F6]/20 text-[#3B82F6] text-sm font-semibold hover:bg-[#3B82F6]/20 transition-colors">
          RMD Calculator →
        </a>
        <a href="/capital-gains-tax-calculator/" class="px-4 py-2 rounded-lg bg-[#34D399]/10 border border-[#34D399]/20 text-[#34D399] text-sm font-semibold hover:bg-[#34D399]/20 transition-colors">
          Capital Gains Tax Calculator →
        </a>
      </div>
    </div>
  </section>
</Layout>
