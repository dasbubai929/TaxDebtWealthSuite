---
import Layout from "../../layouts/Layout.astro";
import QBIDeductionCalculator from "../../components/QBIDeductionCalculator.astro";
---

<Layout
  title="QBI Deduction Calculator | Section 199A Pass-Through Tax Savings"
  description="Calculate your Section 199A Qualified Business Income deduction. See exactly how the 20% deduction, W-2 wage limits, and SSTB rules affect your tax savings."
>
  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "QBI Deduction Calculator",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "description": "Calculate your Section 199A Qualified Business Income deduction. See exactly how the 20% deduction, W-2 wage limits, and SSTB rules affect your tax savings."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is the Section 199A QBI deduction limit?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The QBI deduction allows eligible pass-through business owners to deduct up to 20% of qualified business income, subject to wage and property limits above certain income thresholds."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        QBI Deduction Calculator
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Calculate your Section 199A Qualified Business Income deduction. See how the 20% deduction, W-2 wage limits, and SSTB rules affect your tax savings.
      </p>
    </div>

    <QBIDeductionCalculator />
  </main>
</Layout>
