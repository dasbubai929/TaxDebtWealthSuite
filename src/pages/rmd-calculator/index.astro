---
import Layout from "../../layouts/Layout.astro";
import RmdCalculator from "../../components/RmdCalculator.astro";
---

<Layout
  title="Required Minimum Distribution (RMD) Calculator"
  description="Calculate your IRS required minimum distribution based on the SECURE Act 2.0 Uniform Lifetime Table."
  ogImage="https://taxdebtwealthsuite.com/images/og-rmd-calculator.png"
>
  <link rel="alternate" hreflang="x-default" href="https://taxdebtwealthsuite.com/rmd-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-us" href="https://taxdebtwealthsuite.com/rmd-calculator/" slot="head" />
  <link rel="alternate" hreflang="en-gb" href="https://taxdebtwealthsuite.com/rmd-calculator/uk/" slot="head" />
  <link rel="alternate" hreflang="en-ca" href="https://taxdebtwealthsuite.com/rmd-calculator/canada/" slot="head" />
  <link rel="alternate" hreflang="en-au" href="https://taxdebtwealthsuite.com/rmd-calculator/australia/" slot="head" />

  <script type="application/ld+json" is:inline slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FinanceApplication",
        "name": "RMD Calculator (US)",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "provider": { "@id": "https://taxdebtwealthsuite.com/#organization" },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "description": "Calculate your IRS required minimum distribution based on the SECURE Act 2.0 Uniform Lifetime Table."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "At what age do RMDs start?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Under the SECURE Act 2.0, RMDs generally start at age 73 for those born between 1951 and 1959, and age 75 for those born in 1960 or later."
            }
          },
          {
            "@type": "Question",
            "name": "How is the RMD calculated?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Your RMD is calculated by dividing your tax-deferred retirement account balance as of December 31 of the previous year by a life expectancy factor from the IRS Uniform Lifetime Table."
            }
          },
          {
            "@type": "Question",
            "name": "What happens if I don't take my RMD?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "If you fail to take your full RMD on time, you may be subject to an excise tax (penalty) of 25% on the amount not withdrawn. This penalty can be reduced to 10% if corrected in a timely manner."
            }
          }
        ]
      }
    ]
  }
  </script>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center sm:text-left">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans">
        RMD Calculator (US)
      </h1>
      <p class="mt-2 text-sm text-slate-400 max-w-3xl">
        Calculate your IRS required minimum distribution based on the SECURE Act 2.0 Uniform Lifetime Table. Avoid the 25% excise tax on missed withdrawals.
      </p>
    </div>

    <RmdCalculator country="us" />
  </main>
</Layout>
